@inject NavigationManager NavigationManager

<MudPaper Elevation="0" Style="background:transparent" Class="pa-2">
    <MudNavMenu Dense="true" Rounded="true" Margin="Margin.Dense" Color="Color.Primary" Class="ca-nav-menu">
        <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Accueil</MudNavLink>
        <MudNavLink Href="/vision-globale" Icon="@Icons.Material.Filled.PieChart">Vision Globale</MudNavLink>
        <MudNavLink Href="/portefeuille" Icon="@Icons.Material.Filled.BusinessCenter">Dimensionnement par agence</MudNavLink>
        <MudNavLink Href="/regles-hypotheses" Icon="@Icons.Material.Filled.Tune">Règles & Hypothèses</MudNavLink>
        <MudNavLink Href="/Administration" Icon="@Icons.Material.Filled.Settings">Administration</MudNavLink>
        <MudNavLink Href="/Help" Icon="@Icons.Material.Filled.HelpOutline">Assistance</MudNavLink>
    </MudNavMenu>
</MudPaper>

@code {
    private string tag = string.Empty;

    protected override void OnInitialized()
    {
        tag = NavigationManager.Uri.Replace(NavigationManager.BaseUri, string.Empty);
    }
}
