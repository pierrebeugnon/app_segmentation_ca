@page "/portefeuilles-vision-etp"
@inject MockDataService DataService
@inject SegmentationStateService StateService
@implements IDisposable

<PageTitle>Portefeuilles / Vision ETP — CA Segmentation</PageTitle>

<div class="ca-page">
    <div class="ca-page-header">
        <div>
            <MudText Typo="Typo.h5" Class="ca-page-title">Portefeuilles / Vision ETP</MudText>
            <MudText Typo="Typo.caption" Class="ca-page-subtitle">Dimensionnement des portefeuilles et profils de conseillers (en ETP)</MudText>
        </div>
        <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
            <MudButton StartIcon="@Icons.Material.Filled.Language"
                       Variant="@(vueReseau ? Variant.Filled : Variant.Outlined)"
                       Color="@(vueReseau ? Color.Primary : Color.Default)"
                       OnClick="() => SetVue(true)">Vue Réseau</MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.Business"
                       Variant="@(!vueReseau ? Variant.Filled : Variant.Outlined)"
                       Color="@(!vueReseau ? Color.Primary : Color.Default)"
                       OnClick="() => SetVue(false)">Vue par Agence</MudButton>
        </MudButtonGroup>
    </div>

    <MudPaper Elevation="2" Style="border-radius:8px;overflow:hidden" Class="mb-4">
        <div class="ca-section-header">
            <span class="ca-section-badge">1</span>
            Dimensionnement cible des portefeuilles et des conseillers (en ETP)
        </div>
        <MudTable Items="@cibleRows" Dense="true" Hover="true" Elevation="0"
                  RowClassFunc="@((r,i) => r.IsBold ? "mud-row-bold" : r.IsEcart ? "mud-row-ecart" : "")">
            <HeaderContent>
                <MudTh>Lignes</MudTh>
                <MudTh Style="text-align:right">Portefeuilles Mutualisés</MudTh>
                <MudTh Style="text-align:right">Dédiés</MudTh>
                <MudTh Style="text-align:right">Dédiés – Haut de Gamme</MudTh>
                <MudTh Style="text-align:right">Total</MudTh>
                <MudTh Style="text-align:right">Concordance</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Libelle</MudTd>
                <MudTd Style="text-align:right">@((MarkupString)FormatEtpCell(context.Mutualise, context))</MudTd>
                <MudTd Style="text-align:right">@((MarkupString)FormatEtpCell(context.Dedie, context))</MudTd>
                <MudTd Style="text-align:right">@((MarkupString)FormatEtpCell(context.DedieHautDeGamme, context))</MudTd>
                <MudTd Style="text-align:right">@((MarkupString)FormatEtpCell(context.Total, context))</MudTd>
                <MudTd Style="text-align:right">
                    @if (context.Concordance.HasValue)
                    { <span style="color:#1A4E6B;font-weight:600">@context.Concordance.Value.ToString("F0")%</span> }
                    else { <span style="color:#9AA5B1">—</span> }
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>

    <MudPaper Elevation="2" Style="border-radius:8px;overflow:hidden" Class="mb-4">
        <div class="ca-section-header">
            <span class="ca-section-badge">2</span>
            Dimensionnement des conseillers avec les portefeuilles actuels (en ETP)
        </div>
        <MudTable Items="@actuelRows" Dense="true" Hover="true" Elevation="0"
                  RowClassFunc="@((r,i) => r.IsBold ? "mud-row-bold" : r.IsEcart ? "mud-row-ecart" : "")">
            <HeaderContent>
                <MudTh>Lignes</MudTh>
                <MudTh Style="text-align:right">Portefeuilles Mutualisés</MudTh>
                <MudTh Style="text-align:right">Dédiés</MudTh>
                <MudTh Style="text-align:right">Dédiés – Haut de Gamme</MudTh>
                <MudTh Style="text-align:right">Total</MudTh>
                <MudTh Style="text-align:right">Concordance</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Libelle</MudTd>
                <MudTd Style="text-align:right">@((MarkupString)FormatEtpCell(context.Mutualise, context))</MudTd>
                <MudTd Style="text-align:right">@((MarkupString)FormatEtpCell(context.Dedie, context))</MudTd>
                <MudTd Style="text-align:right">@((MarkupString)FormatEtpCell(context.DedieHautDeGamme, context))</MudTd>
                <MudTd Style="text-align:right">@((MarkupString)FormatEtpCell(context.Total, context))</MudTd>
                <MudTd Style="text-align:right">
                    @if (context.Concordance.HasValue)
                    { <span style="color:#1A4E6B;font-weight:600">@context.Concordance.Value.ToString("F0")%</span> }
                    else { <span style="color:#9AA5B1">—</span> }
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>

    <div class="ca-footer">© 2025 Crédit Agricole Nord de France — Plateforme de Dimensionnement</div>
</div>

@code {
    private bool vueReseau = true;
    private List<DimensionnementEtpRow> cibleRows  = new();
    private List<DimensionnementEtpRow> actuelRows = new();

    protected override void OnInitialized()
    {
        StateService.OnChange += OnReglesChanged;
        LoadData();
    }

    public void Dispose() => StateService.OnChange -= OnReglesChanged;

    private void OnReglesChanged()
    {
        cibleRows = StateService.EtpCibleRows;
        InvokeAsync(StateHasChanged);
    }

    private void SetVue(bool reseau) { vueReseau = reseau; LoadData(); }

    private void LoadData()
    {
        cibleRows  = StateService.EtpCibleRows;
        actuelRows = DataService.GetDimensionnementEtpActuel();
    }

    private string FormatEtpCell(double? val, DimensionnementEtpRow row)
    {
        if (!val.HasValue) return "<span style='color:#9AA5B1'>—</span>";
        var v = val.Value;
        if (row.Libelle.StartsWith("Concordance"))
            return $"<span style='color:#1A4E6B;font-weight:600'>{v:F0}%</span>";
        if (row.IsEcart)
        {
            var color = v > 0 ? "#27AE60" : v < 0 ? "#E74C3C" : "#9AA5B1";
            return $"<span style='color:{color};font-weight:600'>{(v > 0 ? "+" : "")}{v:F2}</span>";
        }
        var boldStyle = row.IsBold ? "font-weight:700;color:#1A4E6B" : "";
        return $"<span style='{boldStyle}'>{v:F2}</span>";
    }
}
