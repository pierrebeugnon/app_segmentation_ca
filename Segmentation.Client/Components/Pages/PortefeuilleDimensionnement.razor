@page "/portefeuille"
@inject SegmentationStateService StateService
@implements IDisposable

<PageTitle>Dimensionnement Portefeuilles — CA Segmentation</PageTitle>

<div class="ca-page">

    <!-- ══════════════════════════════════════════════════════════
         En-tête + toggle ETP / Volume
    ══════════════════════════════════════════════════════════ -->
    <div class="ca-page-header">
        <div>
            <MudText Typo="Typo.h5" Class="ca-page-title">Dimensionnement des Portefeuilles</MudText>
            <MudText Typo="Typo.caption" Class="ca-page-subtitle">
                @(vueEtp
                    ? "Vue ETP — saisie des charges existantes et comparaison à la cible"
                    : "Vue Volume de clients — projection informative")
            </MudText>
        </div>

        <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
            <MudButton StartIcon="@Icons.Material.Filled.AccessTime"
                       Variant="@(vueEtp  ? Variant.Filled : Variant.Outlined)"
                       Color="@(vueEtp    ? Color.Primary  : Color.Default)"
                       OnClick="@(() => vueEtp = true)">Vue ETP</MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.People"
                       Variant="@(!vueEtp ? Variant.Filled : Variant.Outlined)"
                       Color="@(!vueEtp   ? Color.Primary  : Color.Default)"
                       OnClick="@(() => vueEtp = false)">Vue Volume</MudButton>
        </MudButtonGroup>
    </div>

    <!-- ── Légende ───────────────────────────────────────────────────── -->
    <div class="ca-dim-legend-bar">
        <!-- Couleurs -->
        <span class="ca-dim-legend-item">
            <span class="ca-dim-swatch" style="background:#1A6B3C"></span>Prioritaire
        </span>
        <span class="ca-dim-legend-item">
            <span class="ca-dim-swatch" style="background:#52A86B"></span>Secondaire
        </span>
        <span class="ca-dim-legend-item">
            <span class="ca-dim-swatch" style="background:#C3E6CB;border:1px solid #52A86B"></span>Tertiaire
        </span>
        <span class="ca-dim-legend-item" style="color:#9AA5B1">
            <span class="ca-dim-swatch" style="background:#F0F2F5;border:1px solid #D0D5DA"></span>Non affecté
        </span>

        <!-- Séparateur + explication cellule -->
        <span class="ca-dim-legend-sep"></span>
        <span class="ca-dim-legend-item" style="font-size:11px;color:#6C7A89;gap:10px">
            <span class="ca-dim-cell-label-existant">▲ Existant</span>
            <span style="color:#C5CAD0">·</span>
            <span class="ca-dim-cell-label-cible">▼ Cible (Règles &amp; Hypothèses)</span>
        </span>

        <div style="flex:1"></div>

        <!-- KPI dynamiques -->
        @{
            var nbSaisis  = rows.Where(r => !r.IsTotal).Count(r => r.EtpParProfil.Values.Any(v => v > 0));
            var totalSaisi = rows.Where(r => !r.IsTotal).SelectMany(r => r.EtpParProfil.Values).Sum(v => v ?? 0);
        }
        @if (segments.Any())
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
                     Style="height:24px;font-size:11px;font-weight:600">
                @nbSaisis / @segments.Count segments saisis
            </MudChip>
            <MudChip T="string" Size="Size.Small" Color="Color.Dark" Variant="Variant.Outlined"
                     Style="height:24px;font-size:11px;font-weight:600">
                @totalSaisi.ToString("F2") ETP existants
            </MudChip>
        }
    </div>

    @if (!profils.Any() || !segments.Any())
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mt-2">
            Aucune donnée disponible. Configurez d'abord les <strong>Règles &amp; Hypothèses</strong>
            (Sections 1, 2 et 3).
        </MudAlert>
    }
    else
    {
        <!-- ══════════════════════════════════════════════════════════
             TABLE FUSIONNÉE — Existant (▲) + Cible (▼) par cellule
        ══════════════════════════════════════════════════════════ -->
        <MudPaper Elevation="2" Style="border-radius:8px;overflow:hidden">
            <div class="ca-section-header" style="display:flex;align-items:center;gap:10px">
                <span class="ca-section-badge">1</span>
                Répartition des charges @(vueEtp ? "(en ETP)" : "(nombre de clients)") — Existant vs Cible
                <MudTooltip Text="Chaque cellule affiche sur deux lignes : ▲ la valeur existante saisie (modifiable en Vue ETP) et ▼ l'affectation cible issue des Règles et Hypothèses (lecture seule). La couleur de fond indique le rôle du conseiller pour ce segment.">
                    <MudIcon Icon="@Icons.Material.Outlined.Info" Size="Size.Small"
                             Style="color:rgba(255,255,255,0.65)" />
                </MudTooltip>
                @if (vueEtp)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                             Style="height:20px;font-size:10px;color:rgba(255,255,255,0.85);border-color:rgba(255,255,255,0.4);margin-left:auto">
                        Cellules ▲ modifiables
                    </MudChip>
                }
            </div>

            <div class="ca-dim-scroll-wrapper">
                <table class="ca-dim-table">
                    <thead>
                        <!-- Super-header -->
                        <tr class="ca-dim-superheader">
                            <th class="ca-dim-th-segment ca-dim-sticky-col" rowspan="2">
                                Segments clients
                            </th>
                            <th colspan="@profils.Count" class="ca-dim-th-group">
                                Profils conseillers
                            </th>
                            <th class="ca-dim-th-total" rowspan="2">
                                Total ETP<br/>existant
                            </th>
                            <th class="ca-dim-th-ctrl" rowspan="2">
                                Couverture
                            </th>
                        </tr>
                        <!-- Sous-header profils -->
                        <tr>
                            @foreach (var p in profils)
                            {
                                <th class="ca-dim-th-profil">@p</th>
                            }
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var row in rows)
                        {
                            var rowTotal = GetRowTotal(row);
                            var coverage = GetCoverageLevel(row);

                            <tr class="@(row.IsTotal ? "ca-dim-tr-total" : "ca-dim-tr-data")">

                                <!-- Colonne segment -->
                                <td class="ca-dim-td-segment ca-dim-sticky-col">
                                    @if (row.IsTotal)
                                    {
                                        <span class="ca-dim-total-label">@row.Segment</span>
                                    }
                                    else
                                    {
                                        @row.Segment
                                    }
                                </td>

                                <!-- Cellules fusionnées : ▲ Existant / ▼ Cible -->
                                @foreach (var p in profils)
                                {
                                    var profil = p;
                                    var lvl = GetAssignmentLevel(row.Segment, profil);
                                    var etp = row.EtpParProfil.GetValueOrDefault(profil);

                                    <td class="ca-dim-td-merged" style="@GetMergedCellStyle(lvl, row.IsTotal)">
                                        @if (row.IsTotal)
                                        {
                                            <!-- Ligne total : ETP existant + ETP cible -->
                                            var etpCibleTot = GetEtpCibleTotal(profil);
                                            <div class="ca-dim-total-cell">
                                                <div>@(etp.HasValue && etp > 0 ? etp.Value.ToString("F2") : "—")</div>
                                                @if (etpCibleTot.HasValue)
                                                {
                                                    <div class="ca-dim-total-cible">▼ @etpCibleTot.Value.ToString("F2")</div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <!-- ▲ Zone EXISTANT (modifiable) -->
                                            <div class="ca-dim-cell-top">
                                                @if (vueEtp)
                                                {
                                                    <MudNumericField T="double?"
                                                                     Value="@etp"
                                                                     ValueChanged="@(v => SetEtp(row, profil, v))"
                                                                     Immediate="true"
                                                                     Variant="Variant.Text"
                                                                     Margin="Margin.Dense"
                                                                     Format="F2"
                                                                     Min="0"
                                                                     HideSpinButtons="true"
                                                                     Placeholder="@(lvl > 0 ? "0.00" : "—")"
                                                                     Style="max-width:76px;margin:0 auto;color:inherit;font-size:12px;font-weight:600" />
                                                }
                                                else
                                                {
                                                    <span style="font-size:12px;font-weight:600">
                                                        @(etp.HasValue && etp > 0 ? etp.Value.ToString("F2") : "—")
                                                    </span>
                                                }
                                            </div>

                                            <!-- ▼ Zone CIBLE — ETP calculé depuis ReglesHypothèses -->
                                            @{
                                                var etpCible = GetEtpCible(row.Segment, profil);
                                                var roleLbl  = lvl switch { 1 => "Prio", 2 => "Sec.", 3 => "Tert.", _ => "" };
                                            }
                                            <div class="ca-dim-cell-bottom @(lvl > 0 ? "ca-dim-cell-bottom-assigned" : "ca-dim-cell-bottom-empty")">
                                                @if (lvl > 0 && etpCible.HasValue)
                                                {
                                                    <span class="ca-dim-cible-etp">
                                                        @etpCible.Value.ToString("F2")
                                                        <span class="ca-dim-cible-role">(@roleLbl)</span>
                                                    </span>
                                                }
                                                else if (lvl > 0)
                                                {
                                                    <span class="ca-dim-role-pill">@roleLbl</span>
                                                    <MudTooltip Text="Renseignez le nombre de clients dans Règles &amp; Hypothèses Section 1">
                                                        <MudIcon Icon="@Icons.Material.Outlined.Info" Size="Size.Small"
                                                                 Style="font-size:11px;opacity:0.6;margin-left:2px" />
                                                    </MudTooltip>
                                                }
                                                else
                                                {
                                                    <span class="ca-dim-role-none">—</span>
                                                }
                                            </div>
                                        }
                                    </td>
                                }

                                <!-- Total ETP existant (somme ligne) -->
                                <td class="ca-dim-td-total">
                                    @(rowTotal.HasValue
                                        ? (vueEtp ? rowTotal.Value.ToString("F2") : rowTotal.Value.ToString("N0"))
                                        : "—")
                                </td>

                                <!-- Indicateur couverture -->
                                <td class="ca-dim-td-ctrl">
                                    @if (!row.IsTotal)
                                    {
                                        @switch (coverage)
                                        {
                                            case 2:
                                                <MudTooltip Text="Tous les conseillers assignés sont renseignés">
                                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                                             Color="Color.Success" Size="Size.Small" />
                                                </MudTooltip>
                                                break;
                                            case 1:
                                                <MudTooltip Text="Partiellement renseigné">
                                                    <MudIcon Icon="@Icons.Material.Filled.RemoveCircle"
                                                             Color="Color.Warning" Size="Size.Small" />
                                                </MudTooltip>
                                                break;
                                            default:
                                                <MudIcon Icon="@Icons.Material.Outlined.RadioButtonUnchecked"
                                                         Style="color:#D0D5DA" Size="Size.Small" />
                                                break;
                                        }
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </MudPaper>
    }

    <div class="ca-footer">© 2025 Crédit Agricole Nord de France — Plateforme de Dimensionnement</div>
</div>

@code {
    private bool vueEtp = true;
    private List<string> profils  = new();
    private List<string> segments = new();
    private List<DimMatrixRow> rows = new();

    // ── Lifecycle ─────────────────────────────────────────────────────────
    protected override void OnInitialized()
    {
        StateService.OnChange += OnReglesChanged;
        InitData();
    }

    public void Dispose() => StateService.OnChange -= OnReglesChanged;

    private void OnReglesChanged()
    {
        var newProfils = GetProfils();
        // Conserver les valeurs saisies si le profil existe encore
        foreach (var row in rows)
            foreach (var p in newProfils.Where(p => !row.EtpParProfil.ContainsKey(p)))
                row.EtpParProfil[p] = null;

        profils  = newProfils;
        segments = GetSegments();
        RecalcTotal();
        InvokeAsync(StateHasChanged);
    }

    private void InitData()
    {
        profils  = GetProfils();
        segments = GetSegments();
        rows     = BuildRows();
    }

    // ── Sources de données ────────────────────────────────────────────────
    private List<string> GetProfils() =>
        StateService.Regles.ConseillersProfils
            .Select(p => p.Profil)
            .Where(p => !string.IsNullOrWhiteSpace(p))
            .Distinct().ToList();

    private List<string> GetSegments() =>
        StateService.Regles.SegmentsIntensite
            .Select(s => s.Segment)
            .Where(s => !string.IsNullOrWhiteSpace(s))
            .Distinct().ToList();

    // ── Construction de la table ──────────────────────────────────────────
    private List<DimMatrixRow> BuildRows()
    {
        var dataRows = segments
            .Select(s => new DimMatrixRow
            {
                Segment = s,
                EtpParProfil = profils.ToDictionary(p => p, _ => (double?)null)
            }).ToList();

        dataRows.Add(new DimMatrixRow
        {
            Segment = "Total charge ETP",
            IsTotal = true,
            EtpParProfil = profils.ToDictionary(p => p, _ => (double?)null)
        });

        return dataRows;
    }

    // ── Affectation depuis ReglesHypotheses (Section 3) ───────────────────
    // 1 = Prioritaire, 2 = Secondaire, 3 = Tertiaire, 0 = non affecté
    private int GetAssignmentLevel(string segment, string profil)
    {
        if (string.IsNullOrWhiteSpace(segment) || string.IsNullOrWhiteSpace(profil)) return 0;
        var r = StateService.Regles.ReglesAffectationSegments
            .FirstOrDefault(x => x.Segment?.Trim().Equals(segment.Trim(),
                StringComparison.OrdinalIgnoreCase) == true);
        if (r == null) return 0;
        if (r.ConseillerPrioritaire?.Trim().Equals(profil.Trim(), StringComparison.OrdinalIgnoreCase) == true) return 1;
        if (r.ConseillerSecondaire?.Trim().Equals(profil.Trim(),  StringComparison.OrdinalIgnoreCase) == true) return 2;
        if (r.ConseillerTertiaire?.Trim().Equals(profil.Trim(),   StringComparison.OrdinalIgnoreCase) == true) return 3;
        return 0;
    }

    // Style de fond de la cellule fusionnée (depuis affectation CIBLE)
    private static string GetMergedCellStyle(int level, bool isTotal) => isTotal ? "" : level switch
    {
        1 => "background:#1A6B3C;color:white",
        2 => "background:#52A86B;color:white",
        3 => "background:#C3E6CB;color:#1A4E6B",
        _ => ""
    };

    // ── Mutations ────────────────────────────────────────────────────────
    private void SetEtp(DimMatrixRow row, string profil, double? value)
    {
        row.EtpParProfil[profil] = value;
        RecalcTotal();
    }

    private void RecalcTotal()
    {
        var totalRow = rows.LastOrDefault(r => r.IsTotal);
        if (totalRow == null) return;
        foreach (var p in profils)
        {
            var vals = rows.Where(r => !r.IsTotal)
                           .Select(r => r.EtpParProfil.GetValueOrDefault(p)).ToList();
            totalRow.EtpParProfil[p] = vals.Any(v => v.HasValue) ? vals.Sum(v => v ?? 0) : null;
        }
    }

    // ── Indicateur couverture ─────────────────────────────────────────────
    // 0 = vide, 1 = partiel, 2 = complet
    private int GetCoverageLevel(DimMatrixRow row)
    {
        if (row.IsTotal) return -1;
        var assigned = profils.Where(p => GetAssignmentLevel(row.Segment, p) > 0).ToList();
        if (!assigned.Any()) return 0;
        var filled = assigned.Count(p => (row.EtpParProfil.GetValueOrDefault(p) ?? 0) > 0);
        return filled == 0 ? 0 : filled == assigned.Count ? 2 : 1;
    }

    // ── ETP CIBLE calculé depuis ReglesHypothèses ─────────────────────────
    // Formule : NombreClients(segment) / TailleThéorique(profil, segment)
    // TailleThéorique = VolumeHoraire(profil) / IntensitéRelationnelle(segment)
    // = (HeuresTravailParAn × PartTempsCommercialPct/100) / (NbRdv × DuréeRdv)
    private double? GetEtpCible(string segment, string profil)
    {
        var si = StateService.Regles.SegmentsIntensite
            .FirstOrDefault(s => s.Segment?.Trim().Equals(segment.Trim(), StringComparison.OrdinalIgnoreCase) == true);
        if (si == null || si.NombreClients <= 0) return null;

        var intensite = si.IntensiteRelationnelle;
        if (intensite <= 0) return null;

        var cp = StateService.Regles.ConseillersProfils
            .FirstOrDefault(p => p.Profil?.Trim().Equals(profil.Trim(), StringComparison.OrdinalIgnoreCase) == true);
        if (cp == null) return null;

        var heuresAn = StateService.Regles.HeuresTravailParAn;
        var volumeHoraire = heuresAn * cp.PartTempsCommercialPct / 100.0;
        if (volumeHoraire <= 0) return null;

        var tailleTheorique = volumeHoraire / intensite;   // nb clients par conseiller
        return tailleTheorique > 0
            ? Math.Round(si.NombreClients / tailleTheorique, 2)
            : null;
    }

    // ── ETP CIBLE total par colonne (ligne Total) ─────────────────────────
    private double? GetEtpCibleTotal(string profil) =>
        segments.Select(s => GetEtpCible(s, profil))
                .Where(v => v.HasValue)
                .Select(v => v!.Value)
                .DefaultIfEmpty()
                .Sum() is double t && t > 0 ? t : null;

    // ── Calculs ───────────────────────────────────────────────────────────
    private double? GetRowTotal(DimMatrixRow row)
    {
        var vals = profils.Select(p => row.EtpParProfil.GetValueOrDefault(p))
                          .Where(v => v.HasValue).ToList();
        return vals.Any() ? vals.Sum(v => v!.Value) : null;
    }
}
