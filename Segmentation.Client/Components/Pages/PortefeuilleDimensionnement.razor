    // ── Lifecycle ─────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;

        try
        {
            StateService.OnChange += OnReglesChanged;

            _segmentationDistributive = await Http.GetFromJsonAsync<List<SegmentationDistributiveData>>(
                "api/SegmentationDistributive"
            ) ?? new();

            Console.WriteLine($">>> SegmentationDistributive chargée : {_segmentationDistributive.Count} lignes");

            filtreRegion = _segmentationDistributive
                .Select(x => x.LibRegion)
                .Where(x => !string.IsNullOrWhiteSpace(x))
                .OrderBy(x => x)
                .FirstOrDefault();

            filtreSecteur = _segmentationDistributive
                .Where(x => string.IsNullOrEmpty(filtreRegion) || x.LibRegion == filtreRegion)
                .Select(x => x.LibSecteur)
                .Where(x => !string.IsNullOrWhiteSpace(x))
                .OrderBy(x => x)
                .FirstOrDefault();

            filtreAgence = _segmentationDistributive
                .Where(x => string.IsNullOrEmpty(filtreRegion) || x.LibRegion == filtreRegion)
                .Where(x => string.IsNullOrEmpty(filtreSecteur) || x.LibSecteur == filtreSecteur)
                .Select(x => x.LibAgence)
                .Where(x => !string.IsNullOrWhiteSpace(x))
                .OrderBy(x => x)
                .FirstOrDefault();

            _segmentationDistributiveFiltree = _segmentationDistributive
                .Where(x => string.IsNullOrEmpty(filtreRegion) || x.LibRegion == filtreRegion)
                .Where(x => string.IsNullOrEmpty(filtreSecteur) || x.LibSecteur == filtreSecteur)
                .Where(x => string.IsNullOrEmpty(filtreAgence) || x.LibAgence == filtreAgence)
                .ToList();

            filtreRegionApplique = filtreRegion;
            filtreSecteurApplique = filtreSecteur;
            filtreAgenceApplique = filtreAgence;

            BuildFilterOptions();
            InitData();

            Console.WriteLine($">>> Agence par défaut : {filtreAgence}");
            Console.WriteLine($">>> Lignes filtrées : {_segmentationDistributiveFiltree.Count}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur chargement Portefeuille : {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    public void Dispose() => StateService.OnChange -= OnReglesChanged;

    private void OnReglesChanged()
    {
        profils  = GetProfils();
        segments = GetSegments();
        foreach (var p in profils.Where(p => !_slots.Any(s => s.Profil.Equals(p, StringComparison.OrdinalIgnoreCase))))
        {
            var prefix = _profilShort.GetValueOrDefault(p, p[..Math.Min(3, p.Length)].ToUpper());
            var newSlot = new ConseillerSlot { Profil = p, Label = prefix + "-1", IsActuel = true, IsCible = true };
            _slots.Add(newSlot);
            foreach (var row in rows) { row.EtpParProfil[newSlot.Id] = null; row.EtpCibleSaisieParProfil[newSlot.Id] = null; }
        }
        BuildFilterOptions();
        RecalcTotal();
        InvokeAsync(StateHasChanged);
    }

    private void InitData()
    {
        profils = GetProfils();
        segments = GetSegments();
        _slots = BuildSlots();

        Console.WriteLine($">>> Profils : {profils.Count}");
        Console.WriteLine($">>> Segments : {segments.Count}");
        Console.WriteLine($">>> Slots : {_slots.Count}");
        Console.WriteLine($">>> SegmentationDistributiveFiltree : {_segmentationDistributiveFiltree.Count}");

        rows = BuildRows();

        RecalcTotal();
        InitEffectifs();

        BuildFilterOptions();
        ApplyFilters();
    }

    // ── Construction des slots individuels ───────────────────────────────
    private List<ConseillerSlot> BuildSlots()
    {
        if (_segmentationDistributiveFiltree == null || !_segmentationDistributiveFiltree.Any())
            return new List<ConseillerSlot>();

        return _segmentationDistributiveFiltree
            .Where(x => !string.IsNullOrWhiteSpace(x.MatriculeConseiller))
            .Where(x => !string.IsNullOrWhiteSpace(x.TypeConseiller))
            .GroupBy(x => new
            {
                x.MatriculeConseiller,
                x.TypeConseiller
            })
            .Select(g =>
            {
                var profil = g.Key.TypeConseiller;
                var prefix = _profilShort.GetValueOrDefault(
                    profil,
                    profil[..Math.Min(3, profil.Length)].ToUpper()
                );

                return new ConseillerSlot
                {
                    Profil = profil,
                    Label = $"{prefix}-{g.Key.MatriculeConseiller}",
                    IsActuel = true,
                    IsCible = true
                };
            })
            .OrderBy(x => x.Profil)
            .ThenBy(x => x.Label)
            .ToList();
    }

    // ── Gestion des slots ─────────────────────────────────────────────────
    private void AddSlot(string profilType)
    {
        var prefix = _profilShort.GetValueOrDefault(profilType, profilType[..Math.Min(3, profilType.Length)].ToUpper());
        var num    = _slots.Count(s => s.Profil.Equals(profilType, StringComparison.OrdinalIgnoreCase)) + 1;
        var slot   = new ConseillerSlot { Profil = profilType, Label = $"{prefix}-{num}", IsActuel = false, IsCible = true };
        _slots.Add(slot);
        foreach (var row in rows)
        {
            row.EtpParProfil[slot.Id]            = null;
            row.EtpCibleSaisieParProfil[slot.Id] = null;
        }
        RecalcTotal();
    }

    private async Task<bool> ConfirmRemoveSlotWithChargeAsync(ConseillerSlot slot, List<DimMatrixRow> chargeRows)
    {
        var totalCharge = chargeRows.Sum(r => r.EtpCibleSaisieParProfil.GetValueOrDefault(slot.Id) ?? 0);
        var message =
            $"{slot.Label} a encore {chargeRows.Count} segment(s) avec {totalCharge:F2} ETP réparti(s) en cible.\n" +
            "La suppression de cet effectif supprimera également sa charge.";

        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.Message, message },
            { x => x.ConfirmText, "Supprimer" },
        };
        var dialogRef = await DialogService.ShowAsync<ConfirmDialog>(
            "Supprimer l'effectif et sa charge",
            parameters,
            new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall });
        var result = await dialogRef.Result;
        return result is { Canceled: false };
    }

    private async Task RemoveNewSlot(ConseillerSlot slot)
    {
        var chargeRows = rows.Where(r => !r.IsTotal && (r.EtpCibleSaisieParProfil.GetValueOrDefault(slot.Id) ?? 0) > 0.001).ToList();

        if (chargeRows.Any() && !await ConfirmRemoveSlotWithChargeAsync(slot, chargeRows))
            return;

        foreach (var row in chargeRows)
        {
            row.EtpCibleSaisieParProfil[slot.Id] = null;
        }

        _slots.Remove(slot);
        foreach (var row in rows)
        {
            row.EtpParProfil.Remove(slot.Id);
            row.EtpCibleSaisieParProfil.Remove(slot.Id);
        }
        RecalcTotal();
    }

    private async Task RemoveCibleForExistingSlot(ConseillerSlot slot)
    {
        var chargeRows = rows.Where(r => !r.IsTotal && (r.EtpCibleSaisieParProfil.GetValueOrDefault(slot.Id) ?? 0) > 0.001).ToList();

        if (chargeRows.Any() && !await ConfirmRemoveSlotWithChargeAsync(slot, chargeRows))
            return;

        foreach (var row in chargeRows)
        {
            row.EtpCibleSaisieParProfil[slot.Id] = null;
        }

        slot.IsCible = false;
        RecalcTotal();
    }

    private void RestoreCible(ConseillerSlot slot)
    {
        slot.IsCible = true;
        RecalcTotal();
    }

    // ── Filtres ───────────────────────────────────────────────────────────
    private void BuildFilterOptions()
    {
        if (_segmentationDistributive == null || !_segmentationDistributive.Any())
        {
            allRegions = new List<string>();
            allSecteurs = new List<string>();
            allAgences = new List<string>();
            return;
        }

        allRegions = _segmentationDistributive
            .Select(x => x.LibRegion)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(x => x)
            .ToList();

        allSecteurs = _segmentationDistributive
            .Where(x => string.IsNullOrEmpty(filtreRegion) || x.LibRegion == filtreRegion)
            .Select(x => x.LibSecteur)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(x => x)
            .ToList();

        allAgences = _segmentationDistributive
            .Where(x => string.IsNullOrEmpty(filtreRegion) || x.LibRegion == filtreRegion)
            .Where(x => string.IsNullOrEmpty(filtreSecteur) || x.LibSecteur == filtreSecteur)
            .Select(x => x.LibAgence)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(x => x)
            .ToList();
    }

    private async Task ApplyFilters()
    {
        _isLoading = true;
        StateHasChanged();

        await Task.Delay(1);

        try
        {
            _segmentationDistributiveFiltree = _segmentationDistributive
                .Where(x => string.IsNullOrEmpty(filtreRegion) || x.LibRegion == filtreRegion)
                .Where(x => string.IsNullOrEmpty(filtreSecteur) || x.LibSecteur == filtreSecteur)
                .Where(x => string.IsNullOrEmpty(filtreAgence) || x.LibAgence == filtreAgence)
                .ToList();

            filtreRegionApplique = filtreRegion;
            filtreSecteurApplique = filtreSecteur;
            filtreAgenceApplique = filtreAgence;

            // Reset des charges manuelles quand on change d'agence
            // (les saisies étaient liées aux segments de l'agence précédente)
            _chargeATransfererBP.Clear();
            _chargeRecueBP.Clear();
            _chargeATransfererMutualise.Clear();

            BuildFilterOptions();

            _slots = BuildSlots();
            rows = BuildRows();

            RecalcTotal();

            filteredRows = rows.ToList();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ClearFilters()
    {
        filtreRegion = null;
        filtreSecteur = null;
        filtreAgence = null;

        await ApplyFilters();
    }

    // ── Sources de données ────────────────────────────────────────────────
    private List<string> GetProfils()
    {
        if (_segmentationDistributiveFiltree != null && _segmentationDistributiveFiltree.Any())
        {
            return _segmentationDistributiveFiltree
                .Select(x => x.TypeConseiller)
                .Where(x => !string.IsNullOrWhiteSpace(x))
                .Distinct()
                .OrderBy(x => x)
                .ToList();
        }

        return StateService.Regles.ConseillersProfils
            .Select(p => p.Profil)
            .Where(p => !string.IsNullOrWhiteSpace(p))
            .Distinct().Reverse().ToList();
    }

