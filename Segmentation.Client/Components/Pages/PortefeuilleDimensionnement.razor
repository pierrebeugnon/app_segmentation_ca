    private double? ToDisplayValue(double? etpValue, string segment) =>
        vueEtp ? etpValue : EtpService.GetClientCountFromEtp(etpValue, segment);

    private string FormatDisplay(double? etpValue, string segment, string etpFormat = "F2")
    {
        var v = ToDisplayValue(etpValue, segment);
        if (v is null) return "—";
        var format = !vueEtp || (v.Value % 1) == 0 ? "F0" : etpFormat;
        return v.Value.ToString(format);
    }

    private string FormatTotal(double? value)
    {
        if (value is null) return "—";
        var format = Math.Abs(value.Value % 1) < 0.001 ? "F0" : "F2";
        return value.Value.ToString(format);
    }

