@page "/portefeuille"
@inject SegmentationStateService StateService
@implements IDisposable

<PageTitle>Dimensionnement Portefeuilles — CA Segmentation</PageTitle>

<div class="ca-page">

    <!-- ══════════════════════════════════════════════════════════
         En-tête + toggle ETP / Volume
    ══════════════════════════════════════════════════════════ -->
    <div class="ca-page-header">
        <div>
            <MudText Typo="Typo.h5" Class="ca-page-title">Dimensionnement des Portefeuilles</MudText>
            <MudText Typo="Typo.caption" Class="ca-page-subtitle">
                @(vueEtp
                    ? "Vue ETP — saisie des charges existantes et comparaison à la cible"
                    : "Vue Volume de clients — projection informative")
            </MudText>
        </div>

        <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
            <MudButton StartIcon="@Icons.Material.Filled.AccessTime"
                       Variant="@(vueEtp  ? Variant.Filled : Variant.Outlined)"
                       Color="@(vueEtp    ? Color.Primary  : Color.Default)"
                       OnClick="@(() => vueEtp = true)">Vue ETP</MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.People"
                       Variant="@(!vueEtp ? Variant.Filled : Variant.Outlined)"
                       Color="@(!vueEtp   ? Color.Primary  : Color.Default)"
                       OnClick="@(() => vueEtp = false)">Vue Volume</MudButton>
        </MudButtonGroup>
    </div>

    <!-- ── Filtres organisationnels ────────────────────────────────────── -->
    <MudPaper Elevation="1" Style="border-radius:8px;padding:12px 16px;margin-bottom:8px">
        <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
            <MudIcon Icon="@Icons.Material.Outlined.FilterAlt" Style="color:#1A4E6B;font-size:20px" />
            <MudSelect T="string" Label="Région" Dense="true" Margin="Margin.Dense"
                       Variant="Variant.Outlined" Style="min-width:160px"
                       Value="@filtreRegion" ValueChanged="@(v => { filtreRegion = v; ApplyFilters(); })"
                       Clearable="true">
                @foreach (var r in allRegions)
                {
                    <MudSelectItem Value="@r">@r</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="string" Label="Secteur" Dense="true" Margin="Margin.Dense"
                       Variant="Variant.Outlined" Style="min-width:180px"
                       Value="@filtreSecteur" ValueChanged="@(v => { filtreSecteur = v; ApplyFilters(); })"
                       Clearable="true">
                @foreach (var s in allSecteurs)
                {
                    <MudSelectItem Value="@s">@s</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="string" Label="Agence" Dense="true" Margin="Margin.Dense"
                       Variant="Variant.Outlined" Style="min-width:200px"
                       Value="@filtreAgence" ValueChanged="@(v => { filtreAgence = v; ApplyFilters(); })"
                       Clearable="true">
                @foreach (var a in allAgences)
                {
                    <MudSelectItem Value="@a">@a</MudSelectItem>
                }
            </MudSelect>
            @if (!string.IsNullOrEmpty(filtreRegion) || !string.IsNullOrEmpty(filtreSecteur) || !string.IsNullOrEmpty(filtreAgence))
            {
                <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Secondary"
                           StartIcon="@Icons.Material.Outlined.Clear"
                           OnClick="@ClearFilters">Effacer filtres</MudButton>
            }
            <div style="flex:1"></div>
            @{
                var nbCibles  = filteredRows.Where(r => !r.IsTotal).Count(r => r.EtpCibleSaisieParProfil.Values.Any(v => v > 0));
                var totalExist = filteredRows.Where(r => !r.IsTotal).SelectMany(r => r.EtpParProfil.Values).Sum(v => v ?? 0);
            }
            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
                     Style="height:24px;font-size:11px;font-weight:600">
                @nbCibles / @filteredRows.Count(r => !r.IsTotal) cibles saisies
            </MudChip>
            <MudChip T="string" Size="Size.Small" Color="Color.Dark" Variant="Variant.Outlined"
                     Style="height:24px;font-size:11px;font-weight:600">
                @totalExist.ToString("F2") ETP existants
            </MudChip>
        </div>
    </MudPaper>

    <!-- ── Légende ───────────────────────────────────────────────────── -->
    <div class="ca-dim-legend-bar">
        <span class="ca-dim-legend-item">
            <span class="ca-dim-swatch" style="background:#1A6B3C"></span>Prioritaire
        </span>
        <span class="ca-dim-legend-item">
            <span class="ca-dim-swatch" style="background:#52A86B"></span>Secondaire
        </span>
        <span class="ca-dim-legend-item">
            <span class="ca-dim-swatch" style="background:#C3E6CB;border:1px solid #52A86B"></span>Tertiaire
        </span>
        <span class="ca-dim-legend-item" style="color:#9AA5B1">
            <span class="ca-dim-swatch" style="background:#F0F2F5;border:1px solid #D0D5DA"></span>Non affecté
        </span>
        <span class="ca-dim-legend-sep"></span>
        <span class="ca-dim-legend-item" style="font-size:11px;color:#6C7A89;gap:10px">
            <span style="font-weight:700;color:#1A4E6B">▼ Cible (saisie)</span>
            <span style="color:#C5CAD0">·</span>
            <span style="font-weight:600;color:#FF8F00;font-style:italic">▲ Existant</span>
        </span>
    </div>

    @if (!profils.Any() || !segments.Any())
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mt-2">
            Aucune donnée disponible. Configurez d'abord les <strong>Règles &amp; Hypothèses</strong>
            (Sections 1, 2 et 3).
        </MudAlert>
    }
    else
    {
        <!-- ══════════════════════════════════════════════════════════
             TABLE FUSIONNÉE — Existant (▲) + Cible (▼) par cellule
        ══════════════════════════════════════════════════════════ -->
        <MudPaper Elevation="2" Style="border-radius:8px;overflow:hidden">
            <div class="ca-section-header" style="display:flex;align-items:center;gap:10px">
                <span class="ca-section-badge">1</span>
                Répartition des charges @(vueEtp ? "(en ETP)" : "(nombre de clients)") — Existant vs Cible
                <MudTooltip Text="Chaque cellule affiche : ▲ la valeur existante (lecture seule, colorée selon l'écart à la cible) et ▼ la cible à saisir. La couleur de fond indique le rôle du conseiller pour ce segment.">
                    <MudIcon Icon="@Icons.Material.Outlined.Info" Size="Size.Small"
                             Style="color:rgba(255,255,255,0.65)" />
                </MudTooltip>
                @if (vueEtp)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                             Style="height:20px;font-size:10px;color:rgba(255,255,255,0.85);border-color:rgba(255,255,255,0.4);margin-left:auto">
                        Cellules ▼ cible modifiables
                    </MudChip>
                }
            </div>

            <div class="ca-dim-scroll-wrapper">
                <table class="ca-dim-table">
                    <thead>
                        <!-- Super-header -->
                        <tr class="ca-dim-superheader">
                            <th class="ca-dim-th-segment ca-dim-sticky-col" rowspan="2">
                                Segments clients
                            </th>
                            <th colspan="@profils.Count" class="ca-dim-th-group">
                                Profils conseillers
                            </th>
                            <th class="ca-dim-th-total" rowspan="2">
                                Total ETP<br/>existant
                            </th>
                            <th class="ca-dim-th-ctrl" rowspan="2">
                                Couverture
                            </th>
                        </tr>
                        <!-- Sous-header profils -->
                        <tr>
                            @foreach (var p in profils)
                            {
                                <th class="ca-dim-th-profil">@p</th>
                            }
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var row in filteredRows)
                        {
                            var rowTotal = GetRowTotal(row);
                            var coverage = GetCoverageLevel(row);

                            <tr class="@(row.IsTotal ? "ca-dim-tr-total" : "ca-dim-tr-data")">

                                <!-- Colonne segment -->
                                <td class="ca-dim-td-segment ca-dim-sticky-col">
                                    @if (row.IsTotal)
                                    {
                                        <span class="ca-dim-total-label">@row.Segment</span>
                                    }
                                    else
                                    {
                                        @row.Segment
                                    }
                                </td>

                                <!-- Cellules fusionnées : ▼ Cible (haut, éditable) / ▲ Existant (bas, orange) -->
                                @foreach (var p in profils)
                                {
                                    var profil    = p;
                                    var lvl       = GetAssignmentLevel(row.Segment, profil);
                                    var etp       = row.EtpParProfil.GetValueOrDefault(profil);
                                    var etpCibleS = row.EtpCibleSaisieParProfil.GetValueOrDefault(profil);

                                    <td class="ca-dim-td-merged" style="@GetMergedCellStyle(lvl, row.IsTotal);text-align:center">
                                        @if (row.IsTotal)
                                        {
                                            var etpCibleTot = GetEtpCibleSaisieTotal(profil);
                                            <div class="ca-dim-total-cell" style="text-align:center">
                                                @if (etpCibleTot.HasValue)
                                                {
                                                    <div style="font-size:12px;font-weight:700">▼ @etpCibleTot.Value.ToString("F2")</div>
                                                }
                                                <div style="font-size:11px;color:#FF8F00;font-style:italic">
                                                    @(etp.HasValue && etp > 0 ? etp.Value.ToString("F2") : "—")
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            var roleLbl   = lvl switch { 1 => "Prio", 2 => "Sec.", 3 => "Tert.", _ => "" };
                                            var topCls    = "ca-dim-cell-top";
                                            var bottomCls = lvl > 0 ? "ca-dim-cell-bottom ca-dim-cell-bottom-assigned"
                                                                     : "ca-dim-cell-bottom ca-dim-cell-bottom-empty";

                                            <!-- ▼ CIBLE (haut) — éditable sur TOUTES les lignes -->
                                            <div class="@topCls" style="text-align:center">
                                                @if (vueEtp)
                                                {
                                                    <MudNumericField T="double?"
                                                                     Value="@etpCibleS"
                                                                     ValueChanged="@(v => SetEtpCible(row, profil, v))"
                                                                     Immediate="true"
                                                                     Variant="Variant.Text"
                                                                     Margin="Margin.Dense"
                                                                     Format="F2"
                                                                     Min="0"
                                                                     HideSpinButtons="true"
                                                                     Placeholder="—"
                                                                     Style="max-width:76px;margin:0 auto;color:inherit;font-size:12px;font-weight:700;text-align:center" />
                                                }
                                                else
                                                {
                                                    <span style="font-size:12px;font-weight:700">
                                                        @if (etpCibleS.HasValue && etpCibleS > 0)
                                                        {
                                                            @etpCibleS.Value.ToString("F2")
                                                            @if (lvl > 0)
                                                            {
                                                                <span class="ca-dim-cible-role" style="font-weight:400"> (@roleLbl)</span>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <span style="opacity:0.4">—</span>
                                                        }
                                                    </span>
                                                }
                                            </div>

                                            <!-- ▲ EXISTANT (bas) — lecture seule, orange -->
                                            <div class="@bottomCls" style="text-align:center">
                                                <span style="font-size:11px;font-weight:600;color:#FF8F00;font-style:italic">
                                                    @(etp.HasValue && etp > 0 ? etp.Value.ToString("F2") : "—")
                                                </span>
                                            </div>
                                        }
                                    </td>
                                }

                                <!-- Total ETP — Cible (haut) + Existant orange (bas) -->
                                <td class="ca-dim-td-total" style="font-size:12px;text-align:center">
                                    @{
                                        var cibleTotRow = GetRowCibleTotal(row);
                                    }
                                    @if (cibleTotRow.HasValue)
                                    {
                                        <div style="font-weight:700;font-size:12px">▼ @cibleTotRow.Value.ToString("F2")</div>
                                    }
                                    @if (rowTotal.HasValue)
                                    {
                                        var totStr = vueEtp ? rowTotal.Value.ToString("F2") : rowTotal.Value.ToString("N0");
                                        <div style="color:#FF8F00;font-style:italic;font-size:11px">@totStr</div>
                                    }
                                    else if (!cibleTotRow.HasValue)
                                    {
                                        <span>—</span>
                                    }
                                </td>

                                <!-- Indicateur couverture -->
                                <td class="ca-dim-td-ctrl">
                                    @if (!row.IsTotal)
                                    {
                                        @switch (coverage)
                                        {
                                            case 2:
                                                <MudTooltip Text="Tous les conseillers assignés sont renseignés">
                                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                                             Color="Color.Success" Size="Size.Small" />
                                                </MudTooltip>
                                                break;
                                            case 1:
                                                <MudTooltip Text="Partiellement renseigné">
                                                    <MudIcon Icon="@Icons.Material.Filled.RemoveCircle"
                                                             Color="Color.Warning" Size="Size.Small" />
                                                </MudTooltip>
                                                break;
                                            default:
                                                <MudIcon Icon="@Icons.Material.Outlined.RadioButtonUnchecked"
                                                         Style="color:#D0D5DA" Size="Size.Small" />
                                                break;
                                        }
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>

                    <!-- ═══ Lignes KPI sous Total ETP ═══════════════════════════ -->
                    <tbody>

                        <!-- ── Ligne 1 : Effectif actuel ─────────────────────── -->
                        <tr class="ca-dim-tr-kpi" style="background:#1A4E6B">
                            <td class="ca-dim-td-segment ca-dim-sticky-col" style="font-size:12px;font-weight:700;color:white;padding:6px 12px;background:#1A4E6B">
                                Effectif actuel (nb conseillers)
                            </td>
                            @foreach (var p in profils)
                            {
                                var pCap = p;
                                <td style="text-align:center;padding:4px 8px;background:#1A4E6B;border-bottom:1px solid #2A6E9B">
                                    @if (vueEtp)
                                    {
                                        <MudNumericField T="double?"
                                                         Value="@_effectifActuel.GetValueOrDefault(pCap)"
                                                         ValueChanged="@(v => { _effectifActuel[pCap] = v; })"
                                                         Immediate="true" Variant="Variant.Text" Margin="Margin.Dense"
                                                         Format="F0" Min="0" HideSpinButtons="true" Placeholder="0"
                                                         Style="max-width:70px;margin:0 auto;font-size:13px;font-weight:700;color:white;text-align:center" />
                                    }
                                    else
                                    {
                                        <span style="font-size:13px;font-weight:700;color:white">@(_effectifActuel.GetValueOrDefault(pCap)?.ToString("F0") ?? "—")</span>
                                    }
                                </td>
                            }
                            <td style="text-align:center;font-size:13px;font-weight:700;color:white;padding:4px 8px;background:#0F3A52;border-bottom:1px solid #2A6E9B">
                                @{ var totEffAct = profils.Select(p => _effectifActuel.GetValueOrDefault(p)).Where(v => v.HasValue).Sum(v => v!.Value); }
                                @(profils.Any(p => _effectifActuel.GetValueOrDefault(p).HasValue) ? totEffAct.ToString("F0") : "—")
                            </td>
                            <td style="background:#1A4E6B"></td>
                        </tr>

                        <!-- ── Ligne 2 : Effectif cible ──────────────────────── -->
                        <tr class="ca-dim-tr-kpi" style="background:#1A4E6B">
                            <td class="ca-dim-td-segment ca-dim-sticky-col" style="font-size:12px;font-weight:700;color:white;padding:6px 12px;background:#1A4E6B;border-top:1px solid #2A6E9B">
                                Effectif cible (nb conseillers)
                            </td>
                            @foreach (var p in profils)
                            {
                                var pCap = p;
                                <td style="text-align:center;padding:4px 8px;background:#1A4E6B;border-top:1px solid #2A6E9B;border-bottom:1px solid #2A6E9B">
                                    @if (vueEtp)
                                    {
                                        <MudNumericField T="double?"
                                                         Value="@_effectifCible.GetValueOrDefault(pCap)"
                                                         ValueChanged="@(v => { _effectifCible[pCap] = v; })"
                                                         Immediate="true" Variant="Variant.Text" Margin="Margin.Dense"
                                                         Format="F0" Min="0" HideSpinButtons="true" Placeholder="0"
                                                         Style="max-width:70px;margin:0 auto;font-size:13px;font-weight:700;color:white;text-align:center" />
                                    }
                                    else
                                    {
                                        <span style="font-size:13px;font-weight:700;color:white">@(_effectifCible.GetValueOrDefault(pCap)?.ToString("F0") ?? "—")</span>
                                    }
                                </td>
                            }
                            <td style="text-align:center;font-size:13px;font-weight:700;color:white;padding:4px 8px;background:#0F3A52;border-top:1px solid #2A6E9B">
                                @{ var totEffCib = profils.Select(p => _effectifCible.GetValueOrDefault(p)).Where(v => v.HasValue).Sum(v => v!.Value); }
                                @(profils.Any(p => _effectifCible.GetValueOrDefault(p).HasValue) ? totEffCib.ToString("F0") : "—")
                            </td>
                            <td style="background:#1A4E6B"></td>
                        </tr>

                        <!-- ── Ligne 3 : Remplissage portefeuilles ───────────── -->
                        <tr style="background:#D6E8F7;border-left:4px solid #1A4E6B">
                            <td class="ca-dim-td-segment ca-dim-sticky-col" style="font-size:11px;font-weight:700;color:#1A4E6B;padding:5px 12px;background:#D6E8F7;border-left:4px solid #1A4E6B">
                                Remplissage portefeuilles existants<br/>
                                <span style="font-weight:400;font-size:10px;color:#4A7DA8">Effectif actuel − Total charge ETP</span>
                            </td>
                            @foreach (var p in profils)
                            {
                                var rem = GetRemplissage(p);
                                <td style="text-align:center;padding:5px 8px;font-size:12px;background:#D6E8F7;@DiffColor(rem, positifBon:true);border-bottom:1px solid #B8D4EC">
                                    @FormatDiff(rem)
                                </td>
                            }
                            <td style="text-align:center;padding:5px 8px;font-size:12px;background:#B8D4EC;border-bottom:1px solid #9ABFDF">
                                @{ var totRem = profils.Select(p => GetRemplissage(p)).Where(v => v.HasValue).ToList(); }
                                @if (totRem.Any()) { <span style="@DiffColor(totRem.Sum(v => v!.Value))">@FormatDiff(totRem.Sum(v => v!.Value))</span> } else { <span>—</span> }
                            </td>
                            <td style="background:#D6E8F7"></td>
                        </tr>

                        <!-- ── Ligne 4 : Evolution effectifs ─────────────────── -->
                        <tr style="background:#D6E8F7;border-left:4px solid #1A4E6B">
                            <td class="ca-dim-td-segment ca-dim-sticky-col" style="font-size:11px;font-weight:700;color:#1A4E6B;padding:5px 12px;background:#D6E8F7;border-left:4px solid #1A4E6B">
                                Évolution des effectifs<br/>
                                <span style="font-weight:400;font-size:10px;color:#4A7DA8">Effectif cible − Effectif actuel</span>
                            </td>
                            @foreach (var p in profils)
                            {
                                var evo = GetEvolutionEffectifs(p);
                                <td style="text-align:center;padding:5px 8px;font-size:12px;background:#D6E8F7;@DiffColor(evo, positifBon:true);border-bottom:1px solid #B8D4EC">
                                    @FormatDiff(evo)
                                </td>
                            }
                            <td style="text-align:center;padding:5px 8px;font-size:12px;background:#B8D4EC;border-bottom:1px solid #9ABFDF">
                                @{ var totEvo = profils.Select(p => GetEvolutionEffectifs(p)).Where(v => v.HasValue).ToList(); }
                                @if (totEvo.Any()) { <span style="@DiffColor(totEvo.Sum(v => v!.Value))">@FormatDiff(totEvo.Sum(v => v!.Value))</span> } else { <span>—</span> }
                            </td>
                            <td style="background:#D6E8F7"></td>
                        </tr>

                        <!-- ── Ligne 5 : Taux de concordance ─────────────────── -->
                        <tr style="background:#D6E8F7;border-left:4px solid #1A4E6B">
                            <td class="ca-dim-td-segment ca-dim-sticky-col" style="font-size:11px;font-weight:700;color:#1A4E6B;padding:5px 12px;background:#D6E8F7;border-left:4px solid #1A4E6B">
                                Taux de concordance<br/>
                                <span style="font-weight:400;font-size:10px;color:#4A7DA8">ETP cible / Effectif cible (portefeuille moyen cible)</span>
                            </td>
                            @foreach (var p in profils)
                            {
                                var tc = GetTauxConcordance(p);
                                <td style="text-align:center;padding:5px 8px;font-size:12px;font-weight:700;color:#1A4E6B;background:#D6E8F7;border-bottom:1px solid #B8D4EC">
                                    @(tc.HasValue ? tc.Value.ToString("F2") : "—")
                                </td>
                            }
                            <td style="background:#B8D4EC;border-bottom:1px solid #9ABFDF"></td>
                            <td style="background:#D6E8F7"></td>
                        </tr>

                        <!-- ── Ligne 6 : Taux de rotation ─────────────────────── -->
                        <tr style="background:#D6E8F7;border-left:4px solid #1A4E6B">
                            <td class="ca-dim-td-segment ca-dim-sticky-col" style="font-size:11px;font-weight:700;color:#1A4E6B;padding:5px 12px;background:#D6E8F7;border-left:4px solid #1A4E6B">
                                Taux de rotation du portefeuille (%)<br/>
                                <span style="font-weight:400;font-size:10px;color:#4A7DA8">À renseigner</span>
                            </td>
                            @foreach (var p in profils)
                            {
                                var pCap = p;
                                <td style="text-align:center;padding:4px 8px;background:#D6E8F7;border-bottom:1px solid #B8D4EC">
                                    @if (vueEtp)
                                    {
                                        <MudNumericField T="double?"
                                                         Value="@_tauxRotation.GetValueOrDefault(pCap)"
                                                         ValueChanged="@(v => { _tauxRotation[pCap] = v; })"
                                                         Immediate="true" Variant="Variant.Text" Margin="Margin.Dense"
                                                         Format="F1" Min="0" Max="100" HideSpinButtons="true" Placeholder="0,0"
                                                         Adornment="Adornment.End" AdornmentText="%"
                                                         Style="max-width:80px;margin:0 auto;font-size:12px;color:#1A4E6B;text-align:center" />
                                    }
                                    else
                                    {
                                        <span style="font-size:12px;color:#1A4E6B;font-weight:600">@(_tauxRotation.GetValueOrDefault(pCap).HasValue ? $"{_tauxRotation.GetValueOrDefault(pCap)!.Value:F1} %" : "—")</span>
                                    }
                                </td>
                            }
                            <td style="background:#B8D4EC;border-bottom:1px solid #9ABFDF"></td>
                            <td style="background:#D6E8F7"></td>
                        </tr>

                        <!-- ── Ligne 7 : Taux d'entrée ────────────────────────── -->
                        <tr style="background:#D6E8F7;border-left:4px solid #1A4E6B">
                            <td class="ca-dim-td-segment ca-dim-sticky-col" style="font-size:11px;font-weight:700;color:#1A4E6B;padding:5px 12px;background:#D6E8F7;border-left:4px solid #1A4E6B">
                                Taux d'entrée dans le portefeuille (%)<br/>
                                <span style="font-weight:400;font-size:10px;color:#4A7DA8">À renseigner</span>
                            </td>
                            @foreach (var p in profils)
                            {
                                var pCap = p;
                                <td style="text-align:center;padding:4px 8px;background:#D6E8F7;border-bottom:1px solid #B8D4EC">
                                    @if (vueEtp)
                                    {
                                        <MudNumericField T="double?"
                                                         Value="@_tauxEntree.GetValueOrDefault(pCap)"
                                                         ValueChanged="@(v => { _tauxEntree[pCap] = v; })"
                                                         Immediate="true" Variant="Variant.Text" Margin="Margin.Dense"
                                                         Format="F1" Min="0" Max="100" HideSpinButtons="true" Placeholder="0,0"
                                                         Adornment="Adornment.End" AdornmentText="%"
                                                         Style="max-width:80px;margin:0 auto;font-size:12px;color:#1A4E6B;text-align:center" />
                                    }
                                    else
                                    {
                                        <span style="font-size:12px;color:#1A4E6B;font-weight:600">@(_tauxEntree.GetValueOrDefault(pCap).HasValue ? $"{_tauxEntree.GetValueOrDefault(pCap)!.Value:F1} %" : "—")</span>
                                    }
                                </td>
                            }
                            <td style="background:#B8D4EC;border-bottom:1px solid #9ABFDF"></td>
                            <td style="background:#D6E8F7"></td>
                        </tr>

                    </tbody>
                </table>
            </div>
        </MudPaper>
    }

    <div class="ca-footer">© 2025 Crédit Agricole Nord de France — Plateforme de Dimensionnement</div>
</div>

@code {
    private bool vueEtp = true;
    private List<string> profils  = new();
    private List<string> segments = new();
    private List<DimMatrixRow> rows = new();

    // ── Filtres ───────────────────────────────────────────────────────────
    private string? filtreRegion  = null;
    private string? filtreSecteur = null;
    private string? filtreAgence  = null;

    private List<string> allRegions  = new();
    private List<string> allSecteurs = new();
    private List<string> allAgences  = new();

    private List<DimMatrixRow> filteredRows = new();

    // ── KPI sous Total ETP ────────────────────────────────────────────────
    private Dictionary<string, double?> _effectifActuel = new();
    private Dictionary<string, double?> _effectifCible  = new();
    private Dictionary<string, double?> _tauxRotation   = new();
    private Dictionary<string, double?> _tauxEntree     = new();

    // ── Lifecycle ─────────────────────────────────────────────────────────
    protected override void OnInitialized()
    {
        StateService.OnChange += OnReglesChanged;
        InitData();
    }

    public void Dispose() => StateService.OnChange -= OnReglesChanged;

    private void OnReglesChanged()
    {
        var newProfils = GetProfils();
        foreach (var row in rows)
        {
            foreach (var p in newProfils.Where(p => !row.EtpParProfil.ContainsKey(p)))
            {
                row.EtpParProfil[p]            = null;
                row.EtpCibleSaisieParProfil[p] = null;
            }
        }
        profils  = newProfils;
        segments = GetSegments();
        BuildFilterOptions();
        RecalcTotal();
        InvokeAsync(StateHasChanged);
    }

    private void InitData()
    {
        profils  = GetProfils();
        segments = GetSegments();
        rows     = BuildRows();
        RecalcTotal();       // totalise les ETP existants mockés
        InitEffectifs();
        BuildFilterOptions();
        ApplyFilters();
    }

    private void BuildFilterOptions()
    {
        var si = StateService.Regles.SegmentsIntensite;
        allRegions  = si.Select(s => s.Region ).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct().OrderBy(x => x).ToList();
        allSecteurs = si.Select(s => s.Secteur).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct().OrderBy(x => x).ToList();
        allAgences  = si.Select(s => s.Agence ).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct().OrderBy(x => x).ToList();
    }

    private void ApplyFilters()
    {
        var si = StateService.Regles.SegmentsIntensite;
        // Segments correspondant aux filtres actifs
        var segsFiltres = si
            .Where(s => (string.IsNullOrEmpty(filtreRegion)  || s.Region  == filtreRegion)
                     && (string.IsNullOrEmpty(filtreSecteur) || s.Secteur == filtreSecteur)
                     && (string.IsNullOrEmpty(filtreAgence)  || s.Agence  == filtreAgence))
            .Select(s => s.Segment)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        if (!segsFiltres.Any())
        {
            // Aucun filtre actif → afficher tout
            filteredRows = rows.ToList();
        }
        else
        {
            filteredRows = rows
                .Where(r => r.IsTotal || segsFiltres.Contains(r.Segment))
                .ToList();
        }
    }

    private void ClearFilters()
    {
        filtreRegion = filtreAgence = filtreSecteur = null;
        ApplyFilters();
    }

    // ── Sources de données ────────────────────────────────────────────────
    private List<string> GetProfils() =>
        StateService.Regles.ConseillersProfils
            .Select(p => p.Profil)
            .Where(p => !string.IsNullOrWhiteSpace(p))
            .Distinct().ToList();

    private List<string> GetSegments() =>
        StateService.Regles.SegmentsIntensite
            .Select(s => s.Segment)
            .Where(s => !string.IsNullOrWhiteSpace(s))
            .Distinct().ToList();

    // ── Construction de la table ──────────────────────────────────────────

    // Mock ETP existants par segment × profil (valeurs réalistes pour projection)
    private static readonly Dictionary<string, Dictionary<string, double>> _mockEtpExistant =
        new(StringComparer.OrdinalIgnoreCase)
        {
            ["HDG Premium Potentiel"] = new(StringComparer.OrdinalIgnoreCase) { ["BANQUIER PRIVÉ"] = 0.30, ["DIR. BP"] = 0.10 },
            ["HDG Premium Standard"]  = new(StringComparer.OrdinalIgnoreCase) { ["CGP"] = 0.85, ["BANQUIER PRIVÉ"] = 0.20 },
            ["HDG Potentiel"]         = new(StringComparer.OrdinalIgnoreCase) { ["RESP. AGENCE"] = 1.20, ["RCP"] = 0.35 },
            ["HDG Senior Epargnant"]  = new(StringComparer.OrdinalIgnoreCase) { ["RCP"] = 1.50, ["RESP. AGENCE"] = 0.40 },
            ["HDG Standard"]          = new(StringComparer.OrdinalIgnoreCase) { ["RESP. AGENCE"] = 2.10, ["CONSEILLER CLIENTELE"] = 0.80 },
            ["CI Potentiel"]          = new(StringComparer.OrdinalIgnoreCase) { ["CONSEILLER CLIENTELE"] = 3.60, ["RCP"] = 0.50 },
            ["CI Standard"]           = new(StringComparer.OrdinalIgnoreCase) { ["CONSEILLER CLIENTELE"] = 7.80, ["CONSEILLER COMMERCIAL"] = 2.40 },
            ["GP Potentiel"]          = new(StringComparer.OrdinalIgnoreCase) { ["CONSEILLER CLIENTELE"] = 3.90 },
            ["GP Standard"]           = new(StringComparer.OrdinalIgnoreCase) { ["CONSEILLER COMMERCIAL"] = 11.50, ["CONSEILLER CLIENTELE"] = 3.10 },
            ["Non segmenté"]          = new(StringComparer.OrdinalIgnoreCase) { ["CONSEILLER COMMERCIAL"] = 4.80 },
        };

    private List<DimMatrixRow> BuildRows()
    {
        var dataRows = segments
            .Select(s => new DimMatrixRow
            {
                Segment = s,
                EtpParProfil = profils.ToDictionary(
                    p => p,
                    p => _mockEtpExistant.TryGetValue(s, out var segDict) &&
                         segDict.TryGetValue(p, out var v) ? (double?)v : null),
                EtpCibleSaisieParProfil = profils.ToDictionary(p => p, _ => (double?)null)
            }).ToList();

        dataRows.Add(new DimMatrixRow
        {
            Segment = "Total charge ETP",
            IsTotal = true,
            EtpParProfil              = profils.ToDictionary(p => p, _ => (double?)null),
            EtpCibleSaisieParProfil   = profils.ToDictionary(p => p, _ => (double?)null)
        });

        return dataRows;
    }

    // ── Affectation depuis ReglesHypotheses (Section 3) ───────────────────
    // 1 = Prioritaire, 2 = Secondaire, 3 = Tertiaire, 0 = non affecté
    private int GetAssignmentLevel(string segment, string profil)
    {
        if (string.IsNullOrWhiteSpace(segment) || string.IsNullOrWhiteSpace(profil)) return 0;
        var r = StateService.Regles.ReglesAffectationSegments
            .FirstOrDefault(x => x.Segment?.Trim().Equals(segment.Trim(),
                StringComparison.OrdinalIgnoreCase) == true);
        if (r == null) return 0;
        if (r.ConseillerPrioritaire?.Trim().Equals(profil.Trim(), StringComparison.OrdinalIgnoreCase) == true) return 1;
        if (r.ConseillerSecondaire?.Trim().Equals(profil.Trim(),  StringComparison.OrdinalIgnoreCase) == true) return 2;
        if (r.ConseillerTertiaire?.Trim().Equals(profil.Trim(),   StringComparison.OrdinalIgnoreCase) == true) return 3;
        return 0;
    }

    // Style de fond de la cellule fusionnée (depuis affectation CIBLE)
    private static string GetMergedCellStyle(int level, bool isTotal) => isTotal ? "" : level switch
    {
        1 => "background:#1A6B3C;color:white",
        2 => "background:#52A86B;color:white",
        3 => "background:#C3E6CB;color:#1A4E6B",
        _ => ""
    };

    // ── Mutations ────────────────────────────────────────────────────────
    private void SetEtp(DimMatrixRow row, string profil, double? value)
    {
        row.EtpParProfil[profil] = value;
        RecalcTotal();
    }

    private void SetEtpCible(DimMatrixRow row, string profil, double? value)
    {
        row.EtpCibleSaisieParProfil[profil] = value;
        RecalcTotal();
    }

    private void RecalcTotal()
    {
        var totalRow = rows.LastOrDefault(r => r.IsTotal);
        if (totalRow == null) return;
        foreach (var p in profils)
        {
            var valsExist = rows.Where(r => !r.IsTotal).Select(r => r.EtpParProfil.GetValueOrDefault(p)).ToList();
            var valsCible = rows.Where(r => !r.IsTotal).Select(r => r.EtpCibleSaisieParProfil.GetValueOrDefault(p)).ToList();
            totalRow.EtpParProfil[p]            = valsExist.Any(v => v.HasValue) ? valsExist.Sum(v => v ?? 0) : null;
            totalRow.EtpCibleSaisieParProfil[p] = valsCible.Any(v => v.HasValue) ? valsCible.Sum(v => v ?? 0) : null;
        }
        ApplyFilters();
    }

    // ── Code couleur existant vs cible ────────────────────────────────────
    private static string GetExistantColor(double? existant, double? cible)
    {
        if (!existant.HasValue || existant.Value <= 0) return "color:#9AA5B1";
        if (!cible.HasValue    || cible.Value    <= 0) return "";
        var ratio = existant.Value / cible.Value;
        if (ratio > 1.10) return "color:#C62828";   // rouge — au-dessus cible
        if (ratio < 0.90) return "color:#E65100";   // orange — sous cible
        return "color:#2E7D32";                     // vert — sur cible
    }

    // ── Indicateur couverture ─────────────────────────────────────────────
    // 0 = vide, 1 = partiel, 2 = complet
    private int GetCoverageLevel(DimMatrixRow row)
    {
        if (row.IsTotal) return -1;
        var assigned = profils.Where(p => GetAssignmentLevel(row.Segment, p) > 0).ToList();
        if (!assigned.Any()) return 0;
        var filled = assigned.Count(p => (row.EtpParProfil.GetValueOrDefault(p) ?? 0) > 0);
        return filled == 0 ? 0 : filled == assigned.Count ? 2 : 1;
    }

    // ── ETP CIBLE calculé depuis ReglesHypothèses ─────────────────────────
    // Formule : NombreClients(segment) / TailleThéorique(profil, segment)
    // TailleThéorique = VolumeHoraire(profil) / IntensitéRelationnelle(segment)
    // = (HeuresTravailParAn × PartTempsCommercialPct/100) / (NbRdv × DuréeRdv)
    private double? GetEtpCible(string segment, string profil)
    {
        var si = StateService.Regles.SegmentsIntensite
            .FirstOrDefault(s => s.Segment?.Trim().Equals(segment.Trim(), StringComparison.OrdinalIgnoreCase) == true);
        if (si == null || si.NombreClients <= 0) return null;

        var intensite = si.IntensiteRelationnelle;
        if (intensite <= 0) return null;

        var cp = StateService.Regles.ConseillersProfils
            .FirstOrDefault(p => p.Profil?.Trim().Equals(profil.Trim(), StringComparison.OrdinalIgnoreCase) == true);
        if (cp == null) return null;

        var heuresAn = StateService.Regles.HeuresTravailParAn;
        var volumeHoraire = heuresAn * cp.PartTempsCommercialPct / 100.0;
        if (volumeHoraire <= 0) return null;

        var tailleTheorique = volumeHoraire / intensite;   // nb clients par conseiller
        return tailleTheorique > 0
            ? Math.Round(si.NombreClients / tailleTheorique, 2)
            : null;
    }

    // ── ETP CIBLE saisie total colonne (ligne Total) ─────────────────────
    private double? GetEtpCibleSaisieTotal(string profil)
    {
        var vals = rows.Where(r => !r.IsTotal)
                       .Select(r => r.EtpCibleSaisieParProfil.GetValueOrDefault(profil))
                       .Where(v => v.HasValue).ToList();
        return vals.Any() ? vals.Sum(v => v!.Value) : null;
    }

    // ── Calculs ───────────────────────────────────────────────────────────
    private double? GetRowTotal(DimMatrixRow row)
    {
        var vals = profils.Select(p => row.EtpParProfil.GetValueOrDefault(p))
                          .Where(v => v.HasValue).ToList();
        return vals.Any() ? vals.Sum(v => v!.Value) : null;
    }

    private double? GetRowCibleTotal(DimMatrixRow row)
    {
        var vals = profils.Select(p => row.EtpCibleSaisieParProfil.GetValueOrDefault(p))
                          .Where(v => v.HasValue).ToList();
        return vals.Any() ? vals.Sum(v => v!.Value) : null;
    }

    // ── KPI : Effectifs et taux ───────────────────────────────────────────

    // Mock effectifs actuel par profil (nb conseillers en poste)
    private static readonly Dictionary<string, double> _mockEffectifActuel =
        new(StringComparer.OrdinalIgnoreCase)
        {
            ["DIR. BP"]                = 1,
            ["BANQUIER PRIVÉ"]         = 3,
            ["CGP"]                    = 2,
            ["RESP. AGENCE"]           = 2,
            ["RCP"]                    = 4,
            ["CONSEILLER CLIENTELE"]   = 6,
            ["CONSEILLER COMMERCIAL"]  = 5,
        };

    private void InitEffectifs()
    {
        foreach (var p in profils)
        {
            if (!_effectifActuel.ContainsKey(p))
                _effectifActuel[p] = _mockEffectifActuel.TryGetValue(p, out var v) ? v : null;
            _effectifCible.TryAdd(p, null);
            _tauxRotation .TryAdd(p, null);
            _tauxEntree   .TryAdd(p, null);
        }
    }

    // Total ETP existant par profil (ligne Total)
    private double? GetTotalEtpExistant(string profil)
    {
        var totalRow = rows.LastOrDefault(r => r.IsTotal);
        return totalRow?.EtpParProfil.GetValueOrDefault(profil);
    }

    // Total ETP cible saisi par profil (ligne Total)
    private double? GetTotalEtpCible(string profil)
    {
        var totalRow = rows.LastOrDefault(r => r.IsTotal);
        return totalRow?.EtpCibleSaisieParProfil.GetValueOrDefault(profil);
    }

    // Remplissage = Effectif actuel − Total ETP existant (excédent de capacité)
    private double? GetRemplissage(string profil)
    {
        var eff = _effectifActuel.GetValueOrDefault(profil);
        var etp = GetTotalEtpExistant(profil);
        return (eff.HasValue && etp.HasValue) ? eff.Value - etp.Value : null;
    }

    // Evolution = Effectif cible − Effectif actuel
    private double? GetEvolutionEffectifs(string profil)
    {
        var act = _effectifActuel.GetValueOrDefault(profil);
        var cib = _effectifCible.GetValueOrDefault(profil);
        return (act.HasValue && cib.HasValue) ? cib.Value - act.Value : null;
    }

    // Taux de concordance = Total ETP cible / Effectif cible (portefeuille moyen cible par conseiller)
    private double? GetTauxConcordance(string profil)
    {
        var etpCib = GetTotalEtpCible(profil);
        var effCib = _effectifCible.GetValueOrDefault(profil);
        if (!etpCib.HasValue || !effCib.HasValue || effCib.Value <= 0) return null;
        return etpCib.Value / effCib.Value;
    }

    private static string FormatDiff(double? v, string suffix = "") =>
        v.HasValue ? (v.Value >= 0 ? $"+{v.Value:F2}{suffix}" : $"{v.Value:F2}{suffix}") : "—";

    private static string DiffColor(double? v, bool positifBon = true) =>
        !v.HasValue ? "" :
        v.Value > 0  ? (positifBon ? "color:#2E7D32;font-weight:700" : "color:#C62828;font-weight:700") :
        v.Value < 0  ? (positifBon ? "color:#C62828;font-weight:700" : "color:#2E7D32;font-weight:700") :
        "color:#6C7A89;font-weight:600";
}
