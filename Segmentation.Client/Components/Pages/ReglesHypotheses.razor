@page "/regles-hypotheses"
@using System.Linq
@inject MockDataService DataService
@inject ISnackbar Snackbar
@inject SegmentationStateService StateService
@inject IJSRuntime JS

<PageTitle>Règles & Hypothèses — CA Segmentation</PageTitle>

<div class="ca-page">

    <div class="ca-page-header">
        <div>
            <MudText Typo="Typo.h5" Class="ca-page-title">Règles & Hypothèses</MudText>
            <MudText Typo="Typo.caption" Class="ca-page-subtitle">
                Configuration des paramètres de dimensionnement du réseau
            </MudText>
        </div>

        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Success"
                       Size="Size.Medium"
                       StartIcon="@Icons.Material.Filled.Download"
                       OnClick="ExportExcel">
                Export Excel
            </MudButton>

            <MudButton Variant="Variant.Outlined"
                       Color="@(modeSimulation ? Color.Warning : Color.Primary)"
                       Size="Size.Medium"
                       StartIcon="@Icons.Material.Filled.Science"
                       OnClick="ToggleModeSimulation">
                @(modeSimulation ? "Mode simulation activé" : "Activer le mode simulation")
            </MudButton>

            @if (modeSimulation)
            {
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Secondary"
                           Size="Size.Medium"
                           StartIcon="@Icons.Material.Filled.Restore"
                           OnClick="ReinitialiserSimulation">
                    Réinitialiser
                </MudButton>
            }

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Medium"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="Enregistrer">
                Enregistrer les modifications
            </MudButton>
        </div>
    </div>

    @if (model != null)
    {
        @if (modeSimulation)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
                Mode simulation activé : les écarts comparent les valeurs actuelles aux valeurs de référence chargées initialement.
                L’enregistrement fige les valeurs actuelles comme nouvelle référence.
            </MudAlert>
        }

        <!-- ════════════════════════════════════════════════════════
             Onglets
        ════════════════════════════════════════════════════════ -->
        <MudTabs Rounded="true"
                 Elevation="1"
                 Class="mb-4"
                 Style="overflow:visible">

            <!-- ════════════════════════════════════════════════════════
                 Section 1 : Intensité
            ════════════════════════════════════════════════════════ -->
            <MudTabPanel Text="1. Intensité Relationelle">
                <MudPaper Elevation="1"
                          Style="border-radius:8px;overflow:visible"
                          Class="pa-0 mt-4">

                    <div class="ca-section-header">
                        <span class="ca-section-badge">1</span>
                        Segments et intensité relationnelle
                    </div>

                    <MudTable Items="@model.SegmentsIntensite"
                              Dense="true"
                              Hover="true"
                              Elevation="0"
                              Striped="true"
                              Style="overflow:visible">

                        <HeaderContent>
                            <MudTh>Segments distributifs</MudTh>
                            <MudTh Style="text-align:center">Nombre de RDV / CC / an</MudTh>
                            <MudTh Style="text-align:center">Durée du RDV (heure)</MudTh>
                            <MudTh Style="text-align:center;background:#E8EDF2;color:#1A4E6B">
                                Intensité relationelle par segment
                            </MudTh>

                            @if (modeSimulation)
                            {
                                <MudTh Style="text-align:center;background:#F5F7FA;color:#1A4E6B">
                                    Référence
                                </MudTh>
                                <MudTh Style="text-align:center;background:#F5F7FA;color:#1A4E6B">
                                    Écart
                                </MudTh>
                            }
                        </HeaderContent>

                        <RowTemplate>
                            @{
                                var intensiteActuelle = GetIntensite(context);
                                var intensiteReference = GetBaselineIntensiteBySegment(context.Segment);
                                var ecart = intensiteActuelle - intensiteReference;
                            }

                            <MudTd Style="font-weight:600;color:#1A4E6B">
                                @FormatSegmentLabel(context.Segment)
                            </MudTd>

                            <MudTd Style="text-align:center;background:#FFFDE7">
                                <MudNumericField T="double"
                                                 @bind-Value="context.NombreRdvParAn"
                                                 Immediate="true"
                                                 Variant="Variant.Outlined"
                                                 Margin="Margin.Dense"
                                                 Min="0"
                                                 Max="52"
                                                 Step="0.25"
                                                 Format="F2"
                                                 Style="max-width:110px;margin:0 auto"
                                                 HideSpinButtons="true" />
                            </MudTd>

                            <MudTd Style="text-align:center;background:#FFFDE7">
                                <MudNumericField T="double"
                                                 @bind-Value="context.DureeRdvHeures"
                                                 Immediate="true"
                                                 Variant="Variant.Outlined"
                                                 Margin="Margin.Dense"
                                                 Min="0"
                                                 Max="8"
                                                 Step="0.25"
                                                 Format="F2"
                                                 Style="max-width:110px;margin:0 auto"
                                                 HideSpinButtons="true" />
                            </MudTd>

                            <MudTd Style="text-align:center;background:#E8EDF2;font-weight:700;color:#1A4E6B;font-style:italic">
                                @intensiteActuelle.ToString("F2")
                            </MudTd>

                            @if (modeSimulation)
                            {
                                <MudTd Style="text-align:center;background:#F5F7FA;color:#6C7A89">
                                    @intensiteReference.ToString("F2")
                                </MudTd>

                                <MudTd Style="@GetDeltaCellStyle(ecart)">
                                    @FormatDelta(ecart, "")
                                </MudTd>
                            }
                        </RowTemplate>
                    </MudTable>
                </MudPaper>
            </MudTabPanel>

            <!-- ════════════════════════════════════════════════════════
                 Section 2 : Temps conseiller
            ════════════════════════════════════════════════════════ -->
            <MudTabPanel Text="2. Temps commercial">
                <MudPaper Elevation="1"
                          Style="border-radius:8px;overflow:visible"
                          Class="pa-0 mt-4">

                    <div class="ca-section-header">
                        <span class="ca-section-badge">2</span>
                        Conseillers et temps commercial
                    </div>

                    <div class="pa-4">
                        <MudText Typo="Typo.subtitle2" Style="color:#1A4E6B;margin-bottom:12px">
                            Hypothèse temps de travail des conseillers
                        </MudText>

                        <MudGrid Spacing="3" Class="mb-4">
                            <MudItem xs="12" sm="4">
                                <MudPaper Elevation="0"
                                          Style="background:#FFFDE7;border:1px solid #D8DCE0;border-radius:6px;padding:14px 16px;overflow:visible">

                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        Nombre d'heures travaillées par semaine
                                    </MudText>

                                    <MudNumericField T="double"
                                                     @bind-Value="model.HeuresParSemaine"
                                                     Immediate="true"
                                                     Variant="Variant.Outlined"
                                                     Margin="Margin.Dense"
                                                     Min="1"
                                                     Max="50"
                                                     Step="0.1"
                                                     Format="F1" />
                                </MudPaper>
                            </MudItem>

                            <MudItem xs="12" sm="4">
                                <MudPaper Elevation="0"
                                          Style="background:#FFFDE7;border:1px solid #D8DCE0;border-radius:6px;padding:14px 16px;overflow:visible">

                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        Nombre de semaines travaillées par an
                                    </MudText>

                                    <MudNumericField T="double"
                                                     @bind-Value="model.NbSemainesParAn"
                                                     Immediate="true"
                                                     Variant="Variant.Outlined"
                                                     Margin="Margin.Dense"
                                                     Min="1"
                                                     Max="52"
                                                     Step="0.5"
                                                     Format="F1" />
                                </MudPaper>
                            </MudItem>

                            <MudItem xs="12" sm="4">
                                <MudPaper Elevation="0"
                                          Style="background:#E8EDF2;border:1px solid #D8DCE0;border-radius:6px;padding:14px 16px;overflow:visible">

                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        Nombre d'heures travaillées par an
                                    </MudText>

                                    <MudText Typo="Typo.h6" Style="font-weight:700;color:#1A4E6B;margin-top:4px">
                                        @GetHeuresTravailParAn().ToString("F2") h
                                    </MudText>

                                    @if (modeSimulation)
                                    {
                                        <MudText Typo="Typo.caption" Style="@GetDeltaStyle(GetDeltaHeuresTravailParAn())">
                                            @FormatDelta(GetDeltaHeuresTravailParAn(), "h")
                                        </MudText>
                                    }
                                </MudPaper>
                            </MudItem>
                        </MudGrid>
                    </div>

                    <!-- Blocs par type d'agence (dynamique) -->
                    @{
                        var typesAgence = model.ConseillersProfils
                            .Where(p => !string.IsNullOrWhiteSpace(p.LigneMetier))
                            .Select(p => p.LigneMetier!)
                            .Distinct(StringComparer.OrdinalIgnoreCase)
                            .ToList();
                    }

                    @foreach (var typeAgence in typesAgence)
                    {
                        var profilsDuType    = model.ConseillersProfils
                            .Where(p => p.LigneMetier?.Equals(typeAgence, StringComparison.OrdinalIgnoreCase) == true)
                            .ToList();
                        var tpCommercial     = GetTempsCommercialByType(typeAgence);
                        var tpNonCom         = 100.0 - tpCommercial;
                        var typeLabel        = FormatTypeAgenceLabel(typeAgence);

                        <!-- Bloc type d'agence -->
                        <div style="margin:0 16px 16px;border-radius:8px;overflow:hidden;border:1px solid #D0D8E4;box-shadow:0 1px 4px rgba(0,0,0,0.07)">

                            <!-- Barre d'en-tête sombre -->
                            <div style="background:#1A4E6B;padding:12px 20px;display:flex;justify-content:space-between;align-items:center">
                                <span style="font-weight:700;font-size:15px;color:white;letter-spacing:.2px">@typeLabel</span>
                                <div style="display:flex;align-items:center;gap:10px">
                                    <span style="color:rgba(255,255,255,0.75);font-size:13px">Commercial</span>
                                    <div style="background:rgba(255,255,255,0.18);border:1.5px solid rgba(255,255,255,0.45);border-radius:20px;padding:3px 4px 3px 12px;display:inline-flex;align-items:center;gap:2px">
                                        <input type="number"
                                               value="@tpCommercial"
                                               @oninput="@(e => SetTempsCommercialByTypeSafe(typeAgence, (string?)e.Value))"
                                               min="0" max="100" step="5"
                                               style="background:transparent;border:none;color:white;font-weight:700;font-size:14px;width:36px;text-align:center;padding:0;outline:none;-moz-appearance:textfield" />
                                        <span style="color:white;font-weight:700;font-size:14px">%</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Tableau des profils hérités -->
                            <table style="width:100%;border-collapse:collapse;background:white">
                                <thead>
                                    <tr style="border-bottom:1px solid #E8EDF2;background:#F8F9FA">
                                        <th style="width:44px;padding:8px 4px 8px 16px"></th>
                                        <th style="text-align:left;padding:8px 12px;font-size:11px;color:#8A97A8;font-weight:700;letter-spacing:.6px">PROFIL CONSEILLER</th>
                                        <th style="text-align:center;padding:8px 12px;font-size:11px;color:#8A97A8;font-weight:700;letter-spacing:.6px">STATUT</th>
                                        <th style="text-align:center;padding:8px 12px;font-size:11px;color:#8A97A8;font-weight:700;letter-spacing:.6px">COMM.</th>
                                        <th style="text-align:center;padding:8px 12px;font-size:11px;color:#8A97A8;font-weight:700;letter-spacing:.6px">NON COMM.</th>
                                        <th style="text-align:right;padding:8px 16px 8px 12px;font-size:11px;color:#8A97A8;font-weight:700;letter-spacing:.6px">HEURES/AN</th>
                                        @if (modeSimulation)
                                        {
                                            <th style="text-align:center;padding:8px 12px;font-size:11px;color:#8A97A8;font-weight:700;letter-spacing:.6px;background:#F0F3F7">RÉFÉRENCE</th>
                                            <th style="text-align:center;padding:8px 12px;font-size:11px;color:#8A97A8;font-weight:700;letter-spacing:.6px;background:#F0F3F7">ÉCART</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in profilsDuType)
                                    {
                                        var volActuel  = GetVolumeHoraire(p);
                                        var volRef     = GetBaselineVolumeHoraireByProfil(p.Profil);
                                        var ecartVol   = volActuel - volRef;
                                        <tr style="border-bottom:1px solid #F0F4F8">
                                            <td style="padding:10px 4px 10px 16px;color:#B0BAC5;font-size:14px;text-align:center">↳</td>
                                            <td style="padding:10px 12px;font-size:13px;color:#2C3E50">@p.Profil</td>
                                            <td style="padding:10px 12px;text-align:center">
                                                <span style="background:#E8F5E9;color:#2E7D32;font-size:11px;font-weight:600;padding:3px 12px;border-radius:12px;white-space:nowrap">Hérité</span>
                                            </td>
                                            <td style="padding:10px 12px;text-align:center;font-size:13px;color:#4A5568">@GetPartTempsCommercialPctDisplay(p).ToString("F0") %</td>
                                            <td style="padding:10px 12px;text-align:center;font-size:13px;color:#6C7A89">@GetPartTempsNonCommercialPctDisplay(p).ToString("F0") %</td>
                                            <td style="padding:10px 16px 10px 12px;text-align:right;font-size:13px;font-weight:700;color:#1A4E6B">@volActuel.ToString("F1") h</td>
                                            @if (modeSimulation)
                                            {
                                                <td style="padding:10px 12px;text-align:center;font-size:12px;color:#6C7A89;background:#F5F7FA">@volRef.ToString("F1")</td>
                                                <td style="@GetDeltaCellStyle(ecartVol);text-align:center;padding:10px 12px;font-size:12px">@FormatDelta(ecartVol, "h")</td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    <!-- Note de bas de section -->
                    <div style="padding:10px 20px 14px;color:#8A97A8;font-size:12px">
                        ↳ Valeur héritée du paramétrage parent affichée sur chaque profil
                    </div>

                </MudPaper>
            </MudTabPanel>

            <!-- ════════════════════════════════════════════════════════
                 Section 3 : Affectation
            ════════════════════════════════════════════════════════ -->
            <MudTabPanel Text="3. Règles d'affectation des conseillers">
                <MudPaper Elevation="1"
                          Style="border-radius:8px;overflow:visible"
                          Class="pa-0 mt-4">

                    <div class="ca-section-header">
                        <span class="ca-section-badge">3</span>
                        Règles d'affectation des conseillers par segment de clientèle
                    </div>

                    <MudTable Items="@model.ReglesAffectationSegments"
                              Dense="true"
                              Hover="true"
                              Elevation="0"
                              Striped="true"
                              Style="overflow:visible">

                        <HeaderContent>
                            <MudTh>Segments distributifs</MudTh>
                            <MudTh>Conseiller Prioritaire</MudTh>
                            <MudTh>Conseiller Secondaire 1</MudTh>
                            <MudTh>Conseiller Secondaire 2</MudTh>

                            @if (modeSimulation)
                            {
                                <MudTh Style="text-align:center;background:#F5F7FA;color:#1A4E6B">
                                    Statut simulation
                                </MudTh>
                            }
                        </HeaderContent>

                        <RowTemplate>
                            @{
                                var segment = context.Segment?.Trim() ?? string.Empty;
                                var allOptions = GetOptionsProfilsPourSegment(segment);
                                var optionsPrioritaire = GetOptionsFiltered(allOptions, context.ConseillerSecondaire, context.ConseillerTertiaire);
                                var optionsSecondaire = GetOptionsFiltered(allOptions, context.ConseillerPrioritaire, context.ConseillerTertiaire);
                                var optionsTertiaire = GetOptionsFiltered(allOptions, context.ConseillerPrioritaire, context.ConseillerSecondaire);
                                var selectDisabled = IsSegmentNonAffectable(segment);
                                var affectationModifiee = IsAffectationModifiee(
                                context.Segment,
                                context.ConseillerPrioritaire,
                                context.ConseillerSecondaire,
                                context.ConseillerTertiaire
                                );
                            }

                            <MudTd Style="font-weight:600;color:#1A4E6B">
                                @FormatSegmentLabel(context.Segment)
                            </MudTd>

                            <MudTd Style="background:#FFFDE7;overflow:visible">
                                <MudSelect T="string"
                                           @bind-Value="context.ConseillerPrioritaire"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Dense="true"
                                           Clearable="true"
                                           Disabled="@selectDisabled"
                                           Style="min-width:220px">

                                    @foreach (var p in optionsPrioritaire)
                                    {
                                        <MudSelectItem T="string" Value="@p">@p</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudTd>

                            <MudTd Style="background:#FFFDE7;overflow:visible">
                                <MudSelect T="string"
                                           @bind-Value="context.ConseillerSecondaire"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Dense="true"
                                           Clearable="true"
                                           Disabled="@selectDisabled"
                                           Style="min-width:220px">

                                    @foreach (var p in optionsSecondaire)
                                    {
                                        <MudSelectItem T="string" Value="@p">@p</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudTd>

                            <MudTd Style="background:#FFFDE7;overflow:visible">
                                <MudSelect T="string"
                                           @bind-Value="context.ConseillerTertiaire"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Dense="true"
                                           Clearable="true"
                                           Disabled="@selectDisabled"
                                           Style="min-width:220px">

                                    @foreach (var p in optionsTertiaire)
                                    {
                                        <MudSelectItem T="string" Value="@p">@p</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudTd>

                            @if (modeSimulation)
                            {
                                <MudTd Style="text-align:center;background:#F5F7FA">
                                    @if (affectationModifiee)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">
                                            Modifié
                                        </MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">
                                            Inchangé
                                        </MudChip>
                                    }
                                </MudTd>
                            }
                        </RowTemplate>
                    </MudTable>
                </MudPaper>
            </MudTabPanel>

            <!-- ════════════════════════════════════════════════════════
                 Section 4 : Portefeuille
            ════════════════════════════════════════════════════════ -->
            <MudTabPanel Text="4. Taille théorique des portefeuilles">
                <MudPaper Elevation="1"
                          Style="border-radius:8px;overflow:visible"
                          Class="pa-0 mt-4">

                    <div class="ca-section-header">
                        <span class="ca-section-badge">4</span>
                        Taille théorique de portefeuille par segment

                        <MudChip T="string"
                                 Size="Size.Small"
                                 Variant="Variant.Outlined"
                                 Style="color:white;border-color:rgba(255,255,255,.5);margin-left:auto;font-size:11px">
                            Lecture seule — calculé automatiquement
                        </MudChip>
                    </div>

                    <MudTable Items="@model.TaillesTheoretiques.OrderByDescending(t => GetTailleTheoriqueCalculee(t.Profil, t.SegmentCouvert)).ToList()"
                              Dense="true"
                              Hover="true"
                              Elevation="0"
                              Striped="true"
                              Style="overflow:visible">

                        <HeaderContent>
                            <MudTh>Segments distributifs</MudTh>
                            <MudTh Style="text-align:center;background:#E8EDF2;color:#1A4E6B">
                                Intensité relationelle
                            </MudTh>
                            <MudTh Style="text-align:center;background:#E8EDF2;color:#1A4E6B">
                                Volume horaire par conseiller dédié à la gestion <br />
                                de portefeuilles (en heures/an)
                            </MudTh>
                            <MudTh Style="text-align:center;background:#E8EDF2;color:#1A4E6B">
                                Taille théorique de portefeuille par segment
                            </MudTh>

                            @if (modeSimulation)
                            {
                                <MudTh Style="text-align:center;background:#F5F7FA;color:#1A4E6B">
                                    Référence
                                </MudTh>
                                <MudTh Style="text-align:center;background:#F5F7FA;color:#1A4E6B">
                                    Écart
                                </MudTh>
                            }
                        </HeaderContent>

                        <RowTemplate>
                            @{
                                var segmentNonRenseigne = IsSegmentNonRenseigne(context.SegmentCouvert);
                                var intensiteActuelle = segmentNonRenseigne ? 0 : GetIntensiteBySegment(context.SegmentCouvert);
                                var volumeActuel = GetVolumeHoraireByProfil(context.Profil);
                                var tailleActuelle = intensiteActuelle > 0 ? volumeActuel / intensiteActuelle : 0;

                                var tailleReference = GetBaselineTailleTheorique(context.Profil, context.SegmentCouvert);
                                var ecartTaille = tailleActuelle - tailleReference;
                            }

                            <MudTd Style="font-weight:600;color:#1A4E6B">
                                @FormatSegmentLabel(context.SegmentCouvert)
                            </MudTd>

                            <MudTd Style="text-align:center;background:#E8EDF2;font-weight:600;color:#6C7A89;font-style:italic">
                                @(segmentNonRenseigne ? "?" : intensiteActuelle.ToString("F2"))
                            </MudTd>

                            <MudTd Style="text-align:center;background:#E8EDF2;font-weight:600;color:#6C7A89;font-style:italic">
                                @(string.IsNullOrWhiteSpace(context.Profil) ? "0.0" : volumeActuel.ToString("F1"))
                            </MudTd>

                            <MudTd Style="text-align:center;background:#E8EDF2;font-weight:700;color:#1A4E6B;font-style:italic">
                                @(segmentNonRenseigne || intensiteActuelle == 0 ? "—" : tailleActuelle.ToString("N2"))
                            </MudTd>

                            @if (modeSimulation)
                            {
                                <MudTd Style="text-align:center;background:#F5F7FA;color:#6C7A89">
                                    @(segmentNonRenseigne || tailleReference == 0 ? "—" : tailleReference.ToString("N2"))
                                </MudTd>

                                <MudTd Style="@GetDeltaCellStyle(ecartTaille)">
                                    @(segmentNonRenseigne || tailleReference == 0 ? "—" : FormatDelta(ecartTaille, "clients"))
                                </MudTd>
                            }
                        </RowTemplate>
                    </MudTable>
                </MudPaper>
            </MudTabPanel>
        </MudTabs>
    }

    <div class="ca-footer">
        © 2025 Crédit Agricole Nord de France — Plateforme de Dimensionnement
    </div>
</div>

@code {
    private ReglesHypothesesModel? model;
    private bool modeSimulation = false;
    private SimulationSnapshot? snapshotInitial;

    private readonly Dictionary<string, List<string>> _optionsProfilsParSegment =
        new(StringComparer.OrdinalIgnoreCase);

    private static readonly List<string> ProfilsBanquePrivee = new()
    {
        "DIR. BP",
        "BANQUIER PRIVÉ",
        "CGP"
    };

    private static readonly List<string> ProfilsRetail = new()
    {
        "RESP. AGENCE",
        "RCP",
        "CONSEILLER CLIENTELE",
        "CONSEILLER COMMERCIAL"
    };

    private static readonly List<string> ProfilsRetailAvecAccueil = new()
    {
        "RESP. AGENCE",
        "RCP",
        "CONSEILLER CLIENTELE",
        "CONSEILLER COMMERCIAL",
        "CONSEILLER D'ACCUEIL"
    };

    private static readonly HashSet<string> SegmentsBanquePrivee =
        new(StringComparer.OrdinalIgnoreCase)
        {
            "HDG Premium Potentiel",
            "HDG Premium Standard"
        };

    protected override void OnInitialized()
    {
        model = StateService.Regles;
        BuildOptionsProfilsParSegment();
        snapshotInitial = CreateSnapshot();
    }

    private void ToggleModeSimulation()
    {
        modeSimulation = !modeSimulation;

        if (snapshotInitial == null)
            snapshotInitial = CreateSnapshot();
    }

    private void ReinitialiserSimulation()
    {
        if (snapshotInitial == null || model == null)
            return;

        RestoreSnapshot(snapshotInitial);

        Snackbar.Add(
            "Simulation réinitialisée avec les valeurs de référence.",
            Severity.Info,
            cfg =>
            {
                cfg.Icon = Icons.Material.Filled.Restore;
                cfg.VisibleStateDuration = 3000;
            }
        );
    }

    private SimulationSnapshot CreateSnapshot()
    {
        var snapshot = new SimulationSnapshot();

        if (model == null)
            return snapshot;

        snapshot.HeuresParSemaine = model.HeuresParSemaine;
        snapshot.NbSemainesParAn = model.NbSemainesParAn;

        foreach (var segment in model.SegmentsIntensite)
        {
            var key = NormalizeKey(segment.Segment);

            if (!snapshot.Segments.ContainsKey(key))
            {
                snapshot.Segments[key] = new SegmentSnapshot
                {
                    Segment = segment.Segment ?? string.Empty,
                    NombreRdvParAn = segment.NombreRdvParAn,
                    DureeRdvHeures = segment.DureeRdvHeures
                };
            }
        }

        foreach (var profil in model.ConseillersProfils)
        {
            var key = NormalizeKey(profil.Profil);

            if (!snapshot.PartsCommerciales.ContainsKey(key))
                snapshot.PartsCommerciales[key] = profil.PartTempsCommercialPct;
        }

        foreach (var regle in model.ReglesAffectationSegments)
        {
            var key = NormalizeKey(regle.Segment);

            if (!snapshot.Affectations.ContainsKey(key))
            {
                snapshot.Affectations[key] = new AffectationSnapshot
                {
                    Segment = regle.Segment ?? string.Empty,
                    ConseillerPrioritaire = regle.ConseillerPrioritaire ?? string.Empty,
                    ConseillerSecondaire = regle.ConseillerSecondaire ?? string.Empty,
                    ConseillerTertiaire = regle.ConseillerTertiaire ?? string.Empty
                };
            }
        }

        return snapshot;
    }

    private void RestoreSnapshot(SimulationSnapshot snapshot)
    {
        if (model == null)
            return;

        model.HeuresParSemaine = snapshot.HeuresParSemaine;
        model.NbSemainesParAn = snapshot.NbSemainesParAn;

        foreach (var segment in model.SegmentsIntensite)
        {
            var key = NormalizeKey(segment.Segment);

            if (snapshot.Segments.TryGetValue(key, out var saved))
            {
                segment.NombreRdvParAn = saved.NombreRdvParAn;
                segment.DureeRdvHeures = saved.DureeRdvHeures;
            }
        }

        foreach (var profil in model.ConseillersProfils)
        {
            var key = NormalizeKey(profil.Profil);

            if (snapshot.PartsCommerciales.TryGetValue(key, out var savedPart))
                profil.PartTempsCommercialPct = savedPart;
        }

        foreach (var regle in model.ReglesAffectationSegments)
        {
            var key = NormalizeKey(regle.Segment);

            if (snapshot.Affectations.TryGetValue(key, out var saved))
            {
                regle.ConseillerPrioritaire = saved.ConseillerPrioritaire;
                regle.ConseillerSecondaire = saved.ConseillerSecondaire;
                regle.ConseillerTertiaire = saved.ConseillerTertiaire;
            }
        }

        BuildOptionsProfilsParSegment();
    }

    private void BuildOptionsProfilsParSegment()
    {
        _optionsProfilsParSegment.Clear();

        if (model?.ReglesAffectationSegments == null)
            return;

        foreach (var regle in model.ReglesAffectationSegments)
        {
            var segment = regle.Segment?.Trim() ?? string.Empty;

            if (string.IsNullOrWhiteSpace(segment))
                continue;

            if (!_optionsProfilsParSegment.ContainsKey(segment))
                _optionsProfilsParSegment[segment] = BuildOptionsProfilsForSegment(segment);

            AddIfMissing(_optionsProfilsParSegment[segment], regle.ConseillerPrioritaire);
            AddIfMissing(_optionsProfilsParSegment[segment], regle.ConseillerSecondaire);
            AddIfMissing(_optionsProfilsParSegment[segment], regle.ConseillerTertiaire);
        }
    }

    private List<string> BuildOptionsProfilsForSegment(string segment)
    {
        if (IsSegmentNonAffectable(segment))
            return new List<string>();

        if (SegmentsBanquePrivee.Contains(segment))
            return ProfilsBanquePrivee.ToList();

        if (IsGpStandard(segment))
            return ProfilsRetailAvecAccueil.ToList();

        return ProfilsRetail.ToList();
    }

    private IReadOnlyList<string> GetOptionsProfilsPourSegment(string segment)
    {
        segment = segment?.Trim() ?? string.Empty;

        if (_optionsProfilsParSegment.TryGetValue(segment, out var options))
            return options;

        var newOptions = BuildOptionsProfilsForSegment(segment);
        _optionsProfilsParSegment[segment] = newOptions;

        return newOptions;
    }

    private static IReadOnlyList<string> GetOptionsFiltered(
        IReadOnlyList<string> allOptions,
        params string?[] exclude)
    {
        var excluded = exclude
            .Where(e => !string.IsNullOrWhiteSpace(e))
            .Select(e => e!.Trim())
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        return allOptions.Where(p => !excluded.Contains(p.Trim())).ToList();
    }

    private static void AddIfMissing(List<string> options, string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return;

        var normalizedValue = value.Trim();

        if (!options.Any(x => string.Equals(x.Trim(), normalizedValue, StringComparison.OrdinalIgnoreCase)))
            options.Add(normalizedValue);
    }

    private static bool IsGpStandard(string? segment)
    {
        return string.Equals(segment?.Trim(), "GP Standard", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsSegmentNonAffectable(string? segment)
    {
        var s = segment?.Trim();

        return string.IsNullOrWhiteSpace(s)
               || string.Equals(s, "Non segmenté", StringComparison.OrdinalIgnoreCase)
               || s == "?";
    }

    private static bool IsSegmentNonRenseigne(string? segment)
    {
        return string.IsNullOrWhiteSpace(segment) || segment.Trim() == "?";
    }

    private static string NormalizeKey(string? value)
    {
        return value?.Trim() ?? string.Empty;
    }

    private double GetIntensite(SegmentIntensite segment)
    {
        if (segment == null)
            return 0;

        return segment.NombreRdvParAn * segment.DureeRdvHeures;
    }

    private double GetHeuresTravailParAn()
    {
        if (model == null)
            return 0;

        return model.HeuresParSemaine * model.NbSemainesParAn;
    }

    // ── Helpers type d'agence ─────────────────────────────────────────────

    private static string FormatTypeAgenceLabel(string lm) =>
        string.IsNullOrWhiteSpace(lm) ? "" : char.ToUpperInvariant(lm[0]) + lm[1..];

    private double GetTempsCommercialByType(string ligneMetier)
    {
        var p = model?.ConseillersProfils
            .FirstOrDefault(x => x.LigneMetier?.Equals(ligneMetier, StringComparison.OrdinalIgnoreCase) == true);
        return p != null ? GetPartTempsCommercialPctDisplay(p) : 0;
    }

    private void SetTempsCommercialByType(string ligneMetier, double pct)
    {
        if (model == null) return;
        foreach (var p in model.ConseillersProfils
            .Where(x => x.LigneMetier?.Equals(ligneMetier, StringComparison.OrdinalIgnoreCase) == true))
        {
            SetPartTempsCommercialPctFromDisplay(p, pct);
        }
    }

    private void SetTempsCommercialByTypeSafe(string ligneMetier, string? val)
    {
        if (double.TryParse(val, System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var d))
            SetTempsCommercialByType(ligneMetier, Math.Clamp(d, 0, 100));
    }

    // ── Fin helpers type d'agence ─────────────────────────────────────────

    private double GetPartTempsCommercialRatio(ConseillerTempsProfil profil)
    {
        if (profil == null)
            return 0;

        return ConvertPartTempsCommercialToRatio(profil.PartTempsCommercialPct);
    }

    private double ConvertPartTempsCommercialToRatio(double valeur)
    {
        if (double.IsNaN(valeur) || double.IsInfinity(valeur))
            return 0;

        if (valeur < 0)
            return 0;

        return valeur > 1 ? valeur / 100.0 : valeur;
    }

    private double GetPartTempsCommercialPctDisplay(ConseillerTempsProfil profil)
    {
        return GetPartTempsCommercialRatio(profil) * 100.0;
    }

    private double GetPartTempsNonCommercialPctDisplay(ConseillerTempsProfil profil)
    {
        return 100.0 - GetPartTempsCommercialPctDisplay(profil);
    }

    private void SetPartTempsCommercialPctFromDisplay(ConseillerTempsProfil profil, double valeurPct)
    {
        if (profil == null)
            return;

        profil.PartTempsCommercialPct = Math.Clamp(valeurPct, 0, 100);
    }

    private double GetVolumeHoraire(ConseillerTempsProfil profil)
    {
        if (model == null || profil == null)
            return 0;

        return Math.Round(GetHeuresTravailParAn() * GetPartTempsCommercialRatio(profil), 1);
    }

    private double GetVolumeHoraireByProfil(string profil)
    {
        if (model == null || string.IsNullOrWhiteSpace(profil))
            return 0;

        var conseiller = model.ConseillersProfils
            .FirstOrDefault(c => string.Equals(c.Profil?.Trim(), profil.Trim(), StringComparison.OrdinalIgnoreCase));

        return conseiller != null ? GetVolumeHoraire(conseiller) : 0;
    }

    private double GetIntensiteBySegment(string segment)
    {
        if (model == null || IsSegmentNonRenseigne(segment))
            return 0;

        var segmentTrouve = model.SegmentsIntensite
            .FirstOrDefault(s => string.Equals(s.Segment?.Trim(), segment.Trim(), StringComparison.OrdinalIgnoreCase));

        return segmentTrouve != null ? GetIntensite(segmentTrouve) : 0;
    }

    private double GetTailleTheoriqueCalculee(string? profil, string? segment)
    {
        if (string.IsNullOrWhiteSpace(profil) || IsSegmentNonRenseigne(segment))
            return 0;

        var intensite = GetIntensiteBySegment(segment!);
        var volume = GetVolumeHoraireByProfil(profil);

        return intensite > 0 ? volume / intensite : 0;
    }

    private double GetVolumeMoyen()
    {
        if (model == null || model.ConseillersProfils == null || !model.ConseillersProfils.Any())
            return 0;

        return model.ConseillersProfils.Average(c => GetVolumeHoraire(c));
    }

    private double GetIntensiteMoyenne()
    {
        if (model == null || model.SegmentsIntensite == null || !model.SegmentsIntensite.Any())
            return 0;

        var valeurs = model.SegmentsIntensite
            .Select(GetIntensite)
            .Where(v => v > 0)
            .ToList();

        return valeurs.Any() ? valeurs.Average() : 0;
    }

    private double GetCapaciteMoyenne()
    {
        if (model == null || model.TaillesTheoretiques == null)
            return 0;

        var valeurs = model.TaillesTheoretiques
            .Where(t => !IsSegmentNonRenseigne(t.SegmentCouvert))
            .Select(t =>
            {
                var intensite = GetIntensiteBySegment(t.SegmentCouvert);
                var volume = GetVolumeHoraireByProfil(t.Profil);
                return intensite > 0 ? volume / intensite : 0;
            })
            .Where(v => v > 0)
            .ToList();

        return valeurs.Any() ? valeurs.Average() : 0;
    }

    private double GetBaselineHeuresTravailParAn()
    {
        if (snapshotInitial == null)
            return 0;

        return snapshotInitial.HeuresParSemaine * snapshotInitial.NbSemainesParAn;
    }

    private double GetBaselineIntensiteBySegment(string? segment)
    {
        if (snapshotInitial == null || string.IsNullOrWhiteSpace(segment))
            return 0;

        var key = NormalizeKey(segment);

        if (!snapshotInitial.Segments.TryGetValue(key, out var saved))
            return 0;

        return saved.NombreRdvParAn * saved.DureeRdvHeures;
    }

    private double GetBaselinePartCommercialeRatioByProfil(string? profil)
    {
        if (snapshotInitial == null || string.IsNullOrWhiteSpace(profil))
            return 0;

        var key = NormalizeKey(profil);

        if (!snapshotInitial.PartsCommerciales.TryGetValue(key, out var saved))
            return 0;

        return ConvertPartTempsCommercialToRatio(saved);
    }

    private double GetBaselineVolumeHoraireByProfil(string? profil)
    {
        if (string.IsNullOrWhiteSpace(profil))
            return 0;

        return Math.Round(GetBaselineHeuresTravailParAn() * GetBaselinePartCommercialeRatioByProfil(profil), 1);
    }

    private double GetBaselineTailleTheorique(string? profil, string? segment)
    {
        if (snapshotInitial == null || string.IsNullOrWhiteSpace(profil) || IsSegmentNonRenseigne(segment))
            return 0;

        var intensite = GetBaselineIntensiteBySegment(segment);
        var volume = GetBaselineVolumeHoraireByProfil(profil);

        return intensite > 0 ? volume / intensite : 0;
    }

    private double GetBaselineVolumeMoyen()
    {
        if (model == null || snapshotInitial == null || model.ConseillersProfils == null || !model.ConseillersProfils.Any())
            return 0;

        return model.ConseillersProfils.Average(c => GetBaselineVolumeHoraireByProfil(c.Profil));
    }

    private double GetBaselineIntensiteMoyenne()
    {
        if (snapshotInitial == null || !snapshotInitial.Segments.Any())
            return 0;

        var valeurs = snapshotInitial.Segments.Values
            .Select(s => s.NombreRdvParAn * s.DureeRdvHeures)
            .Where(v => v > 0)
            .ToList();

        return valeurs.Any() ? valeurs.Average() : 0;
    }

    private double GetBaselineCapaciteMoyenne()
    {
        if (model == null || snapshotInitial == null || model.TaillesTheoretiques == null)
            return 0;

        var valeurs = model.TaillesTheoretiques
            .Where(t => !IsSegmentNonRenseigne(t.SegmentCouvert))
            .Select(t => GetBaselineTailleTheorique(t.Profil, t.SegmentCouvert))
            .Where(v => v > 0)
            .ToList();

        return valeurs.Any() ? valeurs.Average() : 0;
    }

    private double GetDeltaHeuresTravailParAn()
    {
        return GetHeuresTravailParAn() - GetBaselineHeuresTravailParAn();
    }

    private double GetDeltaVolumeMoyen()
    {
        return GetVolumeMoyen() - GetBaselineVolumeMoyen();
    }

    private double GetDeltaIntensiteMoyenne()
    {
        return GetIntensiteMoyenne() - GetBaselineIntensiteMoyenne();
    }

    private double GetDeltaCapaciteMoyenne()
    {
        return GetCapaciteMoyenne() - GetBaselineCapaciteMoyenne();
    }

    private bool IsAffectationModifiee(string? segment, string? conseillerPrioritaire, string? conseillerSecondaire, string? conseillerTertiaire = null)
    {
        if (snapshotInitial == null || string.IsNullOrWhiteSpace(segment))
            return false;

        var key = NormalizeKey(segment);

        if (!snapshotInitial.Affectations.TryGetValue(key, out var saved))
            return false;

        return !string.Equals(saved.ConseillerPrioritaire?.Trim(), conseillerPrioritaire?.Trim(), StringComparison.OrdinalIgnoreCase)
               || !string.Equals(saved.ConseillerSecondaire?.Trim(), conseillerSecondaire?.Trim(), StringComparison.OrdinalIgnoreCase)
               || !string.Equals(saved.ConseillerTertiaire?.Trim(), conseillerTertiaire?.Trim(), StringComparison.OrdinalIgnoreCase);
    }

    private string FormatDelta(double delta, string unite)
    {
        if (Math.Abs(delta) < 0.0001)
            return "0";

        var prefix = delta > 0 ? "+" : "";
        var suffix = string.IsNullOrWhiteSpace(unite) ? "" : $" {unite}";

        return $"{prefix}{delta:F2}{suffix}";
    }

    private string GetDeltaStyle(double delta)
    {
        if (Math.Abs(delta) < 0.0001)
            return "color:#6C7A89;font-weight:600";

        if (delta > 0)
            return "color:#1B5E20;font-weight:700";

        return "color:#B71C1C;font-weight:700";
    }

    private string GetDeltaCellStyle(double delta)
    {
        var baseStyle = "text-align:center;font-weight:700;";

        if (Math.Abs(delta) < 0.0001)
            return baseStyle + "background:#F5F7FA;color:#6C7A89";

        if (delta > 0)
            return baseStyle + "background:#E8F5E9;color:#1B5E20";

        return baseStyle + "background:#FDECEA;color:#B71C1C";
    }

    private string GetPortefeuilleCellStyle(double taille, bool segmentNonRenseigne)
    {
        var baseStyle = "text-align:center;font-weight:700;font-size:15px;";

        if (segmentNonRenseigne || taille <= 0)
            return baseStyle + "background:#E8EDF2;color:#6C7A89";

        if (taille < 150)
            return baseStyle + "background:#FDECEA;color:#B71C1C";

        if (taille < 300)
            return baseStyle + "background:#FFF3E0;color:#E65100";

        return baseStyle + "background:#E8F5E9;color:#1B5E20";
    }

    private void Enregistrer()
    {
        if (model == null)
            return;

        StateService.UpdateRegles(model);

        snapshotInitial = CreateSnapshot();

        Snackbar.Add(
            "Modifications enregistrées — les valeurs actuelles deviennent la nouvelle référence de simulation.",
            Severity.Success,
            cfg =>
            {
                cfg.Icon = Icons.Material.Filled.CheckCircle;
                cfg.VisibleStateDuration = 3000;
            }
        );
    }

    private static bool IsBanquePriveeSegment(string? segment) =>
        SegmentsBanquePrivee.Contains(segment?.Trim() ?? string.Empty);

    private static string FormatSegmentLabel(string? segment) =>
        IsBanquePriveeSegment(segment) ? $"{segment} (Banque Privée)" : (segment ?? string.Empty);

    private static string FormatProfilLabel(string? profil) =>
        ProfilsBanquePrivee.Contains(profil ?? string.Empty, StringComparer.OrdinalIgnoreCase)
            ? $"{profil} (Banque Privée)"
            : (profil ?? string.Empty);

    private async Task ExportExcel()
    {
        if (model == null) return;

        var sb = new System.Text.StringBuilder();

        sb.AppendLine("INTENSITÉ RELATIONNELLE");
        sb.AppendLine("Segment;Nb RDV/an;Durée RDV (h);Intensité");
        foreach (var s in model.SegmentsIntensite)
            sb.AppendLine($"{FormatSegmentLabel(s.Segment)};{s.NombreRdvParAn:F2};{s.DureeRdvHeures:F2};{GetIntensite(s):F2}");

        sb.AppendLine();
        sb.AppendLine("TEMPS CONSEILLER");
        sb.AppendLine("Profil;Part tps commercial (%);Volume horaire (h)");
        foreach (var p in model.ConseillersProfils)
            sb.AppendLine($"{p.Profil};{GetPartTempsCommercialPctDisplay(p):F0};{GetVolumeHoraire(p):F1}");

        sb.AppendLine();
        sb.AppendLine("RÈGLES D’AFFECTATION");
        sb.AppendLine("Segment;Conseiller Prioritaire;Conseiller Secondaire;Conseiller Tertiaire");
        foreach (var r in model.ReglesAffectationSegments)
            sb.AppendLine($"{FormatSegmentLabel(r.Segment)};{r.ConseillerPrioritaire};{r.ConseillerSecondaire};{r.ConseillerTertiaire}");

        sb.AppendLine();
        sb.AppendLine("PORTEFEUILLE THÉORIQUE");
        sb.AppendLine("Segment;Intensité;Volume horaire;Taille théorique");
        foreach (var t in model.TaillesTheoretiques)
        {
            var intensite = IsSegmentNonRenseigne(t.SegmentCouvert) ? 0 : GetIntensiteBySegment(t.SegmentCouvert);
            var volume = GetVolumeHoraireByProfil(t.Profil);
            var taille = intensite > 0 ? volume / intensite : 0;
            sb.AppendLine($"{FormatSegmentLabel(t.SegmentCouvert)};{intensite:F2};{volume:F1};{(taille > 0 ? taille.ToString("N0") : "—")}");
        }

        var csv = sb.ToString();
        var fileName = $"parametres_CA_{DateTime.Now:yyyyMMdd_HHmm}.csv";
        await JS.InvokeVoidAsync("downloadCsvFile", fileName, csv);
    }


    private sealed class SimulationSnapshot
    {
        public double HeuresParSemaine { get; set; }
        public double NbSemainesParAn { get; set; }

        public Dictionary<string, SegmentSnapshot> Segments { get; set; } =
            new(StringComparer.OrdinalIgnoreCase);

        public Dictionary<string, double> PartsCommerciales { get; set; } =
            new(StringComparer.OrdinalIgnoreCase);

        public Dictionary<string, AffectationSnapshot> Affectations { get; set; } =
            new(StringComparer.OrdinalIgnoreCase);
    }

    private sealed class SegmentSnapshot
    {
        public string Segment { get; set; } = string.Empty;
        public double NombreRdvParAn { get; set; }
        public double DureeRdvHeures { get; set; }
    }

    private sealed class AffectationSnapshot
    {
        public string Segment { get; set; } = string.Empty;
        public string ConseillerPrioritaire { get; set; } = string.Empty;
        public string ConseillerSecondaire { get; set; } = string.Empty;
        public string ConseillerTertiaire { get; set; } = string.Empty;
    }
}
