@page "/"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@inject MockDataService DataService
@inject SegmentationStateService StateService
@implements IDisposable

<PageTitle>Vision Globale — CA Segmentation</PageTitle>

<div class="ca-page">
    <div class="ca-page-header">
        <div>
            <MudText Typo="Typo.h5" Class="ca-page-title">Vision Globale</MudText>
            <MudText Typo="Typo.caption" Class="ca-page-subtitle">Tableau de bord du dimensionnement du réseau</MudText>
        </div>
        <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small" Color="Color.Default">
            <MudButton StartIcon="@Icons.Material.Filled.Language"
                       Variant="@(vueReseau ? Variant.Filled : Variant.Outlined)"
                       Color="@(vueReseau ? Color.Primary : Color.Default)"
                       OnClick="() => SetVue(true)">Vue Réseau</MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.Business"
                       Variant="@(!vueReseau ? Variant.Filled : Variant.Outlined)"
                       Color="@(!vueReseau ? Color.Primary : Color.Default)"
                       OnClick="() => SetVue(false)">Vue par Agence</MudButton>
        </MudButtonGroup>
    </div>

    @if (model != null)
    {
        <!-- KPI Cards -->
        <MudGrid Spacing="3" Class="mb-4">
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="2" Class="mud-kpi-card pa-4 d-flex align-center gap-4" Style="border-radius:8px">
                    <MudAvatar Style="background:rgba(0,91,43,.12);color:#005B2B;width:52px;height:52px">
                        <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large"/>
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.h4" Style="font-weight:700;color:#12374C;line-height:1">@FormatClients(model.Kpis.TotalClients)</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Total Clients</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@model.Kpis.TotalClients.ToString("N0") clients</MudText>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="2" Class="mud-kpi-card pa-4 d-flex align-center gap-4" Style="border-radius:8px">
                    <MudAvatar Style="background:rgba(26,78,107,.12);color:#1A4E6B;width:52px;height:52px">
                        <MudIcon Icon="@Icons.Material.Filled.SupportAgent" Size="Size.Large"/>
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.h4" Style="font-weight:700;color:#12374C;line-height:1">@model.Kpis.TotalConseillers.ToString("N0")</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Total Conseillers</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Équipes commerciales</MudText>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="2" Class="mud-kpi-card pa-4 d-flex align-center gap-4" Style="border-radius:8px">
                    <MudAvatar Style="background:rgba(232,119,34,.12);color:#E87722;width:52px;height:52px">
                        <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Large"/>
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.h4" Style="font-weight:700;color:#12374C;line-height:1">@model.Kpis.TaillePortefeuilleMoyenne.ToString("N0")</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Taille portefeuille moyenne</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">clients / conseiller</MudText>
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <!-- Sections 1 & 2 -->
        <MudGrid Spacing="3" Class="mb-3">
            <MudItem xs="12" md="6">
                <MudPaper Elevation="2" Style="border-radius:8px;overflow:hidden;height:100%">
                    <div class="ca-section-header">
                        <span class="ca-section-badge">1</span>
                        Clients par Segment
                    </div>
                    <div class="pa-3">
                        @foreach (var s in model.ClientsParSegment)
                        {
                            bool isTotal = s.Segment == "Total";
                            <div style="margin-bottom:@(isTotal ? "0" : "12px");padding-top:@(isTotal ? "10px" : "0");border-top:@(isTotal ? "2px solid #E8EDF2" : "none")">
                                <div class="d-flex justify-space-between align-center mb-1">
                                    <MudText Typo="Typo.body2" Style="@(isTotal ? "font-weight:700" : "")">@s.Segment</MudText>
                                    <div class="d-flex gap-3">
                                        <MudText Typo="Typo.body2" Style="font-weight:600;color:#1A4E6B;min-width:50px;text-align:right">@FormatClientsShort(s.NombreClients)</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="min-width:42px;text-align:right">@s.Pourcentage.ToString("F1")%</MudText>
                                    </div>
                                </div>
                                @if (!isTotal)
                                {
                                    <MudProgressLinear Value="@s.Pourcentage" Max="100" Rounded="true" Size="Size.Small"
                                                       Color="@GetSegmentColor(s.Segment)" />
                                }
                            </div>
                        }
                    </div>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudPaper Elevation="2" Style="border-radius:8px;overflow:hidden;height:100%">
                    <div class="ca-section-header">
                        <span class="ca-section-badge">2</span>
                        Profils de conseillers
                    </div>
                    <div class="pa-3">
                        @foreach (var p in model.ProfilsConseillers)
                        {
                            bool isTotal = p.Profil == "Total";
                            <div style="margin-bottom:@(isTotal ? "0" : "12px");padding-top:@(isTotal ? "10px" : "0");border-top:@(isTotal ? "2px solid #E8EDF2" : "none")">
                                <div class="d-flex justify-space-between align-center mb-1">
                                    <MudText Typo="Typo.body2" Style="@(isTotal ? "font-weight:700" : "")">@p.Profil</MudText>
                                    <div class="d-flex gap-3">
                                        <MudText Typo="Typo.body2" Style="font-weight:600;color:#1A4E6B;min-width:40px;text-align:right">@p.NombreConseillers.ToString("N0")</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="min-width:42px;text-align:right">@p.Pourcentage.ToString("F1")%</MudText>
                                    </div>
                                </div>
                                @if (!isTotal)
                                {
                                    <MudProgressLinear Value="@p.Pourcentage" Max="100" Rounded="true" Size="Size.Small"
                                                       Color="@GetProfilColor(p.Profil)" />
                                }
                            </div>
                        }
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <!-- Sections 3 & 4 -->
        <MudGrid Spacing="3" Class="mb-3">
            <MudItem xs="12" md="6">
                <MudPaper Elevation="2" Style="border-radius:8px;overflow:hidden;height:100%">
                    <div class="ca-section-header">
                        <span class="ca-section-badge">3</span>
                        Taille des Portefeuilles
                    </div>
                    <div class="pa-3">
                        @foreach (var t in model.TaillesPortefeuilles)
                        {
                            <div style="padding:10px 0;border-bottom:1px solid #F0F2F5">
                                <div class="d-flex justify-space-between align-center mb-1">
                                    <MudText Typo="Typo.body2">@t.Profil</MudText>
                                    <MudText Typo="Typo.body2" Style="font-weight:700;color:#1A4E6B">
                                        @t.ClientsParConseiller.ToString("N0") <span style="font-size:11px;font-weight:400;color:#6C7A89">clients/cons.</span>
                                    </MudText>
                                </div>
                                <div class="d-flex align-center gap-3">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="min-width:110px">Taux de remplissage</MudText>
                                    <MudProgressLinear Value="@t.TauxRemplissage" Max="100" Rounded="true" Size="Size.Small"
                                                       Color="Color.Primary" Style="flex:1" />
                                    <MudText Typo="Typo.body2" Style="font-weight:600;color:#005B2B;min-width:36px;text-align:right">@t.TauxRemplissage.ToString("F0")%</MudText>
                                </div>
                            </div>
                        }
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2 d-block">
                            Moyenne : @model.Kpis.TaillePortefeuilleMoyenne clients/cons. &nbsp;|&nbsp;
                            Taux global : @moyenneTauxRemplissage.ToString("F0")%
                        </MudText>
                    </div>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudPaper Elevation="2" Style="border-radius:8px;overflow:hidden;height:100%">
                    <div class="ca-section-header">
                        <span class="ca-section-badge">4</span>
                        Indicateurs d'Applicabilité
                    </div>
                    <div class="pa-3">
                        @foreach (var ind in model.Indicateurs)
                        {
                            var color = ind.EstPositif ? Color.Success : Color.Error;
                            var hexColor = ind.EstPositif ? "#27AE60" : "#E74C3C";
                            <div style="margin-bottom:16px">
                                <div class="d-flex justify-space-between align-center mb-1">
                                    <MudText Typo="Typo.body2">@ind.Libelle</MudText>
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                             Style="@($"background:{hexColor};color:white;height:24px;font-size:12px;font-weight:700")">
                                        @(ind.EstPositif && ind.Valeur > 0 ? "+" : "")@ind.Valeur.ToString("F1")%
                                    </MudChip>
                                </div>
                                <MudProgressLinear Value="@Math.Min(ind.Valeur, 100)" Max="100" Rounded="true"
                                                   Size="Size.Small" Color="@color" />
                            </div>
                        }
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <!-- Section 5: Agences avec des problématiques -->
        <MudPaper Elevation="2" Style="border-radius:8px;overflow:hidden" Class="mb-3">
            <div class="ca-section-header">
                <span class="ca-section-badge">5</span>
                Agences avec des problématiques
            </div>
            <MudTable Items="@model.AgencesProblematiques" Dense="true" Hover="true" Striped="true"
                      SortLabel="Trier" AllowUnsorted="false" Elevation="0">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<AgenceProblematique,object>(x=>x.NomAgence)">Agence</MudTableSortLabel></MudTh>
                    <MudTh Style="text-align:center"><MudTableSortLabel SortBy="new Func<AgenceProblematique,object>(x=>x.ScoreGlobal)">Score Global</MudTableSortLabel></MudTh>
                    <MudTh Style="text-align:right"><MudTableSortLabel SortBy="new Func<AgenceProblematique,object>(x=>x.Remplissage)">Remplissage</MudTableSortLabel></MudTh>
                    <MudTh Style="text-align:right"><MudTableSortLabel SortBy="new Func<AgenceProblematique,object>(x=>x.ConcordanceSegment)">Concord. Segment</MudTableSortLabel></MudTh>
                    <MudTh Style="text-align:right"><MudTableSortLabel SortBy="new Func<AgenceProblematique,object>(x=>x.ConcordanceProfil)">Concord. Profil</MudTableSortLabel></MudTh>
                    <MudTh Style="text-align:right"><MudTableSortLabel SortBy="new Func<AgenceProblematique,object>(x=>x.EvolutionEffectifs)">Évol. Effectifs</MudTableSortLabel></MudTh>
                    <MudTh Style="text-align:right"><MudTableSortLabel SortBy="new Func<AgenceProblematique,object>(x=>x.RotationClients)">Rotation Clients</MudTableSortLabel></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Agence" Style="font-weight:500">@context.NomAgence</MudTd>
                    <MudTd DataLabel="Score" Style="text-align:center">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                 Style="@($"background:{GetScoreColor(context.NiveauScore)};color:white;height:26px;font-weight:700;min-width:42px")">
                            @context.ScoreGlobal
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Remplissage" Style="text-align:right">@context.Remplissage.ToString("F0")%</MudTd>
                    <MudTd DataLabel="Concord. Segment" Style="text-align:right">@context.ConcordanceSegment.ToString("F0")%</MudTd>
                    <MudTd DataLabel="Concord. Profil" Style="text-align:right">@context.ConcordanceProfil.ToString("F0")%</MudTd>
                    <MudTd DataLabel="Évol. Effectifs" Style="@($"text-align:right;font-weight:600;color:{(context.EvolutionEffectifs >= 0 ? "#27AE60" : "#E74C3C")}")">
                        @(context.EvolutionEffectifs >= 0 ? "+" : "")@context.EvolutionEffectifs.ToString("F1")%
                    </MudTd>
                    <MudTd DataLabel="Rotation Clients" Style="text-align:right">@context.RotationClients.ToString("F1")%</MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }

    <div class="ca-footer">© 2025 Crédit Agricole Nord de France — Plateforme de Dimensionnement</div>
</div>

@code {
    private VisionGlobaleModel? model;
    private bool vueReseau = true;
    private double moyenneTauxRemplissage;

    protected override void OnInitialized()
    {
        StateService.OnChange += OnReglesChanged;
        LoadData();
    }

    public void Dispose() => StateService.OnChange -= OnReglesChanged;

    private void OnReglesChanged()
    {
        ApplyStateToModel();
        InvokeAsync(StateHasChanged);
    }

    private void SetVue(bool reseau) { vueReseau = reseau; LoadData(); }

    private void LoadData()
    {
        model = DataService.GetVisionGlobale(!vueReseau);
        ApplyStateToModel();
    }

    private void ApplyStateToModel()
    {
        if (model == null) return;
        // Mettre à jour les tailles de portefeuilles calculées par les règles
        model.TaillesPortefeuilles = StateService.TaillesPortefeuilles;
        // Mettre à jour les KPIs dérivés
        model.Kpis.TaillePortefeuilleMoyenne = StateService.TaillePortefeuilleMoyenne;
        model.Kpis.TotalConseillers          = StateService.TotalConseillersCible;
        if (model.TaillesPortefeuilles.Any())
            moyenneTauxRemplissage = model.TaillesPortefeuilles.Average(t => t.TauxRemplissage);
    }

    private string FormatClients(int n) => n >= 1_000_000 ? (n / 1_000_000.0).ToString("F1") + "M"
                                         : n >= 1_000     ? (n / 1_000.0).ToString("F0")     + "K"
                                         : n.ToString();

    private string FormatClientsShort(int n) => n >= 1_000_000 ? (n / 1_000_000.0).ToString("F1") + "M"
                                              : n >= 1_000     ? (n / 1_000.0).ToString("F0") + "K"
                                              : n.ToString();

    private Color GetSegmentColor(string segment) => segment switch
    {
        "Faible Potentiel" => Color.Info,
        "Haut de Gamme"    => Color.Success,
        _                  => Color.Secondary
    };

    private Color GetProfilColor(string profil) => profil switch
    {
        "Portefeuilles Mutualisés" => Color.Info,
        "Dédiés - Haut de Gamme"   => Color.Success,
        _                          => Color.Secondary
    };

    private string GetScoreColor(string niveau) => niveau switch
    {
        "danger"  => "#C8102E",
        "warning" => "#E87722",
        _         => "#27AE60"
    };
}
