    private string FormatClients(int n) =>
        n >= 1_000_000 ? (n / 1_000_000.0).ToString("F1") + "M"
        : n >= 1_000 ? (n / 1_000.0).ToString("F0") + "K"
        : n.ToString();

    private string FormatClientsShort(int n) =>
        n >= 1_000_000 ? (n / 1_000_000.0).ToString("F1") + "M"
        : n >= 1_000 ? (n / 1_000.0).ToString("F0") + "K"
        : n.ToString();

    private Color GetSegmentColor(string segment) => segment switch
    {
        "Faible Potentiel" => Color.Info,
        "Haut de Gamme" => Color.Success,
        _ => Color.Secondary
    };

    private Color GetProfilColor(string profil) => profil switch
    {
        "Portefeuilles Mutualisés" => Color.Info,
        "Dédiés - Haut de Gamme" => Color.Success,
        _ => Color.Secondary
    };

    private string GetScoreColor(string niveau) => niveau switch
    {
        "danger" => "#C8102E",
        "warning" => "#E87722",
        _ => "#27AE60"
    };
