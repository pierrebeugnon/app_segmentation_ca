@page "/portefeuilles-vision-client"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@inject MockDataService DataService

<PageTitle>Portefeuilles / Vision Client — CA Segmentation</PageTitle>

<div class="ca-page">
    <div class="ca-page-header">
        <div>
            <MudText Typo="Typo.h5" Class="ca-page-title">Portefeuilles / Vision Client</MudText>
            <MudText Typo="Typo.caption" Class="ca-page-subtitle">Dimensionnement des portefeuilles (en nombre de clients)</MudText>
        </div>
        <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
            <MudButton StartIcon="@Icons.Material.Filled.Language"
                       Variant="@(vueReseau ? Variant.Filled : Variant.Outlined)"
                       Color="@(vueReseau ? Color.Primary : Color.Default)"
                       OnClick="() => SetVue(true)">Vue Réseau</MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.Business"
                       Variant="@(!vueReseau ? Variant.Filled : Variant.Outlined)"
                       Color="@(!vueReseau ? Color.Primary : Color.Default)"
                       OnClick="() => SetVue(false)">Vue par Agence</MudButton>
        </MudButtonGroup>
    </div>

    <MudPaper Elevation="2" Style="border-radius:8px;overflow:hidden" Class="mb-4">
        <div class="ca-section-header">
            <span class="ca-section-badge">1</span>
            Dimensionnement cible des portefeuilles (en nombre de clients)
        </div>
        <MudTable Items="@cibleRows" Dense="true" Hover="true" Elevation="0"
                  RowClassFunc="@((row, i) => row.IsTotal ? "mud-row-total" : "")">
            <HeaderContent>
                <MudTh>Segments Clients</MudTh>
                <MudTh Style="text-align:right">Portefeuilles Mutualisés</MudTh>
                <MudTh Style="text-align:right">Dédiés</MudTh>
                <MudTh Style="text-align:right">Dédiés – Haut de Gamme</MudTh>
                <MudTh Style="text-align:right">Total</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd Style="@(context.IsTotal ? "font-weight:700" : "")">@context.Segment</MudTd>
                <MudTd Style="text-align:right">@FormatVal(context.Mutualise)</MudTd>
                <MudTd Style="text-align:right">@FormatVal(context.Dedie)</MudTd>
                <MudTd Style="text-align:right">@FormatVal(context.DedieHautDeGamme)</MudTd>
                <MudTd Style="text-align:right;font-weight:700;color:#1A4E6B">@context.Total.ToString("N0")</MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>

    <MudPaper Elevation="2" Style="border-radius:8px;overflow:hidden" Class="mb-4">
        <div class="ca-section-header">
            <span class="ca-section-badge">2</span>
            Dimensionnement des portefeuilles existants (en nombre de clients)
        </div>
        <MudTable Items="@existantRows" Dense="true" Hover="true" Elevation="0"
                  RowClassFunc="@((row, i) => row.IsTotal ? "mud-row-total" : "")">
            <HeaderContent>
                <MudTh>Segments Clients</MudTh>
                <MudTh Style="text-align:right">Portefeuilles Mutualisés</MudTh>
                <MudTh Style="text-align:right">Dédiés</MudTh>
                <MudTh Style="text-align:right">Dédiés – Haut de Gamme</MudTh>
                <MudTh Style="text-align:right">Total</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd Style="@(context.IsTotal ? "font-weight:700" : "")">@context.Segment</MudTd>
                <MudTd Style="text-align:right">@FormatVal(context.Mutualise)</MudTd>
                <MudTd Style="text-align:right">@FormatVal(context.Dedie)</MudTd>
                <MudTd Style="text-align:right">@FormatVal(context.DedieHautDeGamme)</MudTd>
                <MudTd Style="text-align:right;font-weight:700;color:#1A4E6B">@context.Total.ToString("N0")</MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>

    <div class="ca-footer">© 2025 Crédit Agricole Nord de France — Plateforme de Dimensionnement</div>
</div>

@code {
    private bool vueReseau = true;
    private List<DimensionnementClientRow> cibleRows   = new();
    private List<DimensionnementClientRow> existantRows = new();

    protected override void OnInitialized() => LoadData();

    private void SetVue(bool reseau) { vueReseau = reseau; LoadData(); }

    private void LoadData()
    {
        cibleRows    = DataService.GetDimensionnementClientCible();
        existantRows = DataService.GetDimensionnementClientExistant();
    }

    private MarkupString FormatVal(int? v) =>
        v.HasValue && v.Value > 0
            ? new MarkupString($"<span style='color:#1A4E6B;font-weight:600'>{v.Value:N0}</span>")
            : new MarkupString("<span style='color:#9AA5B1'>—</span>");
}
