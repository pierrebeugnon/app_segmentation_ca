<!-- ── Colonne 2 : Charge à transférer à la BP (HDG Premium uniquement) ── -->
@if (_showChargesManuelles)
{
    <td style="text-align:center;padding:4px 3px;background:#F5EAD9">
        @if (!row.IsTotal)
        {
            if (IsHdgPremium(row.Segment))
            {
                var segT = row.Segment;
                var valTransBP = _chargeATransfererBP.GetValueOrDefault(segT);
                <MudNumericField T="double?"
                                 Value="@valTransBP"
                                 ValueChanged="@(v => { _chargeATransfererBP[segT] = v; StateHasChanged(); })"
                                 Format="F2" Step="0.25" Min="0"
                                 HideSpinButtons="true"
                                 Variant="Variant.Text"
                                 Margin="Margin.Dense"
                                 Class="ca-dim-etp-input"
                                 InputStyle="text-align:center;font-size:12px;font-weight:700;padding:2px 4px;color:#7A4A1E" />
            }
            else
            {
                <span style="color:#BDBDBD;font-size:11px">—</span>
            }
        }
        else
        {
            var totalTransBP = GetTotalATransfererBP();
            <span style="font-weight:700;font-size:12px;color:#7A4A1E">
                @(totalTransBP > 0 ? totalTransBP.ToString("F2") : "—")
            </span>
        }
    </td>
}

