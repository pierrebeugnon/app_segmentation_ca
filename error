using Microsoft.AspNetCore.Components;
using Microsoft.AspNetCore.Components.Web;
using Telerik.Blazor.Components;
using Segmentation.Client.Models;

namespace Segmentation.Client.Components.Layout
{
	/// <summary>
	/// Composant Menu
	/// </summary>
	public partial class Menu : IDisposable
	{
		#region attributes
		private string tag = string.Empty;
		#endregion

		#region properties
		/// <summary>
		/// Version de l'application
		/// </summary>
		[Parameter]
		public string AppVersion { get; set; } = string.Empty;

		/// <summary>
		/// Est étendu ou non
		/// </summary>
		public bool IsExpanded { get; set; }

		/// <summary>
		/// Tiroir
		/// </summary>
		public TelerikDrawer<DrawerItem> Drawer { get; set; } = null!;

		/// <summary>
		/// Tiroir sélectionné
		/// </summary>
		public DrawerItem SelectedItem { get; set; } = null!;

		/// <summary>
		/// Données des tiroirs
		/// </summary>
		public List<DrawerItem> Data { get; set; } = new();
		#endregion

		#region protected methods
		/// <inheritdoc/>
		protected override async Task OnInitializedAsync()
		{
			AppState!.OnChange += StateHasChanged;
			tag = NavigationManager!.Uri.Replace(NavigationManager.BaseUri, string.Empty);
			SetMenuData();
			await GetAppVersionAsync();
		}

		protected virtual void Dispose(bool disposing)
		{
			AppState!.OnChange -= StateHasChanged;
		}
		#endregion

		#region publics methods
		public async Task ToggleDrawer(MouseEventArgs e) => await Drawer.ToggleAsync();

		public async Task ExpandDrawer(MouseEventArgs e) => await Drawer.ExpandAsync();

		public async Task CollapseDrawer(MouseEventArgs e) => await Drawer.CollapseAsync();

		public void Dispose()
		{
			Dispose(true);
			GC.SuppressFinalize(this);
		}

		public void OnItemClick(DrawerItem item)
		{
			SelectedItem = item;
			NavigationManager!.NavigateTo(item.NavigateTo, false);
			StateHasChanged();
		}
		#endregion

		#region privates methods
		private void SetMenuData()
		{
			Data = new List<DrawerItem>
			{
				new() { Text = "Accueil",                    IconClass = "k-icon fad fa-home",             NavigateTo = "/"},
				new() { Text = "Vision Globale",             IconClass = "k-icon fad fa-chart-pie",        NavigateTo = "/vision-globale" },
				new() { Text = "Dimensionnement par agence",            IconClass = "k-icon fad fa-briefcase",     NavigateTo = "/portefeuille" },
				new() { Text = "Règles & Hypothèses",        IconClass = "k-icon fad fa-sliders",       NavigateTo = "/regles-hypotheses" },
				new() { Text = "Administration",             IconClass = "k-icon fad fa-cog",              NavigateTo = "/Administration", HabilitationCodes = new List<string>() { "ADMIN" } },
				new() { Text = "Assistance",                 IconClass = "k-icon fad fa-comments-question",NavigateTo = "/Help", Position = DrawerItem.ItemPosition.Bottom },
			};
			SelectedItem = Data.SingleOrDefault(x => x.Tag == tag) ?? Data[0];
		}

		private async Task GetAppVersionAsync()
		{
			AppVersion = await HttpClient!.GetStringAsync("api/Environment/appversion");
			if (string.IsNullOrWhiteSpace(AppVersion))
			{
				AppVersion = configuration["Application:Version"]!;
			}
		}
		#endregion
	}
}
