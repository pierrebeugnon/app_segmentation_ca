private IReadOnlyList<string> GetOptionsProfilsPourSegment(string segment)
{
    return BuildOptionsProfilsForSegment(segment?.Trim() ?? string.Empty);
}







<MudTd Style="background:#FFFDE7;overflow:visible">
    <MudSelect T="string"
               Value="@context.ConseillerPrioritaire"
               ValueChanged="@(v => { context.ConseillerPrioritaire = v; StateHasChanged(); })"
               Variant="Variant.Outlined"
               Margin="Margin.Dense"
               Dense="true"
               Clearable="true"
               Disabled="@selectDisabled"
               Style="min-width:220px">

        @foreach (var p in optionsPrioritaire)
        {
            <MudSelectItem T="string" Value="@p">@p</MudSelectItem>
        }
    </MudSelect>
</MudTd>

