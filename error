using MapsterMapper;
using Segmentation.Application.Contracts;
using Segmentation.Application.Queries.Region;
using Segmentation.Application.Responses;
using Segmentation.Core.Entities;
using Segmentation.Core.Repositories;
using System;
using System.Collections.Generic;
using System.Text;

namespace Segmentation.Application.Handlers.Region
{
	internal class GetRegionByIdQueryHandler : IQueryHandler<GetRegionByIdQuery, RegionResponse>
	{
		private readonly IMapper _mapper;
		private readonly IRegionsRepository _repository;
		public GetRegionByIdQueryHandler(IMapper mapper, IRegionsRepository repository)
		{
			_mapper = mapper;
			_repository = repository;
		}
		public async Task<RegionResponse> Handle(GetRegionByIdQuery request, CancellationToken cancellationToken)
		{
			Regions? regions = await _repository.GetByIdAsync(request.RegionId);
			return _mapper.Map<RegionResponse>(regions!);
		}
	}
}
