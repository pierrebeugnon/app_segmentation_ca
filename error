using CANDF.Kosmos.Dependencies.Services;
using MapsterMapper;
using MediatR;
using Microsoft.AspNetCore.Mvc;

namespace Segmentation.Server.Controllers
{
    [ApiController]
    [Route("api/[controller]")]
    public class SegmentationBaseController : ControllerBase
    {
        protected IMediator? _mediator;
        protected IMapper? _mapper;

        public SegmentationBaseController()
        {
        
        }

        public SegmentationBaseController(IMediator mediator, IMapper mapper)
        {
            _mediator = mediator;
            _mapper = mapper;
        }
    }
}
