protected override async Task OnInitializedAsync()
{
    _isLoading = true;

    try
    {
        // 1. Abonnement aux changements des règles
        StateService.OnChange += OnReglesChanged;

        // 2. Chargement des 1258 lignes depuis l'API
        _segmentationDistributive = await Http.GetFromJsonAsync<List<SegmentationDistributiveData>>(
            "api/SegmentationDistributive"
        ) ?? new();

        Console.WriteLine($">>> SegmentationDistributive chargée : {_segmentationDistributive.Count} lignes");

        // 3. Filtre par défaut sur la première agence pour ne pas exploser l'affichage
        filtreRegion = _segmentationDistributive
            .Select(x => x.LibRegion)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .OrderBy(x => x)
            .FirstOrDefault();

        filtreSecteur = _segmentationDistributive
            .Where(x => string.IsNullOrEmpty(filtreRegion) || x.LibRegion == filtreRegion)
            .Select(x => x.LibSecteur)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .OrderBy(x => x)
            .FirstOrDefault();

        filtreAgence = _segmentationDistributive
            .Where(x => string.IsNullOrEmpty(filtreRegion) || x.LibRegion == filtreRegion)
            .Where(x => string.IsNullOrEmpty(filtreSecteur) || x.LibSecteur == filtreSecteur)
            .Select(x => x.LibAgence)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .OrderBy(x => x)
            .FirstOrDefault();

        // 4. Applique les filtres par défaut sur les données
        _segmentationDistributiveFiltree = _segmentationDistributive
            .Where(x => string.IsNullOrEmpty(filtreRegion) || x.LibRegion == filtreRegion)
            .Where(x => string.IsNullOrEmpty(filtreSecteur) || x.LibSecteur == filtreSecteur)
            .Where(x => string.IsNullOrEmpty(filtreAgence) || x.LibAgence == filtreAgence)
            .ToList();

        // 5. Mémorise l'état appliqué (pour HasPendingFilterChanges)
        filtreRegionApplique = filtreRegion;
        filtreSecteurApplique = filtreSecteur;
        filtreAgenceApplique = filtreAgence;

        // 6. Init des données de la page
        BuildFilterOptions();
        InitData();

        Console.WriteLine($">>> Agence par défaut : {filtreAgence}");
        Console.WriteLine($">>> Lignes filtrées : {_segmentationDistributiveFiltree.Count}");
    }
    catch (Exception ex)
    {
        Console.WriteLine($"Erreur chargement Portefeuille : {ex.Message}");
    }
    finally
    {
        _isLoading = false;
    }
}
