// Section 4 : calculée dynamiquement à partir des Sections 1, 2, 3
private List<TailleTheoriqueRow> TaillesCalculees =>
    model?.ReglesAffectationSegments
        .Select(r =>
        {
            var profil = r.ConseillerPrioritaire ?? "";
            var ligneMetier = model.ConseillersProfils
                .FirstOrDefault(p => string.Equals(
                    p.Profil, profil, StringComparison.OrdinalIgnoreCase))?.LigneMetier
                ?? "N/A";

            return new TailleTheoriqueRow
            {
                LigneMetier = ligneMetier,
                Profil = profil,
                SegmentCouvert = r.Segment ?? ""
            };
        })
        .ToList()
    ?? new List<TailleTheoriqueRow>();
