private double? GetRealEtpForSlot(string segment, ConseillerSlot slot)
{
    if (_segmentationDistributiveFiltree == null || !_segmentationDistributiveFiltree.Any())
        return null;

    var matricule = ExtractMatriculeFromSlotLabel(slot.Label);

    var lignes = _segmentationDistributiveFiltree
        .Where(x => x.TypeConseiller.Equals(slot.Profil, StringComparison.OrdinalIgnoreCase))
        .Where(x => x.MatriculeConseiller == matricule)
        .ToList();

    if (!lignes.Any())
        return null;

    var nbClients = lignes.Sum(x => GetClientCountForSegment(x, segment));

    if (nbClients <= 0)
        return null;

    return ConvertClientsToEtp(segment, slot.Profil, nbClients);
}

