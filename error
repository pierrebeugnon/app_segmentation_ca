@inject NavigationManager NavigationManager
<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(Program).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    @{
                        NavigationManager.NavigateTo($"api/Auth/AuthUser?returnUrl={NavigationManager.Uri}", forceLoad: true);
                    }
                </NotAuthorized>
                <Authorizing>
                    <div id="loading-overlay">
                        <span class="k-color-primary facd fa-4x fa-logo-ca"></span>
                        <p>@configuration["Application:DisplayName"]</p>
                        <p>Authentification en cours...</p>
                        <img src="css/peri/images/ca-logo-loader.gif" class="loader-ca--img" />
                    </div>
                </Authorizing>
            </AuthorizeRouteView>
        </Found>
        <NotFound>
            <LayoutView Layout="@typeof(MainLayout)">
                @{
                    NavigationManager.NavigateTo("/NotFound", forceLoad: false);
                }
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
