@page "/dashboard"
@inject SegmentationStateService StateService
@inject DashboardService DashboardService
@inject HttpClient Http
@using Segmentation.Client.Services
@using Segmentation.Shared.Models
@using System.Net.Http.Json
@using Segmentation.Client.Components.Dashboard

<PageTitle>Pilotage — CA Segmentation</PageTitle>

<div class="dash-page">

    @if (_isLoading)
    {
        <div class="dash-loader">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
        </div>
    }

    <!-- ═══════════════════════════════════════════════════════
         ZONE 1 — En-tête épuré
    ═══════════════════════════════════════════════════════ -->
    <div class="dash-header">
        <div>
            <div class="dash-title">Pilotage du dimensionnement</div>
            <div class="dash-subtitle">Vue d'ensemble du réseau CA Nord de France</div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════
         ZONE 1B — Filtres cascadés
    ═══════════════════════════════════════════════════════ -->
    <MudPaper Elevation="0" Class="dash-filters">
        <div class="dash-filters-inner">
            <span class="dash-filter-label">FILTRER PAR</span>

            <MudSelect T="string" Label="Région" Dense="true" Margin="Margin.Dense"
                       Variant="Variant.Outlined" Style="min-width:180px"
                       Value="@filtreRegion" ValueChanged="OnRegionChanged"
                       Clearable="true">
                @foreach (var r in allRegions)
                {
                    <MudSelectItem Value="@r">@r</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="string" Label="Secteur" Dense="true" Margin="Margin.Dense"
                       Variant="Variant.Outlined" Style="min-width:200px"
                       Value="@filtreSecteur" ValueChanged="OnSecteurChanged"
                       Clearable="true">
                @foreach (var s in allSecteurs)
                {
                    <MudSelectItem Value="@s">@s</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="string" Label="Agence" Dense="true" Margin="Margin.Dense"
                       Variant="Variant.Outlined" Style="min-width:220px"
                       Value="@filtreAgence" ValueChanged="OnAgenceChanged"
                       Clearable="true">
                @foreach (var a in allAgences)
                {
                    <MudSelectItem Value="@a">@a</MudSelectItem>
                }
            </MudSelect>

            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Check"
                       OnClick="ApplyFilters"
                       Disabled="@(!HasPendingFilterChanges || _isLoading)">
                Valider
            </MudButton>

            @if (!string.IsNullOrEmpty(filtreRegion) || !string.IsNullOrEmpty(filtreSecteur) || !string.IsNullOrEmpty(filtreAgence))
            {
                <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Secondary"
                           OnClick="ClearFilters">Effacer</MudButton>
            }
        </div>
    </MudPaper>

    <!-- ═══════════════════════════════════════════════════════
         ZONE 2 — 6 KPI HÉROS
    ═══════════════════════════════════════════════════════ -->
    <div class="dash-kpi-grid">

        <!-- KPI 1 — Nombre de Clients Commerciaux -->
        <div class="dash-kpi-card">
            <div class="dash-kpi-label">Nombre de Clients Commerciaux</div>
            <div class="dash-kpi-value dash-kpi-neutral">
                @FormatCompact(_kpis.ClientsCommerciaux)
            </div>
            <div class="dash-kpi-hint">Référence de dimensionnement</div>
        </div>

        <!-- KPI 2 — Nombre de conseillers (2 colonnes verticales) -->
        <div class="dash-kpi-card">
            <div class="dash-kpi-label">Nombre de conseillers</div>

            @{
                var deltaConseillers =
                _kpis.ConseillersExistants -
                _kpis.ConseillersCibles;

                var ratioConseillers =
                _kpis.ConseillersCibles > 0
                ? (double)_kpis.ConseillersExistants /
                _kpis.ConseillersCibles * 100
                : 0;
            }

            <div class="dash-kpi-cols">
                <div class="dash-kpi-col dash-kpi-line-existant">
                    <div class="dash-kpi-col-value">@_kpis.ConseillersExistants</div>
                    <div class="dash-kpi-col-label">Existant</div>
                </div>
                <div class="dash-kpi-col dash-kpi-line-cible">
                    <div class="dash-kpi-col-value">@_kpis.ConseillersCibles</div>
                    <div class="dash-kpi-col-label">Cible</div>
                </div>
            </div>

            <div class="dash-kpi-delta @(deltaConseillers >= 0 ? "dash-delta-good" : "dash-delta-critical")">
                @(deltaConseillers >= 0 ? "+" : "")@deltaConseillers vs cible (@ratioConseillers.ToString("F0")%)
            </div>
        </div>

        <!-- KPI 3 — Taux de couverture -->
        <div class="dash-kpi-card">
            <div class="dash-kpi-label">Taux de couverture</div>
            <div class="dash-kpi-value @GetKpiClass(_kpis.TauxCouverture, 100, 90)">
                @_kpis.TauxCouverture.ToString("F0")<span class="dash-kpi-unit">%</span>
            </div>
            <div class="dash-kpi-hint">Effectif réel vs besoin théorique</div>
        </div>

        <!-- KPI 4 — Taux de rotation portefeuille -->
        <div class="dash-kpi-card">
            <div class="dash-kpi-label">Taux de rotation portefeuille</div>
            <div class="dash-kpi-value @GetKpiClass(_kpis.TauxRotationPortefeuille, 10, 20)">
                @_kpis.TauxRotationPortefeuille.ToString("F0")<span class="dash-kpi-unit">%</span>
            </div>
            <div class="dash-kpi-hint">Entrées + sorties portefeuille</div>
        </div>

        <!-- KPI 5 — Concordance moyenne -->
        <div class="dash-kpi-card">
            <div class="dash-kpi-label">Concordance moyenne</div>
            <div class="dash-kpi-value @GetKpiClass(_kpis.Concordance, 80, 60)">
                @_kpis.Concordance.ToString("F0")<span class="dash-kpi-unit">%</span>
            </div>
            <div class="dash-kpi-hint">Alignement avec les règles R&H</div>
        </div>

        <!-- KPI 6 — Taux de pureté des portefeuilles -->
        <div class="dash-kpi-card">
            <div class="dash-kpi-label">Taux de pureté</div>
            <div class="dash-kpi-value @GetKpiClass(_kpis.TauxPurete, 80, 60)">
                @_kpis.TauxPurete.ToString("F0")<span class="dash-kpi-unit">%</span>
            </div>
            <div class="dash-kpi-hint">Clients sur le profil prioritaire R&H</div>
        </div>

    </div>

    <!-- ═══════════════════════════════════════════════════════
         ZONE 3 — Grille 2 colonnes
    ═══════════════════════════════════════════════════════ -->
    <div class="dash-bottom-grid">

        <div class="dash-bottom-left">
            <DashboardRepartitionSegment
                Repartition="@_repartition"
                Dimension="@_dimensionAffichage"
                DimensionChanged="OnDimensionChanged" />

            <DashboardDistributionGeographique
                Distribution="@_distributionGeo"
                Colonnes="@_regionsGeo"
                Dimension="@_dimensionAffichage"
                DimensionChanged="OnDimensionChanged" />
        </div>

        <DashboardRepartitionConseillers
            Repartition="@_repartitionConseillers"
            Dimension="@_dimensionAffichage"
            DimensionChanged="OnDimensionChanged" />

    </div>

    <!-- ═══════════════════════════════════════════════════════
         ZONE 4 — VUE DÉTAILLÉE PAR AGENCE
    ═══════════════════════════════════════════════════════ -->
    <div class="dash-section-title">
        <span>Vue détaillée par agence</span>
        <span class="dash-section-hint">@_heatmap.Count @GetHeatmapUnit()</span>
    </div>

    <MudPaper Elevation="0" Class="dash-heatmap">
        @if (!_heatmap.Any())
        {
            <div class="dash-placeholder">Aucune donnée à afficher</div>
        }
        else
        {
            var maxClients = _heatmap.Max(x => x.ClientsGeres);

            <!-- En-tête de colonnes -->
            <div class="dash-hm-header">
                <div class="dash-hm-col-nom">Agence</div>
                <div class="dash-hm-col-volume">Clients gérés</div>
                <div class="dash-hm-col-consei">Cons. existants</div>
                <div class="dash-hm-col-consei">Cons. cibles</div>
                <div class="dash-hm-col-etp">ETP requis</div>
                <div class="dash-hm-col-couv">Taux de couverture</div>
                <div class="dash-hm-col-conc">Taux de concordance</div>
                <div class="dash-hm-col-rot">Taux de rotation</div>
                <div class="dash-hm-col-rot">Taux de pureté</div>
            </div>

            <!-- Lignes agences -->
            @foreach (var row in _heatmap)
            {
                var barWidth = maxClients > 0 ? row.ClientsGeres * 100.0 / maxClients : 0;
                var statusColor = GetStatusColor(row);

                <div class="dash-hm-row">
                    <div class="dash-hm-col-nom">
                        <span class="dash-hm-status-dot" style="background:@statusColor"></span>
                        <span class="dash-hm-nom">@row.Nom</span>
                    </div>

                    <div class="dash-hm-col-volume">
                        <div class="dash-hm-barwrap">
                            <div class="dash-hm-bar" style="width:@(barWidth.ToString("F0"))%"></div>
                        </div>
                        <span class="dash-hm-barval">@FormatCompact(row.ClientsGeres)</span>
                    </div>

                    <div class="dash-hm-col-consei dash-hm-existant">@row.ConseillersActifs</div>
                    <div class="dash-hm-col-consei dash-hm-cible">@row.ConseillersCibles</div>

                    <div class="dash-hm-col-etp">@row.EtpNecessaires.ToString("F1")</div>

                    <div class="dash-hm-col-couv">
                        <span class="dash-hm-pill @GetPillClass(row.TauxCouverture, 100, 90)">
                            @row.TauxCouverture.ToString("F0")%
                        </span>
                    </div>

                    <div class="dash-hm-col-conc">
                        <span class="dash-hm-pill @GetPillClass(row.Concordance, 80, 60)">
                            @row.Concordance.ToString("F0")%
                        </span>
                    </div>

                    <div class="dash-hm-col-rot">
                        <span class="dash-hm-pill @GetPillClassRotation(row.TauxRotation)">
                            @row.TauxRotation.ToString("F0")%
                        </span>
                    </div>
                </div>
            }

            <!-- Ligne TOTAL -->
            
                var totalClientsAg = _heatmap.Sum(r => r.ClientsGeres);
                var totalExistAg = _heatmap.Sum(r => r.ConseillersActifs);
                var totalCibleAg = _heatmap.Sum(r => r.ConseillersCibles);
                var totalEtpAg = _heatmap.Sum(r => r.EtpNecessaires);
                var avgCouv = _heatmap.Any() ? _heatmap.Average(r => r.TauxCouverture) : 0;
                var avgConc = _heatmap.Any() ? _heatmap.Average(r => r.Concordance) : 0;
                var avgRot = _heatmap.Any() ? _heatmap.Average(r => r.TauxRotation) : 0;
            

            <div class="dash-hm-row dash-hm-total-row">
                <div class="dash-hm-col-nom">
                    <span class="dash-hm-total-label">TOTAL</span>
                </div>

                <div class="dash-hm-col-volume">
                    <span class="dash-hm-barval dash-hm-total-val">@FormatCompact(totalClientsAg)</span>
                </div>

                <div class="dash-hm-col-consei dash-hm-existant">@totalExistAg</div>
                <div class="dash-hm-col-consei dash-hm-cible">@totalCibleAg</div>

                <div class="dash-hm-col-etp">@totalEtpAg.ToString("F1")</div>

                <div class="dash-hm-col-couv">
                    <span class="dash-hm-pill @GetPillClass(avgCouv, 100, 90)">
                        @avgCouv.ToString("F0")%
                    </span>
                </div>

                <div class="dash-hm-col-conc">
                    <span class="dash-hm-pill @GetPillClass(avgConc, 80, 60)">
                        @avgConc.ToString("F0")%
                    </span>
                </div>

                <div class="dash-hm-col-rot">
                    <span class="dash-hm-pill @GetPillClassRotation(avgRot)">
                        @avgRot.ToString("F0")%
                    </span>
                </div>
            </div>
        }
    </MudPaper>

    <div class="dash-footer">
        © 2026 CA Nord de France — Pilotage réseau
    </div>
</div>

<style>
    /* ═══════════════════════════════════════════════════════
       Design épuré — pas de bordures, whitespace, typography-driven
    ═══════════════════════════════════════════════════════ */
    .dash-page {
        padding: 24px 32px;
        background: #F5F7FA;
        min-height: 100vh;
        font-family: 'Calibri', sans-serif;
    }

    .dash-loader {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(255,255,255,0.75);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* ── En-tête ────────────────────────────────── */
    .dash-header {
        margin-bottom: 20px;
    }

    .dash-title {
        font-size: 28px;
        font-weight: 700;
        color: #1A4E6B;
        letter-spacing: -0.3px;
    }

    .dash-subtitle {
        font-size: 13px;
        color: #6C7A89;
        margin-top: 2px;
    }

    /* ── Filtres ────────────────────────────────── */
    .dash-filters {
        background: white;
        border-radius: 10px;
        padding: 14px 18px;
        margin-bottom: 24px;
    }

    .dash-filters-inner {
        display: flex;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
    }

    .dash-filter-label {
        font-size: 10px;
        font-weight: 700;
        color: #8A97A8;
        letter-spacing: 2px;
    }

    /* ── KPI Grid — 6 colonnes ────────────────────── */
    .dash-kpi-grid {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 16px;
        margin-bottom: 28px;
    }

    .dash-kpi-card {
        background: white;
        border-radius: 12px;
        padding: 22px 24px;
        transition: transform 0.15s ease;
    }

        .dash-kpi-card:hover {
            transform: translateY(-2px);
        }

    .dash-kpi-label {
        font-size: 11px;
        font-weight: 600;
        color: #8A97A8;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .dash-kpi-value {
        font-size: 42px;
        font-weight: 700;
        line-height: 1;
        letter-spacing: -1px;
    }

    .dash-kpi-unit {
        font-size: 20px;
        font-weight: 500;
        color: #B0BAC5;
        margin-left: 2px;
    }

    .dash-kpi-hint {
        font-size: 11px;
        color: #A0AAB8;
        margin-top: 10px;
        font-style: italic;
    }

    .dash-kpi-good     { color: #1B5E20; }
    .dash-kpi-warn     { color: #E65100; }
    .dash-kpi-critical { color: #C62828; }
    .dash-kpi-neutral  { color: #1A4E6B; }

    /* ── KPI en 2 colonnes verticales (Existant | Cible) ── */
    .dash-kpi-cols {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-top: 4px;
    }

    .dash-kpi-col {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }

    .dash-kpi-col-value {
        font-size: 32px;
        font-weight: 700;
        line-height: 1;
        letter-spacing: -0.5px;
    }

    .dash-kpi-col-label {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        margin-top: 6px;
    }

    .dash-kpi-line-existant .dash-kpi-col-value,
    .dash-kpi-line-existant .dash-kpi-col-label {
        color: #E65100;
    }

    .dash-kpi-line-cible .dash-kpi-col-value,
    .dash-kpi-line-cible .dash-kpi-col-label {
        color: #1A4E6B;
    }

    .dash-kpi-delta {
        margin-top: 10px;
        font-size: 12px;
        font-weight: 700;
        text-align: center;
    }

    .dash-delta-good     { color: #1B5E20; }
    .dash-delta-critical { color: #C62828; }

    /* ── Sections ────────────────────────────────── */
    .dash-section-title {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: 12px;
        margin-top: 8px;
    }

    .dash-section-title span:first-child {
        font-size: 15px;
        font-weight: 700;
        color: #1A4E6B;
    }

    .dash-section-hint {
        font-size: 11px;
        color: #8A97A8;
        font-style: italic;
    }

    /* ═══════════════════════════════════════════════════════
       HEATMAP AGENCES — 8 colonnes
    ═══════════════════════════════════════════════════════ */
    .dash-heatmap {
        padding: 0;
        overflow: hidden;
        margin-bottom: 24px;
    }

    .dash-hm-header,
    .dash-hm-row {
        display: grid;
        grid-template-columns: 2fr 2fr 1fr 1fr 1fr 1fr 1fr 1fr;
        align-items: center;
        padding: 9px 24px;
        gap: 16px;
    }

    .dash-hm-header {
        font-size: 10px;
        font-weight: 700;
        color: #8A97A8;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        border-bottom: 1px solid #EEF1F5;
        background: #FAFBFC;
    }

    .dash-hm-row {
        font-size: 13px;
        color: #2C3E50;
        border-bottom: 1px solid #F5F7FA;
        transition: background 0.12s ease;
    }

        .dash-hm-row:last-child {
            border-bottom: none;
        }

        .dash-hm-row:hover {
            background: #FAFBFC;
        }

    .dash-hm-col-nom {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 600;
        color: #1A4E6B;
    }

    .dash-hm-status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .dash-hm-nom {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .dash-hm-col-volume {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .dash-hm-barwrap {
        flex: 1;
        height: 6px;
        background: #EEF3F7;
        border-radius: 3px;
        overflow: hidden;
        max-width: 140px;
    }

    .dash-hm-bar {
        height: 100%;
        background: linear-gradient(90deg, #4A80B5 0%, #1A4E6B 100%);
        border-radius: 3px;
        transition: width 0.3s ease;
    }

    .dash-hm-barval {
        font-size: 12px;
        color: #6C7A89;
        font-weight: 600;
        min-width: 40px;
        text-align: right;
    }

    .dash-hm-col-consei,
    .dash-hm-col-etp {
        text-align: center;
        font-weight: 600;
        color: #1A4E6B;
    }

    .dash-hm-existant {
        color: #E65100 !important;
        font-weight: 700;
    }

    .dash-hm-cible {
        color: #1A4E6B !important;
        font-weight: 700;
    }

    .dash-hm-col-couv,
    .dash-hm-col-conc,
    .dash-hm-col-rot {
        text-align: center;
    }

    .dash-hm-pill {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 700;
        min-width: 42px;
        text-align: center;
    }

    .dash-hm-pill-good     { background: #E8F5E9; color: #1B5E20; }
    .dash-hm-pill-warn     { background: #FFF3E0; color: #E65100; }
    .dash-hm-pill-critical { background: #FFEBEE; color: #C62828; }

    /* ── Ligne TOTAL heatmap ── */
    .dash-hm-total-row {
        background: #DFE7F0 !important;
        border-top: 2px solid #1A4E6B !important;
        border-bottom: none !important;
    }

    .dash-hm-total-row:hover {
        background: #D5DEE8 !important;
    }

    .dash-hm-total-label {
        color: #1A4E6B;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        font-size: 12px;
    }

    .dash-hm-total-val {
        color: #1A4E6B !important;
        font-weight: 700 !important;
        font-size: 14px !important;
    }

    .dash-hm-total-row .dash-hm-col-etp {
        font-size: 14px;
    }

    /* ═══════════════════════════════════════════════════════
       Grille 2 colonnes (Répartitions + Distribution)
    ═══════════════════════════════════════════════════════ */
    .dash-bottom-grid {
        display: grid;
        grid-template-columns: 3fr 2fr;
        gap: 16px;
        margin-bottom: 24px;
        align-items: start;
    }

    .dash-bottom-left {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .dash-placeholder {
        color: #B0BAC5;
        text-align: center;
        padding: 40px;
        font-style: italic;
        font-size: 13px;
    }

    .dash-footer {
        text-align: center;
        color: #A0AAB8;
        font-size: 11px;
        padding: 20px 0 10px;
    }
</style>

@code {

    // ── État ────────────────────────────────────────
    private bool _isLoading = false;
    private DashboardKpis _kpis = new();
    private List<TerritoireRow> _heatmap = new();
    private List<SegmentationDistributiveData> _data = new();
    private List<SegmentationDistributiveData> _dataFiltree = new();
    private List<SegmentRepartition> _repartition = new();
    private List<LigneMetierRepartition> _repartitionConseillers = new();

    // ── Distribution géographique ───────────────────
    private Dictionary<string, Dictionary<string, int>> _distributionGeo = new();
    private List<string> _regionsGeo = new();

    // ── Dimension d'affichage partagée par les 3 blocs du bas ──
    private string _dimensionAffichage = "Region";

    // ── Filtres ────────────────────────────────────
    private string? filtreRegion, filtreSecteur, filtreAgence;
    private string? filtreRegionApplique, filtreSecteurApplique, filtreAgenceApplique;

    private List<string> allRegions = new();
    private List<string> allSecteurs = new();
    private List<string> allAgences = new();

    private bool HasPendingFilterChanges =>
        filtreRegion  != filtreRegionApplique ||
        filtreSecteur != filtreSecteurApplique ||
        filtreAgence  != filtreAgenceApplique;

    // ── Lifecycle ──────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        try
        {
            _data = await Http.GetFromJsonAsync<List<SegmentationDistributiveData>>(
                "api/SegmentationDistributive") ?? new();

            _dataFiltree = _data.ToList();

            BuildFilterOptions();
            RecomputeAll();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur Dashboard : {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ── Recalcul global ────────────────────────────
    private void RecomputeAll()
    {
        _kpis = DashboardService.ComputeGlobalKpis(_dataFiltree, StateService.Regles);

        _heatmap = DashboardService.ComputeHeatmapAgences(
            _dataFiltree, StateService.Regles);

        _repartition = DashboardService.ComputeRepartitionParSegment(_dataFiltree);

        _repartitionConseillers = DashboardService.ComputeRepartitionConseillers(
            _dataFiltree, StateService.Regles);

        var geoResult = DashboardService.ComputeDistributionGeographique(
            _dataFiltree, _dimensionAffichage);
        _distributionGeo = geoResult.Distribution;
        _regionsGeo = geoResult.Colonnes;
    }

    // ── Changement de dimension pour la distribution géo ──
    private void OnDimensionChanged(string dim)
    {
        _dimensionAffichage = dim;

        var geoResult = DashboardService.ComputeDistributionGeographique(
            _dataFiltree, _dimensionAffichage);
        _distributionGeo = geoResult.Distribution;
        _regionsGeo = geoResult.Colonnes;

        StateHasChanged();
    }

    // ── Handlers de filtres ────────────────────────
    private void OnRegionChanged(string? r)
    {
        filtreRegion = r;
        filtreSecteur = null;
        filtreAgence = null;
        BuildFilterOptions();
    }

    private void OnSecteurChanged(string? s)
    {
        filtreSecteur = s;
        filtreAgence = null;
        BuildFilterOptions();
    }

    private void OnAgenceChanged(string? a)
    {
        filtreAgence = a;
    }

    private async Task ApplyFilters()
    {
        _isLoading = true;
        StateHasChanged();
        await Task.Delay(1);

        try
        {
            _dataFiltree = _data
                .Where(x => string.IsNullOrEmpty(filtreRegion)  || x.LibRegion  == filtreRegion)
                .Where(x => string.IsNullOrEmpty(filtreSecteur) || x.LibSecteur == filtreSecteur)
                .Where(x => string.IsNullOrEmpty(filtreAgence)  || x.LibAgence  == filtreAgence)
                .ToList();

            filtreRegionApplique  = filtreRegion;
            filtreSecteurApplique = filtreSecteur;
            filtreAgenceApplique  = filtreAgence;

            BuildFilterOptions();
            RecomputeAll();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ClearFilters()
    {
        filtreRegion = filtreSecteur = filtreAgence = null;
        await ApplyFilters();
    }

    private void BuildFilterOptions()
    {
        allRegions = _data.Select(x => x.LibRegion)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(x => x).ToList();

        allSecteurs = _data
            .Where(x => string.IsNullOrEmpty(filtreRegion) || x.LibRegion == filtreRegion)
            .Select(x => x.LibSecteur)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(x => x).ToList();

        allAgences = _data
            .Where(x => string.IsNullOrEmpty(filtreRegion)  || x.LibRegion  == filtreRegion)
            .Where(x => string.IsNullOrEmpty(filtreSecteur) || x.LibSecteur == filtreSecteur)
            .Select(x => x.LibAgence)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(x => x).ToList();
    }

    // ── Helpers UI KPIs ────────────────────────────
    private string GetKpiClass(double value, double greenThreshold, double orangeThreshold)
    {
        if (value >= greenThreshold)  return "dash-kpi-good";
        if (value >= orangeThreshold) return "dash-kpi-warn";
        return "dash-kpi-critical";
    }

    private string FormatCompact(int value)
    {
        if (value >= 1_000_000) return $"{value / 1_000_000.0:F1}M";
        if (value >= 1_000)     return $"{value / 1_000.0:F0}K";
        return value.ToString("N0");
    }

    // ── Helpers heatmap agences ────────────────────
    private string GetHeatmapUnit() =>
        _heatmap.Count > 1 ? "agences" : "agence";

    private string GetPillClass(double value, double greenThreshold, double orangeThreshold)
    {
        if (value >= greenThreshold)  return "dash-hm-pill-good";
        if (value >= orangeThreshold) return "dash-hm-pill-warn";
        return "dash-hm-pill-critical";
    }

    /// <summary>
    /// Code couleur du taux de rotation : logique inversée (bas = bon).
    /// ≤10% vert · ≤20% orange · >20% rouge
    /// </summary>
    private string GetPillClassRotation(double value)
    {
        if (value <= 10) return "dash-hm-pill-good";
        if (value <= 20) return "dash-hm-pill-warn";
        return "dash-hm-pill-critical";
    }

    private string GetStatusColor(TerritoireRow row)
    {
        if (row.Concordance >= 80 && row.TauxCouverture >= 100) return "#1B5E20";
        if (row.Concordance >= 60 && row.TauxCouverture >= 90)  return "#E65100";
        return "#C62828";
    }
}
