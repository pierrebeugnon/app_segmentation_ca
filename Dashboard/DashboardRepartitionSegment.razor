@using Segmentation.Client.Services

<MudPaper Elevation="0" Class="dash-repartition">

    <div class="dash-section-title">
        <span>Volume clients par segment distributif</span>
        <span class="dash-section-hint">Par ligne métier</span>
    </div>

    <div class="dash-dim-tags">
        <button class="dash-dim-tag @(Dimension == "Region" ? "active" : "")"
                @onclick="@(() => Switch("Region"))">
            Région
        </button>
        <button class="dash-dim-tag @(Dimension == "Secteur" ? "active" : "")"
                @onclick="@(() => Switch("Secteur"))">
            Secteur
        </button>
        <button class="dash-dim-tag @(Dimension == "Agence" ? "active" : "")"
                @onclick="@(() => Switch("Agence"))">
            Agence
        </button>
    </div>

    @if (Repartition == null || !Repartition.Any())
    {
        <div class="dash-placeholder">Aucune donnée disponible</div>
    }
    else
    {
        var maxRep = Repartition.Max(x => x.NbClients);

        <div class="dash-rep-list">

            <!-- En-tête -->
            <div class="dash-rep-header">
                <div>Segment</div>
                <div>Volume</div>
                <div>Clients</div>
                <div>Poids</div>
                <div>ETP</div>
                <div>Cons.</div>
            </div>

            <!-- Lignes segments -->
            @foreach (var seg in Repartition)
            {
                var barWidth = maxRep > 0 ? seg.NbClients * 100.0 / maxRep : 0;
                var segColor = GetSegmentColor(seg.Segment);

                <div class="dash-rep-row">
                    <div class="dash-rep-label">@seg.Segment</div>
                    <div class="dash-rep-barwrap">
                        <div class="dash-rep-bar"
                             style="width:@(barWidth.ToString("F0"))%;background:@segColor">
                        </div>
                    </div>
                    <div class="dash-rep-val">@FormatCompact(seg.NbClients)</div>
                    <div class="dash-rep-pct">@seg.Pourcentage.ToString("F0")%</div>
                    <div class="dash-rep-etp">@seg.ChargeEtp.ToString("F1")</div>
                    <div class="dash-rep-cons">@seg.ConseillersConcernes</div>
                </div>
            }

            <!-- Ligne TOTAL -->
            @{
                var totalClients = Repartition.Sum(s => s.NbClients);
                var totalEtp = Repartition.Sum(s => s.ChargeEtp);
                var totalCons = Repartition.Sum(s => s.ConseillersConcernes);
            }

            <div class="dash-rep-row dash-rep-total">
                <div class="dash-rep-label">Total</div>
                <div></div>
                <div class="dash-rep-val">@FormatCompact(totalClients)</div>
                <div class="dash-rep-pct">100%</div>
                <div class="dash-rep-etp">@totalEtp.ToString("F1")</div>
                <div class="dash-rep-cons">@totalCons</div>
            </div>
        </div>
    }
</MudPaper>

<style>
    .dash-repartition {
        background: white;
        border-radius: 12px;
        padding: 20px 24px;
        min-height: 300px;
    }

    .dash-repartition .dash-section-title {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: 16px;
    }

    .dash-repartition .dash-section-title span:first-child {
        font-size: 15px;
        font-weight: 700;
        color: #1A4E6B;
    }

    .dash-repartition .dash-section-hint {
        font-size: 11px;
        color: #8A97A8;
        font-style: italic;
    }

    .dash-rep-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    /* ── Tag switcher ── */
    .dash-dim-tags {
        display: flex;
        gap: 6px;
        margin-bottom: 12px;
    }

    .dash-dim-tag {
        background: #F0F3F7;
        color: #6C7A89;
        border: none;
        padding: 4px 12px;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.6px;
        text-transform: uppercase;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.15s ease;
    }

    .dash-dim-tag:hover {
        background: #E1E7EF;
    }

    .dash-dim-tag.active {
        background: #1A4E6B;
        color: white;
    }

    .dash-rep-header,
    .dash-rep-row {
        display: grid;
        grid-template-columns: 150px 1fr 60px 45px 55px 45px;
        align-items: center;
        gap: 10px;
    }

    .dash-rep-header {
        font-size: 10px;
        font-weight: 700;
        color: #8A97A8;
        letter-spacing: 1px;
        text-transform: uppercase;
        padding-bottom: 6px;
        border-bottom: 1px solid #EEF1F5;
    }

    .dash-rep-header div:nth-child(3),
    .dash-rep-header div:nth-child(4),
    .dash-rep-header div:nth-child(5),
    .dash-rep-header div:nth-child(6) {
        text-align: right;
    }

    .dash-rep-label {
        font-size: 12px;
        font-weight: 600;
        color: #2C3E50;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .dash-rep-barwrap {
        height: 14px;
        background: #F0F3F7;
        border-radius: 3px;
        overflow: hidden;
    }

    .dash-rep-bar {
        height: 100%;
        border-radius: 3px;
        transition: width 0.4s ease;
    }

    .dash-rep-val,
    .dash-rep-pct,
    .dash-rep-etp,
    .dash-rep-cons {
        text-align: right;
        font-size: 12px;
        font-weight: 700;
    }

    .dash-rep-val  { color: #1A4E6B; }
    .dash-rep-pct  { color: #8A97A8; }
    .dash-rep-etp  { color: #E65100; }
    .dash-rep-cons { color: #1A4E6B; }

    /* ── Ligne TOTAL ── */
    .dash-rep-total {
        border-top: 2px solid #1A4E6B;
        background: #F7FBFE;
        border-radius: 4px;
        padding: 8px 6px;
        margin-top: 4px;
    }

    .dash-rep-total .dash-rep-label {
        font-weight: 700;
        color: #1A4E6B;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 11px;
    }

    .dash-rep-total .dash-rep-val,
    .dash-rep-total .dash-rep-pct,
    .dash-rep-total .dash-rep-etp,
    .dash-rep-total .dash-rep-cons {
        font-size: 13px;
        font-weight: 700;
    }

    .dash-repartition .dash-placeholder {
        color: #B0BAC5;
        text-align: center;
        padding: 40px;
        font-style: italic;
        font-size: 13px;
    }
</style>

@code {
    [Parameter]
    public List<SegmentRepartition>? Repartition { get; set; }

    [Parameter] public string Dimension { get; set; } = "Region";
    [Parameter] public EventCallback<string> DimensionChanged { get; set; }

    private async Task Switch(string dim)
    {
        if (dim == Dimension) return;
        Dimension = dim;
        await DimensionChanged.InvokeAsync(dim);
    }

    private string GetSegmentColor(string segment)
    {
        if (segment.Contains("Premium", StringComparison.OrdinalIgnoreCase))
            return "#0A2540";
        if (segment.StartsWith("HDG", StringComparison.OrdinalIgnoreCase))
            return "#1A4E6B";
        if (segment.StartsWith("CI", StringComparison.OrdinalIgnoreCase))
            return "#4A80B5";
        if (segment.StartsWith("GP", StringComparison.OrdinalIgnoreCase))
            return "#5CA6D9";
        return "#B0BAC5";
    }

    private string FormatCompact(int value)
    {
        if (value >= 1_000_000) return $"{value / 1_000_000.0:F1}M";
        if (value >= 1_000)     return $"{value / 1_000.0:F0}K";
        return value.ToString("N0");
    }
}
