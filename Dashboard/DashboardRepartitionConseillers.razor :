@using Segmentation.Client.Services

<MudPaper Elevation="0" Class="dash-rc-card">

    <div class="dash-section-title">
        <span>Répartition des conseillers × Taille théorique des portefeuilles</span>
        <span class="dash-section-hint">Par ligne métier</span>
    </div>

    @if (Repartition == null || !Repartition.Any())
    {
        <div class="dash-placeholder">Aucune donnée disponible</div>
    }
    else
    {
        <div class="dash-rc-tablewrap">
            <table class="dash-rc-table">
                <thead>

                    <!-- Ligne 1 : groupes -->
                    <tr class="dash-rc-header-group">
                        <th class="dash-rc-col-metier">&nbsp;</th>
                        <th colspan="3" class="dash-rc-group-conseillers">
                            Nombre de conseillers
                        </th>
                        <th colspan="3" class="dash-rc-group-taille">
                            Taille théorique du portefeuille
                        </th>
                    </tr>

                    <!-- Ligne 2 : colonnes détaillées -->
                    <tr class="dash-rc-header-cols">
                        <th class="dash-rc-col-metier">Ligne métier</th>

                        <th class="dash-rc-col-existant">Existant</th>
                        <th class="dash-rc-col-cible">Cible</th>
                        <th class="dash-rc-col-delta">Δ</th>

                        <th class="dash-rc-col-existant dash-rc-taille">Existant</th>
                        <th class="dash-rc-col-cible dash-rc-taille">Cible</th>
                        <th class="dash-rc-col-delta dash-rc-taille">Δ</th>
                    </tr>

                </thead>
                <tbody>
                    @foreach (var l in Repartition)
                    {
                        var deltaConsClass = GetDeltaClass(l.DeltaConseillers);
                        var deltaTailleClass = GetDeltaClass(l.DeltaTaillePortefeuille);

                        <tr>
                            <td class="dash-rc-col-metier dash-rc-metier-label">
                                @l.LigneMetier
                            </td>

                            <!-- Conseillers -->
                            <td class="dash-rc-val-existant">@l.ConseillersExistants</td>
                            <td class="dash-rc-val-cible">@l.ConseillersCibles</td>
                            <td class="@deltaConsClass">
                                @FormatDelta(l.DeltaConseillers)
                            </td>

                            <!-- Taille portefeuille (fond bleu clair) -->
                            <td class="dash-rc-val-existant dash-rc-taille">
                                @l.TaillePortefeuilleExistant.ToString("N0")
                            </td>
                            <td class="dash-rc-val-cible dash-rc-taille">
                                @l.TaillePortefeuilleCible.ToString("N0")
                            </td>
                            <td class="dash-rc-taille @deltaTailleClass">
                                @FormatDelta(l.DeltaTaillePortefeuille, "N0")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</MudPaper>

<style>
    .dash-rc-card {
        background: white;
        border-radius: 12px;
        padding: 20px 24px;
        min-height: 300px;
    }

    .dash-rc-card .dash-section-title {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: 16px;
    }

    .dash-rc-card .dash-section-title span:first-child {
        font-size: 15px;
        font-weight: 700;
        color: #1A4E6B;
    }

    .dash-rc-card .dash-section-hint {
        font-size: 11px;
        color: #8A97A8;
        font-style: italic;
    }

    /* Tableau */
    .dash-rc-tablewrap {
        overflow-x: auto;
    }

    .dash-rc-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'Calibri', sans-serif;
    }

    /* En-tête ligne 1 : groupes */
    .dash-rc-header-group th {
        font-size: 10px;
        font-weight: 700;
        color: #8A97A8;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        padding: 8px 6px;
        text-align: center;
    }

    .dash-rc-group-conseillers {
        border-bottom: 2px solid #E1E7EF;
    }

    .dash-rc-group-taille {
        background: #EBF3FB;
        border-bottom: 2px solid #B9D2E8;
        border-radius: 6px 6px 0 0;
    }

    /* En-tête ligne 2 : colonnes */
    .dash-rc-header-cols th {
        font-size: 10px;
        font-weight: 700;
        color: #6C7A89;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        padding: 8px 6px;
        text-align: center;
        border-bottom: 1px solid #EEF1F5;
    }

    .dash-rc-header-cols .dash-rc-col-metier {
        text-align: left;
        color: #8A97A8;
    }

    /* Colonnes détail conseillers */
    .dash-rc-col-existant { color: #E65100; }
    .dash-rc-col-cible    { color: #1A4E6B; }
    .dash-rc-col-delta    { color: #6C7A89; }

    /* Cellules taille — background bleu léger */
    .dash-rc-taille {
        background: #EBF3FB;
    }

    /* Lignes de données */
    .dash-rc-table tbody tr {
        border-bottom: 1px solid #F5F7FA;
        transition: background 0.12s ease;
    }

    .dash-rc-table tbody tr:last-child {
        border-bottom: none;
    }

    .dash-rc-table tbody tr:hover {
        background: #FAFBFC;
    }

    .dash-rc-table tbody tr:hover .dash-rc-taille {
        background: #DFEBF7;
    }

    .dash-rc-table tbody td {
        padding: 14px 6px;
        text-align: center;
        font-size: 15px;
        font-weight: 700;
    }

    .dash-rc-metier-label {
        text-align: left !important;
        color: #1A4E6B;
        padding-left: 8px !important;
        font-size: 13px !important;
        font-weight: 700;
    }

    .dash-rc-val-existant { color: #E65100; }
    .dash-rc-val-cible    { color: #1A4E6B; }

    .dash-delta-good     { color: #1B5E20; }
    .dash-delta-critical { color: #C62828; }
    .dash-delta-neutral  { color: #6C7A89; }

    .dash-rc-card .dash-placeholder {
        color: #B0BAC5;
        text-align: center;
        padding: 40px;
        font-style: italic;
        font-size: 13px;
    }
</style>

@code {
    /// <summary>
    /// Répartition par ligne métier (BP / Retail) :
    /// nombre de conseillers existant vs cible + taille théorique portefeuille.
    /// </summary>
    [Parameter]
    public List<LigneMetierRepartition>? Repartition { get; set; }

    private string GetDeltaClass(int delta)
    {
        if (delta > 0)  return "dash-delta-good";
        if (delta < 0)  return "dash-delta-critical";
        return "dash-delta-neutral";
    }

    private string GetDeltaClass(double delta)
    {
        if (delta > 0)  return "dash-delta-good";
        if (delta < 0)  return "dash-delta-critical";
        return "dash-delta-neutral";
    }

    private string FormatDelta(int delta)
    {
        if (delta == 0) return "0";
        return delta > 0 ? $"+{delta}" : delta.ToString();
    }

    private string FormatDelta(double delta, string format = "N0")
    {
        if (delta == 0) return "0";
        var v = delta.ToString(format);
        return delta > 0 ? $"+{v}" : v;
    }
}
