@using Segmentation.Client.Services

<MudPaper Elevation="0" Class="dash-rc-card">

    <div class="dash-section-title">
        <span>Répartition des conseillers × Taille théorique des portefeuilles</span>
        <span class="dash-section-hint">Par ligne métier</span>
    </div>

    @if (Repartition == null || !Repartition.Any())
    {
        <div class="dash-placeholder">Aucune donnée disponible</div>
    }
    else
    {
        <div class="dash-rc-tablewrap">
            <table class="dash-rc-table">
                <thead>

                    <!-- Ligne 1 : groupes -->
                    <tr class="dash-rc-header-group">
                        <th class="dash-rc-col-metier">&nbsp;</th>
                        <th colspan="3" class="dash-rc-group-conseillers">
                            Nombre de conseillers
                        </th>
                        <th colspan="3" class="dash-rc-group-taille">
                            Taille théorique du portefeuille
                        </th>
                    </tr>

                    <!-- Ligne 2 : colonnes détaillées -->
                    <tr class="dash-rc-header-cols">
                        <th class="dash-rc-col-metier">Ligne métier / Profil</th>

                        <th class="dash-rc-col-existant">Existant</th>
                        <th class="dash-rc-col-cible">Cible</th>
                        <th class="dash-rc-col-delta">Δ</th>

                        <th class="dash-rc-col-existant dash-rc-taille">Existant</th>
                        <th class="dash-rc-col-cible dash-rc-taille">Cible</th>
                        <th class="dash-rc-col-delta dash-rc-taille">Δ</th>
                    </tr>

                </thead>
                <tbody>
                    @foreach (var l in Repartition)
                    {
                        var deltaConsClass = GetDeltaClass(l.DeltaConseillers);
                        var deltaTailleClass = GetDeltaClass(l.DeltaTaillePortefeuille);

                        <!-- Row en-tête LIGNE MÉTIER : agrégé, majuscule, graisse fine, background -->
                        <tr class="dash-rc-lm-row">
                            <td class="dash-rc-col-metier dash-rc-lm-label">
                                @l.LigneMetier.ToUpper()
                            </td>

                            <td class="dash-rc-val-existant">@l.ConseillersExistants</td>
                            <td class="dash-rc-val-cible">@l.ConseillersCibles</td>
                            <td class="@deltaConsClass">@FormatDelta(l.DeltaConseillers)</td>

                            <td class="dash-rc-val-existant dash-rc-taille">
                                @l.TaillePortefeuilleExistant.ToString("N0")
                            </td>
                            <td class="dash-rc-val-cible dash-rc-taille">
                                @l.TaillePortefeuilleCible.ToString("N0")
                            </td>
                            <td class="dash-rc-taille @deltaTailleClass">
                                @FormatDelta(l.DeltaTaillePortefeuille, "N0")
                            </td>
                        </tr>

                        <!-- Rows détail par profil -->
                        @foreach (var p in l.Profils)
                        {
                            var deltaProfilClass = GetDeltaClass(p.DeltaConseillers);

                            <tr class="dash-rc-profil-row">
                                <td class="dash-rc-col-metier dash-rc-profil-label">
                                    @p.Profil
                                </td>

                                <td class="dash-rc-val-existant dash-rc-profil-val">@p.ConseillersExistants</td>
                                <td class="dash-rc-val-cible dash-rc-profil-val">@p.ConseillersCibles</td>
                                <td class="dash-rc-profil-val @deltaProfilClass">
                                    @FormatDelta(p.DeltaConseillers)
                                </td>

                                <!-- Colonnes taille : non applicable au niveau profil -->
                                <td class="dash-rc-taille dash-rc-empty">—</td>
                                <td class="dash-rc-taille dash-rc-empty">—</td>
                                <td class="dash-rc-taille dash-rc-empty">—</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }

</MudPaper>

<style>
    .dash-rc-card {
        background: white;
        border-radius: 12px;
        padding: 20px 24px;
        min-height: 300px;
    }

    .dash-rc-card .dash-section-title {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: 16px;
    }

    .dash-rc-card .dash-section-title span:first-child {
        font-size: 15px;
        font-weight: 700;
        color: #1A4E6B;
    }

    .dash-rc-card .dash-section-hint {
        font-size: 11px;
        color: #8A97A8;
        font-style: italic;
    }

    /* Tableau */
    .dash-rc-tablewrap {
        overflow-x: auto;
    }

    .dash-rc-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'Calibri', sans-serif;
    }

    /* En-tête ligne 1 : groupes */
    .dash-rc-header-group th {
        font-size: 10px;
        font-weight: 700;
        color: #8A97A8;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        padding: 8px 6px;
        text-align: center;
    }

    .dash-rc-group-conseillers {
        border-bottom: 2px solid #E1E7EF;
    }

    /* Bleu très léger sur le groupe taille */
    .dash-rc-group-taille {
        background: #F4F9FD;
        border-bottom: 2px solid #D4E4F0;
        border-radius: 6px 6px 0 0;
    }

    /* En-tête ligne 2 : colonnes */
    .dash-rc-header-cols th {
        font-size: 10px;
        font-weight: 700;
        color: #6C7A89;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        padding: 8px 6px;
        text-align: center;
        border-bottom: 1px solid #EEF1F5;
    }

    .dash-rc-header-cols .dash-rc-col-metier {
        text-align: left;
        color: #8A97A8;
    }

    /* Couleurs charte Portefeuille */
    .dash-rc-col-existant { color: #E65100; }
    .dash-rc-col-cible    { color: #1A4E6B; }
    .dash-rc-col-delta    { color: #6C7A89; }

    /* Colonnes taille — bleu très léger */
    .dash-rc-taille {
        background: #F7FBFE;
    }

    /* ═══════════════════════════════════════════════
       Row en-tête LIGNE MÉTIER — uppercase, thin, background
    ═══════════════════════════════════════════════ */
    .dash-rc-lm-row {
        background: #EEF1F5;
        border-top: 1px solid #DAE0E7;
        border-bottom: 1px solid #DAE0E7;
    }

    .dash-rc-lm-row:hover {
        background: #E5E9EF;
    }

    /* Fond taille légèrement plus soutenu sur la row LM */
    .dash-rc-lm-row .dash-rc-taille {
        background: #EAF2FA;
    }

    .dash-rc-lm-row:hover .dash-rc-taille {
        background: #E0EBF5;
    }

    .dash-rc-lm-label {
        font-size: 12px !important;
        font-weight: 400 !important;          /* thin */
        letter-spacing: 2px;
        color: #1A4E6B;
        text-transform: uppercase;
    }

    .dash-rc-lm-row td {
        padding: 12px 6px;
        text-align: center;
        font-size: 15px;
        font-weight: 700;
    }

    .dash-rc-lm-row .dash-rc-col-metier {
        text-align: left;
        padding-left: 10px;
    }

    /* ═══════════════════════════════════════════════
       Row détail PROFIL
    ═══════════════════════════════════════════════ */
    .dash-rc-profil-row {
        background: white;
    }

    .dash-rc-profil-row:hover {
        background: #FAFBFC;
    }

    .dash-rc-profil-row .dash-rc-taille {
        background: #F7FBFE;
    }

    .dash-rc-profil-row:hover .dash-rc-taille {
        background: #EDF4FA;
    }

    .dash-rc-profil-row td {
        padding: 8px 6px;
        text-align: center;
        font-size: 12px;
    }

    .dash-rc-profil-label {
        text-align: left !important;
        padding-left: 26px !important;
        color: #4A5568;
        font-size: 12px;
        font-weight: 500;
    }

    .dash-rc-profil-val {
        font-weight: 600;
    }

    .dash-rc-empty {
        color: #C5CBD3 !important;
        font-weight: 400 !important;
        font-style: italic;
    }

    /* ═══════════════════════════════════════════════
       Delta colors
    ═══════════════════════════════════════════════ */
    .dash-delta-good     { color: #1B5E20; }
    .dash-delta-critical { color: #C62828; }
    .dash-delta-neutral  { color: #6C7A89; }

    .dash-rc-card .dash-placeholder {
        color: #B0BAC5;
        text-align: center;
        padding: 40px;
        font-style: italic;
        font-size: 13px;
    }
</style>

@code {
    /// <summary>
    /// Répartition par ligne métier (BP / Retail) avec détail par type de conseiller.
    /// </summary>
    [Parameter]
    public List<LigneMetierRepartition>? Repartition { get; set; }

    private string GetDeltaClass(int delta)
    {
        if (delta > 0)  return "dash-delta-good";
        if (delta < 0)  return "dash-delta-critical";
        return "dash-delta-neutral";
    }

    private string GetDeltaClass(double delta)
    {
        if (delta > 0)  return "dash-delta-good";
        if (delta < 0)  return "dash-delta-critical";
        return "dash-delta-neutral";
    }

    private string FormatDelta(int delta)
    {
        if (delta == 0) return "0";
        return delta > 0 ? $"+{delta}" : delta.ToString();
    }

    private string FormatDelta(double delta, string format = "N0")
    {
        if (delta == 0) return "0";
        var v = delta.ToString(format);
        return delta > 0 ? $"+{v}" : v;
    }
}
