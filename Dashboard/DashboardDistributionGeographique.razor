@using Segmentation.Client.Services

<MudPaper Elevation="0" Class="dash-dg-card">

    <div class="dash-section-title">
        <span>Distribution géographique par segment</span>
        <span class="dash-section-hint">Vue par @LabelDim() — @Colonnes.Count colonnes</span>
    </div>

    <!-- ── Tag switcher ── -->
    <div class="dash-dim-tags">
        <button class="dash-dim-tag @(Dimension == "Region" ? "active" : "")"
                @onclick="@(() => Switch("Region"))">Région</button>
        <button class="dash-dim-tag @(Dimension == "Secteur" ? "active" : "")"
                @onclick="@(() => Switch("Secteur"))">Secteur</button>
        <button class="dash-dim-tag @(Dimension == "Agence" ? "active" : "")"
                @onclick="@(() => Switch("Agence"))">Agence</button>
    </div>

    @if (Distribution == null || !Distribution.Any() || !Colonnes.Any())
    {
        <div class="dash-placeholder">Aucune donnée disponible</div>
    }
    else
    {
        <div class="dash-dg-tablewrap">
            <table class="dash-dg-table">
                <thead>
                    <tr>
                        <th class="dash-dg-col-segment">Segment</th>
                        @foreach (var c in Colonnes)
                        {
                            <th class="dash-dg-col-region" title="@c">@Abrege(c)</th>
                        }
                        <th class="dash-dg-col-total">Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Distribution)
                    {
                        var total = row.Value.Values.Sum();
                        var maxVal = row.Value.Values.DefaultIfEmpty(0).Max();

                        <tr>
                            <td class="dash-dg-col-segment dash-dg-seg-label">@row.Key</td>
                            @foreach (var c in Colonnes)
                            {
                                var val = row.Value.GetValueOrDefault(c, 0);
                                var intensity = maxVal > 0 ? val * 100.0 / maxVal : 0;
                                <td class="dash-dg-cell" style="@GetCellStyle(intensity)">
                                    @(val > 0 ? FormatCompact(val) : "—")
                                </td>
                            }
                            <td class="dash-dg-col-total">@FormatCompact(total)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</MudPaper>

<style>
    .dash-dg-card {
        background: white;
        border-radius: 12px;
        padding: 14px 18px;
    }

    .dash-dg-card .dash-section-title {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: 10px;
    }

    .dash-dg-card .dash-section-title span:first-child {
        font-size: 15px;
        font-weight: 700;
        color: #1A4E6B;
    }

    .dash-dg-card .dash-section-hint {
        font-size: 11px;
        color: #8A97A8;
        font-style: italic;
    }

    /* ── Tag switcher ── */
    .dash-dim-tags {
        display: flex;
        gap: 6px;
        margin-bottom: 12px;
    }

    .dash-dim-tag {
        background: #F0F3F7;
        color: #6C7A89;
        border: none;
        padding: 4px 12px;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.6px;
        text-transform: uppercase;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.15s ease;
    }

    .dash-dim-tag:hover {
        background: #E1E7EF;
    }

    .dash-dim-tag.active {
        background: #1A4E6B;
        color: white;
    }

    .dash-dg-tablewrap {
        overflow-x: auto;
    }

    .dash-dg-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'Calibri', sans-serif;
    }

    .dash-dg-table th {
        font-size: 9px;
        font-weight: 700;
        color: #8A97A8;
        letter-spacing: 0.6px;
        text-transform: uppercase;
        padding: 6px 4px;
        border-bottom: 1px solid #EEF1F5;
        text-align: center;
        white-space: nowrap;
    }

    .dash-dg-col-segment {
        text-align: left !important;
        padding-left: 4px !important;
    }

    .dash-dg-col-total {
        background: #F7FBFE;
        font-weight: 700;
        color: #1A4E6B !important;
    }

    .dash-dg-table tbody tr {
        border-bottom: 1px solid #F5F7FA;
        transition: background 0.12s ease;
    }

    .dash-dg-table tbody tr:hover {
        background: #FAFBFC;
    }

    .dash-dg-table tbody td {
        padding: 9px 4px;
        font-size: 11px;
        text-align: center;
        color: #2C3E50;
    }

    .dash-dg-seg-label {
        text-align: left !important;
        font-weight: 600;
        color: #1A4E6B;
        font-size: 11px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        max-width: 140px;
    }

    .dash-dg-cell {
        font-weight: 600;
        border-radius: 3px;
    }

    .dash-dg-card .dash-placeholder {
        color: #B0BAC5;
        text-align: center;
        padding: 30px;
        font-style: italic;
        font-size: 12px;
    }
</style>

@code {
    [Parameter] public Dictionary<string, Dictionary<string, int>>? Distribution { get; set; }
    [Parameter] public List<string> Colonnes { get; set; } = new();
    [Parameter] public string Dimension { get; set; } = "Region";
    [Parameter] public EventCallback<string> DimensionChanged { get; set; }

    private async Task Switch(string dim)
    {
        if (dim == Dimension) return;
        Dimension = dim;
        await DimensionChanged.InvokeAsync(dim);
    }

    private string LabelDim() => Dimension switch
    {
        "Secteur" => "secteur",
        "Agence"  => "agence",
        _         => "région"
    };

    private string GetCellStyle(double intensity)
    {
        if (intensity <= 0) return "color:#C5CBD3";
        var opacity = intensity / 100.0 * 0.7;
        return $"background:rgba(74,128,181,{opacity.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)});color:{(intensity > 50 ? "#0A2540" : "#1A4E6B")}";
    }

    private string Abrege(string nom)
    {
        if (string.IsNullOrWhiteSpace(nom)) return "";
        if (nom.Length <= 12) return nom;
        return nom[..12] + "…";
    }

    private string FormatCompact(int value)
    {
        if (value >= 1_000_000) return $"{value / 1_000_000.0:F1}M";
        if (value >= 1_000)     return $"{value / 1_000.0:F0}K";
        return value.ToString("N0");
    }
}
